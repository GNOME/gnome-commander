msgstr ""
"Esta opção define se linhas de texto longas demais devem ser quebradas."

#: data/org.gnome.gnome-commander.gschema.xml:1032
msgid "Tab size"
msgstr "Tamanho do tab"

#: data/org.gnome.gnome-commander.gschema.xml:1033
