msgstr "Результат проверки:"

#: plugins/fileroller/file-roller-plugin.cc:676
msgid ""
"Use $N as a pattern for the original file name. See the manual page for "
"“strftime” for other patterns."
msgstr ""
"Используйте $N как шаблон исходного имени файла. Смотрите man-страницу "
"«strftime» для получения информации о других шаблонах."

#: plugins/fileroller/file-roller-plugin.cc:787
msgid ""
"A plugin that adds File Roller shortcuts for creating and extracting "
"compressed archives."
msgstr "Модуль, использующий File-Roller для создания и извлечения архивов."

#: plugins/gsf/gsf-plugin.cc:64 plugins/poppler/poppler-plugin.cc:60
msgid "Author"
msgstr "Автор"

#: plugins/gsf/gsf-plugin.cc:65
msgid ""
"An entity primarily responsible for making the content of the resource, "
"typically a person, organization, or service."
msgstr ""
"Сущность, первоначально ответственная за создание содержимого ресурса; как "
"правило — человек, организация или служба."

#: plugins/gsf/gsf-plugin.cc:66 plugins/poppler/poppler-plugin.cc:57
msgid "Title of the document."
msgstr "Заглавие документа."

#: plugins/gsf/gsf-plugin.cc:67 plugins/poppler/poppler-plugin.cc:58
msgid "Subject"
msgstr "Тема"

#: plugins/gsf/gsf-plugin.cc:67 plugins/poppler/poppler-plugin.cc:58
msgid "Document subject."
msgstr "Тема документа."

#: plugins/gsf/gsf-plugin.cc:68
msgid "An account of the content of the resource."
msgstr "Учётная запись содержимого ресурса."

#: plugins/gsf/gsf-plugin.cc:69
msgid "Category."
msgstr "Категория."

#: plugins/gsf/gsf-plugin.cc:70 plugins/poppler/poppler-plugin.cc:59
msgid "Searchable, indexable keywords."
msgstr "Ключевые слова для поиска и индексации."

#: plugins/gsf/gsf-plugin.cc:71
msgid "Revision Count"
msgstr "Количество исправлений"

#: plugins/gsf/gsf-plugin.cc:71
msgid "Number of revision on the document."
msgstr "Количество исправлений в документе."

#: plugins/gsf/gsf-plugin.cc:72 plugins/poppler/poppler-plugin.cc:55
msgid "Page Count"
msgstr "Количество страниц"

#: plugins/gsf/gsf-plugin.cc:72 plugins/gsf/gsf-plugin.cc:104
#: plugins/poppler/poppler-plugin.cc:55
msgid "Number of pages in the document."
msgstr "Количество страниц в документе."

#: plugins/gsf/gsf-plugin.cc:73
msgid "Paragraph Count"
msgstr "Количество параграфов"

#: plugins/gsf/gsf-plugin.cc:73
msgid "Number of paragraphs in the document."
msgstr "Количество параграфов в документе."

#: plugins/gsf/gsf-plugin.cc:74
msgid "Line Count"
msgstr "Количество строк"

#: plugins/gsf/gsf-plugin.cc:74
msgid "Number of lines in the document."
msgstr "Количество строк в документе."

#: plugins/gsf/gsf-plugin.cc:75
msgid "Word Count"
msgstr "Количество слов"

#: plugins/gsf/gsf-plugin.cc:75
msgid "Number of words in the document."
msgstr "Количество слов в документе."

#: plugins/gsf/gsf-plugin.cc:76
msgid "Byte Count"
msgstr "Количество байтов"

#: plugins/gsf/gsf-plugin.cc:76
msgid "Number of bytes in the document."
msgstr "Количество байтов в документе."

#: plugins/gsf/gsf-plugin.cc:77
msgid "Cell Count"
msgstr "Количество ячеек"

#: plugins/gsf/gsf-plugin.cc:77
msgid "Number of cells in the spreadsheet document."
msgstr "Количество ячеек в табличном документе."

#: plugins/gsf/gsf-plugin.cc:78
msgid "Character Count"
msgstr "Количество символов"

#: plugins/gsf/gsf-plugin.cc:78
msgid "Number of characters in the document."
msgstr "Количество символов в документе."

#: plugins/gsf/gsf-plugin.cc:79
msgid "Codepage"
msgstr "Кодовая страница"

#: plugins/gsf/gsf-plugin.cc:79
msgid "The MS codepage to encode strings for metadata."
