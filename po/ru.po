msgstr "Отношение фокусного расстояния объектива к диаметру диафрагмы."

#: plugins/exiv2/exiv2-plugin.cc:75 plugins/exiv2/exiv2-plugin.cc:94
msgid "Focal Length"
msgstr "Фокусное расстояние"

#: plugins/exiv2/exiv2-plugin.cc:75
msgid "Focal length of lens in mm."
msgstr "Фокусное расстояние объектива в мм."

#: plugins/exiv2/exiv2-plugin.cc:76
msgid "ISO Speed"
msgstr "Скорость ISO"

#: plugins/exiv2/exiv2-plugin.cc:76
