msgstr "Μορφή μεγέθους σελίδας."

#: plugins/poppler/poppler-plugin.cc:66
msgid "Page Width"
msgstr "Πλάτος σελίδας"

#: plugins/poppler/poppler-plugin.cc:66
msgid "Page width in mm."
msgstr "Πλάτος σελίδας σε χιλιοστά"

#: plugins/poppler/poppler-plugin.cc:67
msgid "Page Height"
