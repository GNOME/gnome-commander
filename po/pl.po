msgstr "Ta opcja określa tryb wyszukiwania wewnętrznej przeglądarki."

#. Translators: This is the default string of encoding used by the internal
#. viewer
#. for displaying the file in the given encoding. You may want to customize it
#. by using
#. an encoding that is common in your country.
#. See https://gitlab.gnome.org/GNOME/gnome-
#. commander/-/blob/main/src/intviewer/window.rs#L776 for
#. a list of supported encodings.
#: data/org.gnome.gnome-commander.gschema.xml:1002
msgid "'UTF8'"
msgstr "'UTF8'"

#: data/org.gnome.gnome-commander.gschema.xml:1003
msgid "Character set"
msgstr "Zestaw znaków"

#: data/org.gnome.gnome-commander.gschema.xml:1004
