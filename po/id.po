msgstr "Tinggi jendela penampil berkas internal."

#: data/org.gnome.gnome-commander.gschema.xml:1067
msgid "Search pattern for text"
msgstr "Pola pencarian teks"

#: data/org.gnome.gnome-commander.gschema.xml:1068
