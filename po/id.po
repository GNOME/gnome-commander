#: plugins/poppler/poppler-plugin.cc:77
msgid "Commenting"
msgstr "Mengomentari"

#: plugins/poppler/poppler-plugin.cc:77
msgid "Set to “1” if adding or modifying text annotations is allowed."
msgstr "Isi dengan \"1\" bila menambah atau mengubah anotasi teks diperbolehkan."

#: plugins/poppler/poppler-plugin.cc:78
msgid "Form Filling"
msgstr "Pengisian Formulir"

#: plugins/poppler/poppler-plugin.cc:78
msgid "Set to “1” if filling of form fields is allowed."
msgstr "Isi dengan \"1\" bila mengisi ruas-ruas formulir diizinkan."

#: plugins/poppler/poppler-plugin.cc:79
msgid "Accessibility Support"
msgstr "Dukungan Aksesibilitas"

#: plugins/poppler/poppler-plugin.cc:79
msgid "Set to “1” if accessibility support (e.g. screen readers) is enabled."
msgstr ""
