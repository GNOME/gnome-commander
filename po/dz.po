msgstr "དྭངས་ཤེལ་པར་ཆས་དོང་ཆུང་འདི། ཆ་ཕྲན་འདི་ཨེ་པི་ཨི་ཨེགསི་གནས་གོང་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:111
msgid ""
"Name of the camera owner, photographer or image creator. The detailed format"
" is not specified, but it is recommended that the information be written for"
" ease of Interoperability. When the field is left blank, it is treated as "
"unknown."
msgstr ""
"པར་ཆས་བདག་པོ་ དཔར་བཏབ་མི་ཡང་ན་གཟུགས་བརྙན་གསར་བསྐྲུན་འབད་མི་འདི་གི་མིང་། "
"རྩ་སྒྲིག་རྒྱས་བཤད་འདི་གསལ་བཀོད་མ་འབད་བར་ཡོདཔ་ "
"ཨིན་རུང་ཨིན་ཊར་ཨོ་པརེ་བི་ལི་ཊི་གི་ལྷོད་ལྷོད་དོན་ལུ་བརྡ་དོན་འདི་འབྲི་དགོཔ་སྦེ་འོས་སྦྱོར་འབད་ཡོདཔ།"
" ས་སྒོ་འདི་སྟོངམ་སྦེ་བཞག་པའི་སྐབས་འདི་ལུ་མ་ཤེསཔ་སྦེ་བརྩི་འཇོག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:112
msgid "Battery Level"
msgstr "འཕྲུལ་ལྟོ་གནས་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:112
msgid "Battery level."
msgstr "འཕྲུལ་ལྟོ་ གནས་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:113
msgid "Bits per Sample"
msgstr "དཔེ་ཚད་རེ་རེ་བིཊིསི།"

#: plugins/exiv2/exiv2-plugin.cc:113
msgid ""
"The number of bits per image component. Each component of the image is 8 "
"bits, so the value for this tag is 8. In JPEG compressed data a JPEG marker "
"is used instead of this tag."
msgstr ""
"གཟུགས་བརྙན་ཆ་ཤས་རེ་རེ་བིཊིསི་རེ་གི་ཨང་འདི། "
"གཟུགས་བརྙན་འདི་གི་ཆ་ཤས་རེ་རེ་ལུ་བིཊིསི་ ༨ "
"རེ་ཡོདཔ་ལས་ངོ་རྟགས་འདི་གི་གནས་གོང་འདི་་ ༨་ཨིན། "
"ཇེ་པི་ཨི་ཇི་་ཨེབ་བཙུགས་གནས་སྡུད་ནང་ངོ་རྟགས་འདི་གི་ཚབ་ལུ་ཇེ་པི་ཨི་ཇི་རྟགས་བཀོད་པ་ཅིག་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:114
msgid "Brightness"
msgstr "དཀར་མདངས།"

#: plugins/exiv2/exiv2-plugin.cc:114
msgid ""
"The value of brightness. The unit is the APEX value. Ordinarily it is given "
"in the range of -99.99 to 99.99."
msgstr ""
"དཀར་མདངས་ཀྱི་གནས་གོང་འདི། ཆ་ཕྲན་འདི་ཨེ་པི་ཨི་ཨེགསི་གནས་གོང་ཨིན། "
"དཀྱུ་མ་སྦེ་འདི་ཁྱབ་ཚད་ -༩༩.༩༩ ལས་༩༩.༩༩་ནང་ལུ་བྱིན་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:115 plugins/exiv2/exiv2-plugin.cc:159
msgid "CFA Pattern"
msgstr "སི་ཨེཕ་ཨེ་དཔེ་གཞི།"

#: plugins/exiv2/exiv2-plugin.cc:115 plugins/exiv2/exiv2-plugin.cc:159
msgid ""
"The color filter array (CFA) geometric pattern of the image sensor when a "
"one-chip color area sensor is used. It does not apply to all sensing "
"methods."
msgstr ""
"ཅིབས་ཚོས་གཞི་མངའ་ཁོངས་ཚོར་འཕྲུལ་གཅིག་འདི་ལག་ལེན་འཐབ་ཡོད་པའི་སྐབས་གཟུགས་བརྙན་ཚོར་འཕྲུལ་འདི་གི་ཚོས་གཞི་ཚགས་མ་ཨེ་རེ་(སི་ཨེཕ་ཨེ་)ཐིག་རྩིས་ཀྱི་དཔེ་གཞི་འདི།"
" འདི་གིས་ཚོར་འཕྲུལ་ཐབས་ལམ་ཚུ་ཆ་མཉམ་ལུ་འཇུག་སྤྱོད་མི་འབད།"

#: plugins/exiv2/exiv2-plugin.cc:116
msgid "CFA Repeat Pattern Dim"
msgstr "སི་ཨེཕ་ཨེ་ཡང་བསྐྱར་དཔེ་ཚད་མདངས་གྲིབ།"

#: plugins/exiv2/exiv2-plugin.cc:116
msgid "CFA Repeat Pattern Dim."
msgstr "སི་ཨེཕ་ཨེ་ ཡང་བསྐྱར་དཔེ་གཞི་མདངས་སྒྲིབ།"

#: plugins/exiv2/exiv2-plugin.cc:107
msgid "Color Space"
msgstr "ཚོས་གཞི་བར་སྟོང་།"

#: plugins/exiv2/exiv2-plugin.cc:107
msgid ""
"The color space information tag is always recorded as the color space "
"specifier. Normally sRGB is used to define the color space based on the PC "
"monitor conditions and environment. If a color space other than sRGB is "
"used, Uncalibrated is set. Image data recorded as Uncalibrated can be "
"treated as sRGB when it is converted to FlashPix."
msgstr ""
"ཚོས་གཞི་བར་སྟོང་བརྡ་དོན་ངོ་རྟགས་འདི་ཨ་རྟག་རང་ཚོས་གཞི་བར་སྟོང་གསལ་བཀོད་པ་སྦེ་སྒྲ་བཟུང་ཡོདཔ་ཨིན།"
" "
"སྤྱིར་བཏང་ཨེསི་ཨར་ཇི་བི་(=1)འདི་པི་སི་ལྟ་རྟོག་པ་གནས་སྟངས་ཚུ་དང་མཐའ་འཁོར་འདི་གུ་གཞི་བཞག་ཡོད་མི་ཚོས་གཞི་བར་སྟོང་འདི་ངེས་འཛིན་འབད་ནི་ལུ་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"
" ཚོས་གཞི་བར་སྟོང་ཅིག་ལས་གཞན་ཨེསི་ཨར་ཇི་བི་འདི་ལག་ལེན་འཐབ་ཡོད་པ་ཅིན་ "
"ཚད་རྟགས་བཀལ་བཤོལ་འདི་གཞི་སྒྲིག་ཡོདཔ་ཨིན། "
"གཟུགསབརྙན་གནས་སྡུད་ཚད་རྟགས་བཀལ་བཤོལ་སྦེ་སྒྲ་བཟུང་ཡོད་མི་འདི་རིབ་སྟོན་པར་ལུ་གཞི་བསྒྱུར་འབད་ཚར་བའི་སྐབས་ཨེསི་ཨར་ཇི་བི་སྦེ་བརྩི་འཇོག་འབདཝ་ཨིན།"
" "

#: plugins/exiv2/exiv2-plugin.cc:117
msgid "Components Configuration"
msgstr "རིམ་སྒྲིག་ཆ་ཤས་ཚུ།"

#: plugins/exiv2/exiv2-plugin.cc:117
msgid ""
"Information specific to compressed data. The channels of each component are "
"arranged in order from the 1st component to the 4th. For uncompressed data "
"the data arrangement is given in the <Exif.PhotometricInterpretation> tag. "
"However, since <Exif.PhotometricInterpretation> can only express the order "
"of Y, Cb and Cr, this tag is provided for cases when compressed data uses "
"components other than Y, Cb, and Cr and to enable support of other "
"sequences."
msgstr ""
"བརྡ་དོན་ཨེབ་བཙུགས་གནས་སྡུད་ལུ་དམིགས་བསལ་འབད། ཆ་ཤས་རེ་རེ་གི་རྒྱུན་ལམ་ཚུ་ "
"ཆ་ཤས་དང་པ་ལས་ཆ་ཤས་བཞི་པ་འདི་ལུ་གོ་རིམ་ནང་བདེ་ཞིབ་འབད་ཡོདཔ་ཨིན། "
"ཨེབ་བཙུགས་བཤོལ་ཡོད་མི་བཞི་་འདི་གནས་སྡུད་བདེ་ཞིབ་འདི་<Exif.PhotometricInterpretation>ངོ་རྟགས་འདི་ནང་གྲ་སྒྲིག་ཡོདཔ་ཨིན།"
" ག་དེ་འབད་རུང་<Exif.PhotometricInterpretation>གིས་རྐྱངམ་ཅིག་ ཝའི་ "
"སི་བི་དང་སི་ཨར་གྱི་གོ་རིམ་འདི་སླབ་ཚུགསཔ་ལས་ཚུར་ "
"ཨེབ་བཙུགས་འབད་ཡོད་མི་གནས་སྡུད་ཀྱིས་ཝའི་ སི་བི་ དང་སི་ཨར་ "
"ལས་གཞན་ཆ་ཤས་ཚུ་ལག་ལེན་འཐབ་ནི་དང་གཞན་འབྱུང་རིམ་ཚུ་གི་རྒྱབ་སྐྱོར་ལྕོགས་ཅན་བཟོ་ནི་ལུ་ལག་ལེན་འཐབ་བཏུབ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:118
msgid "Compressed Bits per Pixel"
msgstr "པིག་སེལ་རེ་ལུ་བིཊིསི་ཨེབ་བཙུགས་ཡོདཔ།"

#: plugins/exiv2/exiv2-plugin.cc:118
msgid ""
"Information specific to compressed data. The compression mode used for a "
"compressed image is indicated in unit bits per pixel."
msgstr ""
"ཨེབ་བཙུགས་གནས་སྡུད་ལུ་བརྡ་དོན་དམིགས་བསལ། "
"ཨེབ་བཙུགས་གཟུགས་བརྙན་ཅིག་གི་དོན་ལུ་ལག་ལེན་འཐབ་ཡོད་མི་ཨེབ་བཙུགས་ཐབས་ལམ་འདི་ཆ་ཕྲན་བིཊིསི་པིག་སེལ་རེ་རེ་ནང་བརྡ་སྟོན་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:119
msgid "Compression"
msgstr "ཨེབ་བཙུགས།"

#: plugins/exiv2/exiv2-plugin.cc:119
msgid ""
"The compression scheme used for the image data. When a primary image is JPEG"
" compressed, this designation is not necessary and is omitted. When "
"thumbnails use JPEG compression, this tag value is set to 6."
msgstr ""
"གཟུགས་བརྙན་གནས་སྡུད་འདི་གི་དོན་ལུ་ལག་ལེན་འཐབ་ཡོད་མི་ཨེབ་བཙུགས་ལས་འཆར་འདི། "
"གཞི་རིམ་གཟུགས་བརྙན་འདི་ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་ཡོད་པའི་སྐབས་གོ་གནས་འདི་ཉེར་མཁོ་མེདཔ་ལས་འདི་སྐྱུར་བཞག་ཡོདཔ་ཨིན།་མཐེ་གཟེར་ཚུ་གི་ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་ལག་ལེན་འཐབ་པའི་སྐབས་ངོ་རྟགས་གནས་གོང་འདི་"
" ༦་ ལུ་གཞི་སྒྲིག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:120
msgid "Contrast"
msgstr "ཚོན་མདངས།"

#: plugins/exiv2/exiv2-plugin.cc:120
msgid ""
"The direction of contrast processing applied by the camera when the image "
"was shot."
msgstr ""
"པར་ཆས་ཀྱིས་གཟུགས་བརྙན་འདི་པར་བཏབ་ཡོད་པའི་སྐབས་མཚོན་མདངས་བཟོ་སྦྱོར་གྱི་འཇུག་སྤྱོད་འབད་ཡོད་མི་བཀོད་རྒྱ་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:106
msgid "Custom Rendered"
msgstr "སྲོལ་སྒྲིག་ལྷག་སྟོན་འབད་ཡོདཔ།"

#: plugins/exiv2/exiv2-plugin.cc:106
msgid ""
"The use of special processing on image data, such as rendering geared to "
"output. When special processing is performed, the reader is expected to "
"disable or minimize any further processing."
msgstr ""
"གཟུགས་བརྙན་གནས་སྡུད་གུ་་དམིགས་བསལ་ལས་སྦྱོར་གྱི་ལག་ལེན་འཐབ་ནི་འདི་ "
"དཔེར་ན་པའུཊི་པུཊི་ལུ་གི་ཡརཌི་ལྷག་སྟོན་བཟུམ་ཨིན། "
"དམིགས་བསལ་ལས་སྦྱོར་འདི་ལས་འགན་འགྲུབ་ཡོད་པའི་སྐབས་ "
"ལྷག་མི་འདི་གིས་ལས་སྦྱོར་ཐབས་གང་རུང་ཆུང་ཀུ་བཟོ་ནི་ཡང་ན་ལྕོགས་མིན་བཟོ་ནི་ལུ་རེ་བ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:87
msgid "Date and Time"
msgstr "ཚེས་གྲངས་དང་དུས་ཚོད།"

#: plugins/exiv2/exiv2-plugin.cc:87
msgid "The date and time of image creation."
msgstr "གཟུགས་བརྙན་གསར་བསྐྲུན་འབད་ནི་གི་ཚེས་གྲངས་དང་དུས་ཚོད།"

#: plugins/exiv2/exiv2-plugin.cc:121
msgid "Date and Time (digitized)"
msgstr "ཚེས་གྲངས་དང་དུས་ཚོད(ཨང་ཡིག་བཟོ་ཡོད་མི།)"

#: plugins/exiv2/exiv2-plugin.cc:121
msgid "The date and time when the image was stored as digital data."
msgstr ""
"གཟུགས་བརྙན་འདི་ཌི་ཇི་ཊཱལ་གནས་སྡུད་སྦེ་གསོག་འཇོག་འབད་ཡོད་པའི་སྐབས་ཚེས་གྲངས་དང་དུས་ཚོད་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:122
msgid "Date and Time (original)"
msgstr "ཚེས་གྲངས་དང་དུས་ཚོད(ངོ་མ།)།"

#: plugins/exiv2/exiv2-plugin.cc:122
msgid ""
"The date and time when the original image data was generated. For a digital "
"still camera the date and time the picture was taken are recorded."
msgstr ""
"གཟུགས་བརྙན་གནས་སྡུད་ངོ་མ་འདི་བཟོ་བཏོན་འབད་ཡོད་མི་གི་ཚེས་གྲངས་དང་དུས་ཚོད་འདི།"
" "
"ཌི་ཇི་ཊཱལ་འགུལ་མེད་པར་ཆས་ཅིག་གི་དོན་ལུ་ཚེས་གྲངས་དང་དུས་ཚོད་འདི་ནང་བཏབ་མི་པར་འདི་དྲན་ཐོ་འབད་ཡོདཔ་ཨིན།"
" "

#: plugins/exiv2/exiv2-plugin.cc:123
msgid "Device Setting Description"
msgstr "ཐབས་འཕྲུལ་སྒྲིག་སྟངས་འགྲེལ་བཤད།"

#: plugins/exiv2/exiv2-plugin.cc:123
msgid ""
"Information on the picture-taking conditions of a particular camera model. "
"The tag is used only to indicate the picture-taking conditions in the "
"reader."
msgstr ""
"བྱེ་བྲག་པར་ཆས་དཔེ་ཅིག་གི་པར་བཏབ་ནི་གནས་སྟངས་ཚུ་གུ་བརྡ་དོན། "
"ངོ་རྟགས་འདི་ལྷག་ནི་ནང་པར་བཏབ་ནི་གནས་སྟངས་ཚུ་བརྡ་སྟོན་ནི་ལུ་རྐྱངམ་ཅིག་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:124
msgid "Digital Zoom Ratio"
msgstr "ཌི་ཇི་ཊཱལ་རྒྱས་ཟུམ་དཔྱ་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:124
msgid ""
"The digital zoom ratio when the image was shot. If the numerator of the "
"recorded value is 0, this indicates that digital zoom was not used."
msgstr ""
"གཟུགས་བརྙན་དེ་པར་བཏབ་པའི་སྐབས་ཌི་ཇི་ཊཱལ་རྒྱས་ཟུམ་དཔྱད་ཚད་འདི། "
"དཔྱ་གྲངས་འདི་གི་སྒྲ་བཟུང་འབད་ཡོད་མི་གནས་གོང་འདི་ ༠ ཨིན་པ་ཅིན་ "
"ཌི་ཇི་ཊཱལ་རྒྱས་ཟུམ་དེ་ལག་ལེན་མ་འཐབ་པར་ཡོདཔ།"

#: plugins/exiv2/exiv2-plugin.cc:108
msgid "Document Name"
msgstr "ཡིག་ཆ་མིང་།"

#: plugins/exiv2/exiv2-plugin.cc:108
msgid "Document name."
msgstr "ཡིག་ཆའི་མིང་།"

#: plugins/exiv2/exiv2-plugin.cc:125
msgid "Exif Version"
msgstr "ཨི་ཨེགསི་ཨའི་ཨེཕ་ཐོན་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:125
msgid ""
"The version of Exif standard supported. Nonexistence of this field is taken "
"to mean nonconformance to the standard."
msgstr ""
"ཨི་ཨེགསི་ཨའི་ཨེཕ་ཚད་ལྡན་རྒྱབ་སྐྱོར་འབད་ཡོད་མི་གི་ཐོན་རིམ་འདི། "
"ས་སྒོ་འདི་གནས་པ་མེན་མི་ལུ་ཚད་ལྡན་འདི་ལུ་ངེས་དཔྱད་འབད་མེནམ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:88
msgid "Exposure Bias"
msgstr "མདངས་ཕོག་ཕྱོགས་རིས།"

#: plugins/exiv2/exiv2-plugin.cc:88
msgid ""
"The exposure bias. The units is the APEX value. Ordinarily it is given in "
"the range of -99.99 to 99.99."
msgstr ""
"ཙདངས་ཕོག་ཕྱོགས་རིས་འདི། ཆ་ཕྲན་འདི་ཨེ་པི་ཨི་ཨེགསི་གནས་གོང་འདི་ཨིན། "
"ཁྱབ་ཚད་འདི་ནང་གི་-༩༩.༩༩ ལས་༩༩.༩༩་ལུ་བྱིན་ཡོད་མི་འདི་ངོ་མ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:126
msgid "Exposure Index"
msgstr "མདངས་ཕོག་ཟུར་ཐོ།"

#: plugins/exiv2/exiv2-plugin.cc:126
msgid ""
"The exposure index selected on the camera or input device at the time the "
"image is captured."
msgstr ""
"པར་ཆས་ཡང་ན་ཨིན་པུཊི་ཐབས་འཕྲུལ་གུ་སེལ་འཐུ་འབད་ཡོད་མི་མདངས་ཕོག་ཟུར་ཐོ་འདི་དུས་ཚོད་ལུ་གཟུགས་བརྙན་འདི་འཛིན་བཟུང་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:89
msgid "Exposure Mode"
msgstr "མདངས་ཕོག་ཐབས་ལམ།"

#: plugins/exiv2/exiv2-plugin.cc:71 plugins/exiv2/exiv2-plugin.cc:90
msgid "Exposure Program"
msgstr "མདངས་ཕོག་ལས་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:90
msgid ""
"The class of the program used by the camera to set exposure when the picture"
" is taken."
msgstr ""
"པར་བཏབ་པའི་སྐབས་མདངས་ཕོག་གཞི་སྒྲིག་ལུ་པར་ཆས་ཀྱིས་ལག་ལེཔ་འཐབ་ཡོད་མི་ལས་རིམ་འདི་གི་དབྱེ་རིགས་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:72 plugins/exiv2/exiv2-plugin.cc:127
msgid "Exposure Time"
msgstr "མདངས་ཕོག་དུས་ཚོད།"

#: plugins/exiv2/exiv2-plugin.cc:127
msgid "Exposure time, given in seconds."
msgstr "སྐར་ཆག་ཚུ་ནང་བྱིན་ཡོད་མི་མདངས་ཕོག་དུས་ཚོད།"

#: plugins/exiv2/exiv2-plugin.cc:128
msgid "File Source"
msgstr "ཡིག་སྣོད་འབྱུང་ཁུངས།"

#: plugins/exiv2/exiv2-plugin.cc:128
msgid ""
"Indicates the image source. If a DSC recorded the image, this tag value of "
"this tag always be set to 3, indicating that the image was recorded on a "
"DSC."
msgstr ""
"གཟུགས་བརྙན་འབྱུང་ཁུངས་འདི་བརྡ་སྟོནམ་ཨིན། "
"ཌི་ཨེསི་སི་ཅིག་གིས་གཟུགས་བརྙན་འདི་དྲན་ཐོ་བཀོད་ཡོད་པ་ཅིན་ གཟུགས་བརྙན་འདི་ "
"ཌི་ཨེསི་སི་ཅིག་གུ་དྲན་ཐོ་བཀོད་ཡོད་པའི་བརྡ་སྟོན་དེ་ "
"ངོ་རྟགས་གནས་གོང་འདི་གི་ངོ་རྟགས་འདི་ཨ་རྟག་རང་ ༣ ལུ་གཞི་སྒྲིག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:129
msgid "Fill Order"
msgstr "བཀོད་རྒྱ་བཀང་།"

#: plugins/exiv2/exiv2-plugin.cc:129
msgid "Fill order."
msgstr "ཡིག་སྣོད་ གོ་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:73 plugins/exiv2/exiv2-plugin.cc:91
msgid "Flash"
msgstr "རིབ་སྟོན།"

#: plugins/exiv2/exiv2-plugin.cc:91
msgid ""
"This tag is recorded when an image is taken using a strobe light (flash)."
msgstr ""
"སི་ཊོབ་འོད་ཅིག་ལག་ལེན་འཐབ་གཟུགས་བརྙན་ཅིག་བཏབ་པའི་སྐབས་ངོ་རྟགས་འདི་སྒྲ་བཟུང་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:92
msgid "Flash Energy"
msgstr "རིབ་སྟོན་ནུས་ཤུགས།"

#: plugins/exiv2/exiv2-plugin.cc:130
msgid "FlashPix Version"
msgstr "རིབ་སྟོན་པར་ཐོན་ཡིམ།"

#: plugins/exiv2/exiv2-plugin.cc:130
msgid "The FlashPix format version supported by a FPXR file."
msgstr ""
"ཨེཕ་པི་ཨེགསི་ཨར་ཡིག་སྣོད་ཅིག་གིས་རྒྱབ་སྐྱོར་འབད་ཡོད་མི་རིབ་སྟོན་པིགསི་རྩ་སྒྲིག་ཐོན་རིམ་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:74 plugins/exiv2/exiv2-plugin.cc:93
msgid "F Number"
msgstr "ཨེཕ་ཨང་།"

#: plugins/exiv2/exiv2-plugin.cc:74 plugins/exiv2/exiv2-plugin.cc:93
msgid ""
"Diameter of the aperture relative to the effective focal length of the lens."
msgstr ""
"དྭངས་ཤེལ་འདི་གི་ནུས་ཅན་ཕོ་ཀཱལ་རིང་ཚད་འདི་ལུ་འབྲེལ་བ་ཡོད་མི་པར་ཆས་དོང་ཆུང་འདི་གི་སྒོར་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:75 plugins/exiv2/exiv2-plugin.cc:94
msgid "Focal Length"
msgstr "ཕོ་ཀཱལ་རིང་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:94
msgid ""
"The actual focal length of the lens, in mm. Conversion is not made to the "
"focal length of a 35 mm film camera."
msgstr ""
"ཨེམ་ཨེམ་ནང་དྭངས་ཤེལ་འདི་གི་ཕོ་ཀཱལ་རིང་ཚད་ངོ་མ་འདི། ཨེམ་ཨེམ་ ༣༥ "
"གློག་བརྙན་པར་ཆས་ཅིག་གི་ཕོ་ཀཱལ་རིང་ཚད་འདི་ལུ་གཞི་བསྒྱུར་མ་བཟོ་བ་ཡོདཔ།"

#: plugins/exiv2/exiv2-plugin.cc:131
msgid "Focal Length In 35mm Film"
msgstr "ཨེམ་ཨེམ་ ༣༥་ གློག་བརྙན་ནང་ཕོ་ཀཱལ་རིང་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:132
msgid "Focal Plane Resolution Unit"
msgstr "ཕོ་ཀཱལ་བྱིལ་ལི་ཧུམ་ཆ་ཆ་ཕྲན།"

#: plugins/exiv2/exiv2-plugin.cc:133
msgid "Focal Plane x-Resolution"
msgstr "ཕོ་ཀཱལ་བྱིལ་ལི་ཨེགསི་ཧུམ་ཆ།"

#: plugins/exiv2/exiv2-plugin.cc:134
msgid "Focal Plane y-Resolution"
msgstr "ཕོ་ཀཱལ་བྱིལ་ལི་ཝའི་ཧུམ་ཆ།"

#: plugins/exiv2/exiv2-plugin.cc:135
msgid "Gain Control"
msgstr "ཚད་འཛིན་ཁེ་ཕན།"

#: plugins/exiv2/exiv2-plugin.cc:135
msgid "This tag indicates the degree of overall image gain adjustment."
msgstr ""
"ངོ་རྟགས་འདི་གིས་གཟུགས་བརྙན་ཁེ་ཕན་བདེ་སྒྲིག་ཡོངས་བསྡོམས་ཀྱི་དབྱེ་རིམ་འདི་བརྡ་སྟོནམ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:136
msgid "Gamma"
msgstr "གམ་མ།"

#: plugins/exiv2/exiv2-plugin.cc:136
msgid "Indicates the value of coefficient gamma."
msgstr "གྲངས་རྟགས་གམ་མ་གི་གནས་གོང་འདི་བརྡ་སྟོནམ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:137
msgid "Altitude"
msgstr "ས་ཁའི་མཐོ་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:137
msgid ""
"Indicates the altitude based on the reference in <Exif.GPS.AltitudeRef>. The"
" reference unit is meters."
msgstr ""
"ནང་་གཞི་བསྟུན་འབད་མི་གུ་ "
"<Exif.GPS.AltitudeRef>ས་ཁའི་མཐོ་ཚད་གཞི་བཞག་འདི་བརྡ་སྟོནམ་ཨིན།  "
"གཞི་བསྟུན་ཆ་ཕྲན་འདི་མི་ཊར་ཚུ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:138
msgid "Altitude Reference"
msgstr "ས་ཁའི་མཐོ་ཚད་གཞི་བསྟུན།"

#: plugins/exiv2/exiv2-plugin.cc:138
msgid ""
"Indicates the altitude used as the reference altitude. If the reference is "
"sea level and the altitude is above sea level, 0 is given. If the altitude "
"is below sea level, a value of 1 is given and the altitude is indicated as "
"an absolute value in the <Exif.GPS.Altitude> tag. The reference unit is "
"meters."
msgstr ""
"ས་ཁའི་མཐོ་ཚད་གཞི་བསྟུན་སྦེ་ལག་ལེན་འཐབ་ཡོད་མི་ས་ཁའི་མཐོ་ཚད་འདི་བརྡ་སྟོནམ་ཨིན།"
" "
"གཞི་བསྟུན་འདི་མཚོ་གནས་རིམ་དང་ས་ཁའི་མཐོ་ཚད་འདི་མཚོའི་ལྟག་གི་གནས་རིམ་ཨིན་པ་ཅིན་"
" ༠་ བྱིན་ཡོདཔ་ཨིན། ས་ཁའི་མཐོ་ཚད་འདི་མཚོའི་འོག་ལས་ཨིན་པཅིན་ གནས་གོང་འདི་ ༡ "
"བྱིན་ཡོདཔ་དང་ ས་ཁའི་མཐོ་ཚད་འདི་<Exif.GPS.Altitude> "
"ངོ་རྟགས་འདི་ནང་གནས་གོང་ཡང་དག་སྦེ་བརྡ་སྟོན་ཡོདཔ་ཨིན། "
"གཞི་བསྟུན་ཆ་ཕྲན་འདི་མི་ཊར་ཚུ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:139
msgid "GPS Info IFDPointer"
msgstr "ཇི་པི་ཨེསི་བརྡ་དོན་ཨའི་ཨེཕ་ཌི་དཔག་བྱེད།"

#: plugins/exiv2/exiv2-plugin.cc:139
msgid ""
"A pointer to the GPS Info IFD. The Interoperability structure of the GPS "
"Info IFD, like that of Exif IFD, has no image data."
msgstr ""
"ཇི་པི་ཨེསི་བརྡ་དོན་ཨའི་ཨེཕ་ཌི་འདི་ལུ་དཔག་བྱེད་ཅིག "
"ཨི་ཨེགསི་ཨའི་ཨེཕ་ཨའི་ཨེཕ་ཌི་བཟུམ་འབད་མི་ཇི་པི་ཨེསི་བརྡ་དོན་ཨའི་ཨེཕ་ཌི་གཞི་བཀོད་འགོ་བརྗོད་གླུ་གཞས་པ་བཏུབ་མི་ལུ་གཞུགས་བརྙན་གནས་སྡུད་མེད།"

#: plugins/exiv2/exiv2-plugin.cc:140
msgid "Latitude"
msgstr "སྐེད་ཐིག"

#: plugins/exiv2/exiv2-plugin.cc:140
msgid ""
"Indicates the latitude. The latitude is expressed as three RATIONAL values "
"giving the degrees, minutes, and seconds, respectively. When degrees, "
"minutes and seconds are expressed, the format is dd/1,mm/1,ss/1. When "
"degrees and minutes are used and, for example, fractions of minutes are "
"given up to two decimal places, the format is dd/1,mmmm/100,0/1."
msgstr ""
"ལྷོ་བྱང་མཚམས་ཐིག་འདི་བརྡ་སྟོནམ་ཨིན། ལྷ་བྱང་མཚམས་ཐིག་འདི་ "
"སྐར་མ་དང་སྐར་ཆ་ཚུ་རིམ་བཞིན་་གྲ་སྒྲིག་ཡོད་མི་དབྱེ་རིམ་མཚུངས་གྲངས་གནས་གོང་ཚུ་གསུམ་སྦེ་སླབ་ཡོདཔ་ཨིན།"
" དབྱེ་རིམ་ཚུ་ སྐར་མ་དང་སྐར་ཆག་ཚུ་སླབ་ཡོདཔ་ད་ རྩ་སྒྲིག་འདི་ ཌི་ཌི་/༡ "
"ཨེམ་ཨེམ་/༡ ཨེསི་ཨེསི/༡ ཨིན། དབྱེ་རིམ་ཚུ་དང་སྐར་མ་ཚུ་ལག་ལེན་འཐབ་ཡོདཔ་དང་ "
"དཔེར་ན་སྐར་མ་ཚུ་གི་དཔྱ་ཕྲན་ཚུ་བཅུ་ཚག་ས་གནས་གཉིས་ཚུན་ཚོད་གྲ་སྒྲིག་ཡོདཔ་ཨིན་རྩ་སྒྲིག་འདི་"
" ཌི་ཌི/༡ ཨེམ་ཨེམ་ཨེམ་ཨེམ/༡༠༠ ༠/༡ ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:141
msgid "North or South Latitude"
msgstr "ནུབ་ཡང་ན་ལྷོའི་སྐེད་ཐིག"

#: plugins/exiv2/exiv2-plugin.cc:142
msgid "Longitude"
msgstr "གཞུང་ཐིག"

#: plugins/exiv2/exiv2-plugin.cc:142
msgid ""
"Indicates the longitude. The longitude is expressed as three RATIONAL values"
" giving the degrees, minutes, and seconds, respectively. When degrees, "
"minutes and seconds are expressed, the format is ddd/1,mm/1,ss/1. When "
"degrees and minutes are used and, for example, fractions of minutes are "
"given up to two decimal places, the format is ddd/1,mmmm/100,0/1."
msgstr ""
"ལྷོ་བྱང་མཚམས་ཐིག་འདི་བརྡ་སྟོནམ་ཨིན།  "
"ལྷོ་བྱང་མཚམས་ཐིག་འདི་མཚུངས་གྲངས་གནས་གོང་དབྱེ་རིམ་གསུམ་སྦེ་ "
"སྐར་མ་དང་སྐར་ཆག་ཚུ་རིམ་བཞིན་སླབ་ཡོདཔ་ཨིན།  "
"དབྱེ་རིམ་ཚུ་སྐར་མ་དང་སྐར་ཆག་ཚུ་སླབ་ཡོདཔ་ད་ རྩ་སྒྲིག་འདི་ ཌི་ཌི་ཌི/༡ "
"ཨེམ་ཨེམ་/༡ ཨེསི་ཨེསི་/༡ ཨིན།  དབྱེ་རིམ་ཚུ་དང་སྐར་མ་ཚུ་ལག་ལེན་འཐབ་ཡོདཔ་དང་ "
"དཔེར་ན་ སྐར་མ་ཚུ་གི་དཔྱ་ཕྲན་ཚུ་ བཅུ་ཚག་ས་གནས་གཉིས་ཚུན་ཚོད་གྲ་སྒྲིག་ཡོདཔ་ཨིན་"
" རྩ་སྒྲིག་འདི་ ཌི་ཌི་ཌི་/༡ ཨེམ་ཨེམ་ཨེམ་ཨེམ་/༡༠༠ ༠/༡ ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:143
msgid "East or West Longitude"
msgstr "ཤར་ཡང་ན་ནུབ་ཀྱི་གཞུང་ཐིག"

#: plugins/exiv2/exiv2-plugin.cc:144
msgid "GPS Tag Version"
msgstr "ཇི་པི་ཨེསི་ངོ་རྟགས་ཐོན་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:144
msgid ""
"Indicates the version of <Exif.GPS.InfoIFD>. This tag is mandatory when "
"<Exif.GPS.Info> tag is present."
msgstr ""
"ཐོན་རིམ་ <Exif.GPS.InfoIFD>གྱི་བརྡ་སྟོནམ་ཨིན། ངོ་རྟགས་འདི་སྟོན་མའི་སྐབས་  "
"<Exif.GPS.Info> ངོ་རྟགས་འདི་ངེས་མཁོ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:145
msgid "Image Description"
msgstr "གཟུགས་བརྙན་འགྲེལ་བཤད།"

#: plugins/exiv2/exiv2-plugin.cc:104
msgid "Image Length"
msgstr "གཟུགས་བརྙན་རིང་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:104
msgid ""
"The number of rows of image data. In JPEG compressed data a JPEG marker is "
"used instead of this tag."
msgstr ""
"གཟུགས་བརྙན་གནས་སྡུད་ཀྱི་གྱལ་ཚུ་གི་ཨང་འདི། "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་གནས་སྡུད་ནང་ངོ་རྟགས་འདི་གི་ཚབ་མ་ཇེ་པི་ཨི་ཇི་རྟགས་བཀོད་པ་ཅིག་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:146
msgid "Image Resources Block"
msgstr "གཟུགས་བརྙན་ཐོན་ཁུངས་ཚུའི་སྡེབ་ཚན།"

#: plugins/exiv2/exiv2-plugin.cc:146
msgid "Image Resources Block."
msgstr "གཟུགས་བརྙན་ ཐོན་ཁུངས་ཚུ་གི་ སྡེབ་ཚན།"

#: plugins/exiv2/exiv2-plugin.cc:147
msgid "Image Unique ID"
msgstr "གཟུགས་བརྙན་མཐུན་མོང་མ་ཡིན་པའི་ཨའི་ཌི།"

#: plugins/exiv2/exiv2-plugin.cc:147
msgid ""
"This tag indicates an identifier assigned uniquely to each image. It is "
"recorded as an ASCII string equivalent to hexadecimal notation and 128-bit "
"fixed length."
msgstr ""
"ངོ་རྟགས་འདི་གིས་གཟུགས་བརྙན་རེ་རེ་ལུ་མཐུན་མོང་མ་ཡིན་པ་འགན་སྤྲོད་ཡོད་མི་ངོས་འཛིན་པ་ཅིག་བརྡ་སྟོནམ་ཨིན།"
" འདི་ཨེ་ཨེསི་ཨའི་ཨའི་ ཡིག་རྒྱུན་འདྲ་མཉམ་ཅིག་ཧེག་ཟ་ཌི་སི་མཱལ་་དབྱངས་རྟགས་དང་ "
"བིཊི་༡༢༨ རིང་ཚད་གཏན་བཟོ་ཡོད་མི་སྦེ་སྒྲ་བཟུང་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:105
msgid "Image Width"
msgstr "གཟུགས་བརྙན་རྒྱ་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:105
msgid ""
"The number of columns of image data, equal to the number of pixels per row. "
"In JPEG compressed data a JPEG marker is used instead of this tag."
msgstr ""
"གཟུགས་བརྙན་གནས་སྡུད་ཀྱི་ཀེར་ཐིག་ཚུ་གི་ཨང་འདི་ "
"གྱལ་རེ་གི་པིག་སེལ་ཚུ་གི་ཨང་འདི་ལུ་འདྲ་མཉམ་ཨིན། "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་གནས་སྡུད་ནང་ངོ་རྟགས་འདི་གི་ཚབ་མ་ཇེ་པི་ཨི་ཇི་རྟགས་བཀོད་པ་ཅིག་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:148
msgid "Inter Color Profile"
msgstr "ཕན་ཚུན་ཚོས་གཞི་གསལ་སྡུད།"

#: plugins/exiv2/exiv2-plugin.cc:148
msgid "Inter Color Profile."
msgstr "ཕན་ཚུན་ ཚོ་གཞི་ གསལ་སྡུད།"

#: plugins/exiv2/exiv2-plugin.cc:149
msgid "Interoperability Index"
msgstr "ཨིན་ཊར་ཨོ་པརེ་བི་ལི་ཊི་ཟུར་ཐོ།"

#: plugins/exiv2/exiv2-plugin.cc:150
msgid "Interoperability Version"
msgstr "ཨིན་ཊར་ཨོ་པརེ་བི་ལི་ཊི་ཐོན་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:150
msgid "Interoperability version."
msgstr "ཨིན་ཊར་ཨོ་པརེ་བི་ལི་ཊི་ ཐོན་རིམ།"

#: plugins/exiv2/exiv2-plugin.cc:151
msgid "An IPTC/NAA record."
msgstr ""

#: plugins/exiv2/exiv2-plugin.cc:95
msgid "ISO Speed Ratings"
msgstr "ཨའི་ཨེསི་ཨོ་མགྱོགས་ཚད་གོང་ཚད་ཚུ།"

#: plugins/exiv2/exiv2-plugin.cc:152
msgid "JPEG Interchange Format"
msgstr "ཇེ་པི་ཨི་ཇི་ཕན་ཚུན་བརྗེ་སོར་རྩ་སྒྲིག"

#: plugins/exiv2/exiv2-plugin.cc:152
msgid ""
"The offset to the start byte (SOI) of JPEG compressed thumbnail data. This "
"is not used for primary image JPEG data."
msgstr ""
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་མཐེ་གཟེར་གནས་སྡུད་ཀྱི་འགོ་བཙུགས་བཱའིཊི་(ཨེསི་ཨོ་ཨའི་)འདི་ལུ་པར་ལེན་འདི།"
" གཞི་རིམ་གཟུགས་བརྙན་ཇེ་པི་ཨི་ཇི་གནས་སྡུད་དོན་ལུ་ལག་ལེན་མ་འཐབ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:153
msgid "JPEG Interchange Format Length"
msgstr "ཇེ་པི་ཨི་ཇི་ཕན་ཚུན་བརྗེ་སོར་རྩ་སྒྲིག་རིང་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:153
msgid ""
"The number of bytes of JPEG compressed thumbnail data. This is not used for "
"primary image JPEG data. JPEG thumbnails are not divided but are recorded as"
" a continuous JPEG bitstream from SOI to EOI. Appn and COM markers should "
"not be recorded. Compressed thumbnails must be recorded in no more than 64 "
"Kbytes, including all other data to be recorded in APP1."
msgstr ""
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་ཡོད་མི་མཐེ་གཟེར་གནས་སྡུད་ཀྱི་བཱའིཊིསི་གི་ཨང་འདི། "
"འདི་གཞི་རིམ་གཟུགས་བརྙན་ཇེ་པི་ཨི་ཇི་གནས་སྡུད་ཀྱི་དོན་ལུ་ལག་ལེན་མི་འཐབ། "
"ཇེ་པི་ཨི་ཇི་མཐེ་གཟེར་ཚུ་བགོ་མེད་ཨིན་རུང་ "
"ཨེསི་ཨོ་ཨའི་ལས་ཨི་ཨོ་ཨའི་ལུ་བི་ཊི་རྒྱུན་རིམ་ཇེ་པི་ཨི་ཇི་འཕྲོ་མཐུད་ཅན་ཅིག་བཟུམ་སྦེ་སྒྲ་བཟུང་འབད་ཡོདཔ་ཨིན།"
" མཇུག་བསྣོད་དང་སི་ཨོ་ཨེམ་རྟགས་བཀོད་པ་ཚུ་སྒྲ་བཟུང་འབད་མི་དགོཔ་ཨིན། "
"ཨེབ་བཙུགས་མཐེ་གཟེར་ཚུ་ཀེ་བཱའིཊིསི་ ༦༤ ལས་མངམ་ནང་སྒྲ་བཟུང་འབད་ནི་ "
"གཞན་ཨེ་པི་པི་༡ "
"ནང་སྒྲ་བཟུང་འབད་དགོཔ་གནས་སྡུད་ཆ་མཉམ་གྲངས་སུ་བཙུགས་འབད་དགོཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:154
msgid "JPEG Procedure"
msgstr "ཇེ་པི་ཨི་ཇི་ བྱ་སྒོའི་ལམ་ལུགས་"

#: plugins/exiv2/exiv2-plugin.cc:155
msgid "Light Source"
msgstr "རིང་ཚད་འབྱུང་ཁུངས།"

#: plugins/exiv2/exiv2-plugin.cc:155
msgid "The kind of light source."
msgstr "རིང་ཚད་འབྱུང་ཁུངས་ཀྱི་དབྱེ་ཁག་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:156
msgid "Manufacturer"
msgstr "བཟོ་བསྐྲུན་པ།"

#: plugins/exiv2/exiv2-plugin.cc:156
msgid ""
"The manufacturer of the recording equipment. This is the manufacturer of the"
" DSC, scanner, video digitizer or other equipment that generated the image. "
"When the field is left blank, it is treated as unknown."
msgstr ""
"སྒྲ་བཟུང་མཁོ་ཆས་འདི་གི་བཟོ་བསྐྲུན་པ་འདི། "
"གཟུགས་བརྙན་འདི་བཟོ་བཏོན་འབད་ཡོད་མི་དེ་གཞན་མཁོ་ཆས་ཡང་ན་ཝི་ཌིའོ་ཌི་ཇི་ཊཱལ་ཛའིར་"
" པར་ལེན་འཕྲུལ་ཆས་ ཌི་ཨེསི་སི་འདི་གི་བཟོ་བསྐྲུན་པ་འདི་ཨིན། "
"ས་སྒོ་འདི་སྟོངམ་བཞགཔ་ད་འདི་མ་ཤེསཔ་སྦེ་བརྩི་འཇོག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:157
msgid "Maker Note"
msgstr "དྲན་འཛིན་བཟོ་མི།"

#: plugins/exiv2/exiv2-plugin.cc:157
msgid ""
"A tag for manufacturers of Exif writers to record any desired information. "
"The contents are up to the manufacturer."
msgstr ""
"རེ་འདུན་ཡོད་མི་བརྡ་དོན་གང་རུང་སྒྲ་བཟུང་འབད་ནི་ལུ་་ཨི་ཨེགསི་ཨའི་ཨེཕ་རྩོམ་འབྲི་པ་ཚུ་གི་་བཟོ་བསྐྲུན་འབད་ནི་ཚུ་གི་དོན་ལུ་ངོ་རྟགས་ཅིག"
" ནང་དོན་ཚུ་བཟོ་བསྐྲུན་འབད་ནི་ལུ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:96
msgid "Max Aperture Value"
msgstr "པར་ཆས་དོང་ཆུང་གནས་གོང་མཐོ་ཤོས།"

#: plugins/exiv2/exiv2-plugin.cc:96
msgid ""
"The smallest F number of the lens. The unit is the APEX value. Ordinarily it"
" is given in the range of 00.00 to 99.99, but it is not limited to this "
"range."
msgstr ""
"དྭངས་ཤེལ་འདི་གི་ཨང་ཨེཕ་ཆུང་ཤོས་འདི། "
"ཆ་ཕྲན་འདི་ཨེ་པི་ཨི་ཨེགསི་གནས་གོང་འདི་ཨིན། ཁྱད་ཚབ་ཀྱི་ "
"༠༠.༠༠་ལས་༩༩.༩༩་ནང་བྱིན་ཡོད་མི་ངོ་མ་ཨིན་རུང་ ཁྱད་ཚབ་འདི་ལུ་བཅད་མཚམས་མེདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:78 plugins/exiv2/exiv2-plugin.cc:97
msgid "Metering Mode"
msgstr "ཐབས་ལམ་མི་ཊ་རིང་།"

#: plugins/exiv2/exiv2-plugin.cc:97
msgid "The metering mode."
msgstr "ཐབས་ལམ་མི་ཊ་རིང་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:65 plugins/exiv2/exiv2-plugin.cc:158
msgid "Model"
msgstr "དཔེ།"

#: plugins/exiv2/exiv2-plugin.cc:158
msgid ""
"The model name or model number of the equipment. This is the model name or "
"number of the DSC, scanner, video digitizer or other equipment that "
"generated the image. When the field is left blank, it is treated as unknown."
msgstr ""
"མཁོ་ཆས་འདི་གི་དཔེ་ཨང་ཡང་ན་དཔེ་མིང་འདི། "
"གཟུགས་བརྙན་འདི་བཟོ་བཏོན་འོད་ཡོད་མི་གཞན་མཁོ་ཆས་ཡང་ན་ཝི་ཌིའོ་ཌི་ཇི་ཊཱལ་ཛའིར་པར་ལེན་འཕྲུལ་ཆས་"
" ཌི་ཨེསི་སི་འདི་གི་ཨང་ཡང་ན་དཔེ་མིང་འདི་ཨིན། "
"ས་སྒོ་འདི་སྟོངམ་བཞགཔ་ད་འདི་མ་ཤེསཔ་སྦེ་བརྩི་འཇོག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:160
msgid "New Subfile Type"
msgstr "ཡན་ལག་ཡིག་སྣོད་དབྱེ་བ་གསརཔ།"

#: plugins/exiv2/exiv2-plugin.cc:160
msgid "A general indication of the kind of data contained in this subfile."
msgstr ""
"ཡིག་སྣོད་ཡན་ལག་འདི་ནང་ཡོད་མི་གནས་སྡུད་ཀྱི་དབྱེ་ཁག་འདི་གི་ཡོངས་ཁྱབ་བརྡ་སྟོན་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:161
msgid "OECF"
msgstr "ཨོ་ཨི་སི་ཨེཕ།"

#: plugins/exiv2/exiv2-plugin.cc:79 plugins/exiv2/exiv2-plugin.cc:162
msgid "Orientation"
msgstr "ཕྱོགས།"

#: plugins/exiv2/exiv2-plugin.cc:162
msgid "The image orientation viewed in terms of rows and columns."
msgstr "གྱལ་ཚུ་དང་ཀེར་ཐིག་ཚུ་གི་དོན་ཚིག་ནང་གཟུགས་བརྙན་ཕྱོགས་སྟོན་ཡོད་མི།"

#: plugins/exiv2/exiv2-plugin.cc:163
msgid "Photometric Interpretation"
msgstr "ཕོ་ཊོ་མི་ཊིཀསི་གོ་དོན།"

#: plugins/exiv2/exiv2-plugin.cc:163
msgid ""
"The pixel composition. In JPEG compressed data a JPEG marker is used instead"
" of this tag."
msgstr ""
"པིག་སེལ་རྩོམ་བྲིས་འདི། "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་གནས་སྡུད་ནང་ངོ་རྟགས་འདི་གི་ཚབ་མ་ཇེ་པི་ཨི་ཇི་རྟགས་བཀོད་པ་འདི་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:100
msgid "Pixel X Dimension"
msgstr "པིག་སེལ་ཨེགསི་མཚོན་གྲངས།"

#: plugins/exiv2/exiv2-plugin.cc:100
msgid ""
"Information specific to compressed data. When a compressed file is recorded,"
" the valid width of the meaningful image must be recorded in this tag, "
"whether or not there is padding data or a restart marker. This tag should "
"not exist in an uncompressed file."
msgstr ""
"ཨེབ་བཙུགས་ཡོད་མི་གནས་སྡུད་ལུ་བརྡ་དོན་དམིགས་བསལ། "
"ཨེབ་བཙུགས་ཡིག་སྣོད་ཅིག་སྒྲ་བཟུང་ཡོད་པའི་སྐབས་་གཟུགས་བརྙན་འདི་གི་དོན་ལྡན་ནུས་ཅན་རྒྱ་ཚད་འདི་ངོ་རྟགས་འདི་ནང་སྒྲ་བཟུང་འབད་ཡོདཔ་"
" བར་་ཤབས་་གནས་སྡུད་ཡང་ན་ལོག་འགོ་བཙུགས་རྟགས་བཀོད་པ་ཅིག་མེད་ཡོད་རུང་་དགོཔ་ཨིན།"
" ངོ་རྟགས་འདི་ཨེབ་བཙུགས་བཤོལ་ཡིག་སྣོད་ཅིག་ནང་མེད་པ་དགོཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:101
msgid "Pixel Y Dimension"
msgstr "པིག་སེལ་ཝའི་མཚོན་གྲངས།"

#: plugins/exiv2/exiv2-plugin.cc:101
msgid ""
"Information specific to compressed data. When a compressed file is recorded,"
" the valid height of the meaningful image must be recorded in this tag, "
"whether or not there is padding data or a restart marker. This tag should "
"not exist in an uncompressed file. Since data padding is unnecessary in the "
"vertical direction, the number of lines recorded in this valid image height "
"tag will in fact be the same as that recorded in the SOF."
msgstr ""
"ཨེབ་བཙུགས་ཡོད་མི་གནས་སྡུད་ལུ་བརྡ་དོན་གསལ་བཀོད་འབད། "
"ཨེབ་བཙུགས་ཡོད་མི་ཡིག་སྣོད་ཅིག་སྒྲ་བཟུང་འབད་ཡོདཔ་ད་བར་ཤབས་གནས་སྡུད་ཡང་ན་ལོག་འགོ་བཙུགས་རྟགས་བཀོད་པ་འདི་ཨིན་རུང་མེན་རུང་"
" "
"ངོ་རྟགས་འདི་ནང་དོན་ལྡན་གཟུགས་བརྙན་འདི་གི་ནུས་ཅན་མཐོ་ཚད་སྒྲ་བཟུང་འབད་དགོཔ་ཨིན།"
" ངོ་རྟགས་འདི་ཨེབ་བཙུགས་བཤོལ་ཡིག་སྣོད་ཅིག་ནང་མེདཔ་དགོཔ་ཨིན། "
"གནས་སྡུད་བར་ཤབས་འདི་ཀེར་ཕྲང་བཀོད་རྒྱ་འདི་ནང་ཉེར་མཁོ་མེདཔ་ལས་ཚུར་ནུས་ཅན་གཟུགས་བརྙན་མཐོ་ཚད་ངོ་རྟགས་འདི་ནང་སྒྲ་བཟུང་འབད་ཡོད་མི་གྱལ་ཚུ་གི་ཨང་འདི་"
" ཨེསི་ཨོ་ཨེཕ་འདི་ནང་སྒྲ་བཟུང་འབད་ཡོད་མི་བཟུམ་སྦེ་ཅོག་འཐདཔ་འོངམ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:164
msgid "Planar Configuration"
msgstr "པ་ལ་ནར་རིམ་སྒྲིག"

#: plugins/exiv2/exiv2-plugin.cc:164
msgid ""
"Indicates whether pixel components are recorded in a chunky or planar "
"format. In JPEG compressed files a JPEG marker is used instead of this tag. "
"If this field does not exist, the TIFF default of 1 (chunky) is assumed."
msgstr ""
"པིག་སེལ་ཆ་ཤས་ཚུ་ཅང་ཀི་ཅིག་ཡང་ན་པ་ལ་ནར་་ནང་སྒྲ་བཟུང་ཡོད་རུང་མེད་རུང་བརྡ་སྟོནམ་ཨིན།"
" "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་ཡོད་མི་ཡིག་སྣོད་ཚུ་ནང་ངོ་རྟགས་འདི་གི་ཚབ་མ་ཇེ་པི་ཨི་ཇི་རྟགས་བཀོད་པ་འདི་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"
" ས་སྒོ་འདི་མེད་པ་ཅིན་ (ཅང་ཀི་)༡ གི་ "
"ཊི་ཨའི་ཨེཕ་ཨེཕ་སྔོན་སྒྲིག་འདི་ཚོད་དཔག་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:165
msgid "Primary Chromaticities"
msgstr "གཞི་རིམ་ཀོརོ་མ་ཊིསི་ཊིསི།"

#: plugins/exiv2/exiv2-plugin.cc:165
msgid ""
"The chromaticity of the three primary colors of the image. Normally this tag"
" is not necessary, since colorspace is specified in <Exif.ColorSpace> tag."
msgstr ""
"གཟུགས་བརྙན་འདི་གི་གཞི་རིམ་ཚོས་གཞི་གསུམ་ཚུ་གི་ཀོརོམ་ཊིསི་ཊི་འདི།  "
"སྤྱིར་བཏང་གི་ངོ་རྟགས་འདི་ཉེར་མཁོ་མེདཔ་ལས་ཚུར་ཚོས་གཞི་བར་སྟོང་འདི་ "
"<Exif.ColorSpace> ངོ་རྟགས་འདི་ནང་གསལ་བཀོད་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:166
msgid "Reference Black/White"
msgstr "གཞི་བསྟུན་གནགཔོ/དཀརཔོ།"

#: plugins/exiv2/exiv2-plugin.cc:167
msgid "Related Image File Format"
msgstr "འབྲེལ་བ་ཡོད་མི་གཟུགས་བརྙན་ཡིག་སྣོད་རྩ་སྒྲིག"

#: plugins/exiv2/exiv2-plugin.cc:167
msgid "Related image file format."
msgstr "འབྲེལ་བ་ཡོད་པའི་ གཟུགས་བརྙན་ ཡིག་སྣོད་རྩ་སྒྲིག།"

#: plugins/exiv2/exiv2-plugin.cc:168
msgid "Related Image Length"
msgstr "འབྲེལ་བ་ཡོད་མི་གཟུགས་བརྙན་རིང་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:168
msgid "Related image length."
msgstr "འབྲེལ་བ་ཡོད་པའི་ གཟུགས་བརྙན་གྱི་རིང་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:169
msgid "Related Image Width"
msgstr "འབྲེལ་བ་ཡོད་མི་གཟུགས་བརྙན་རྒྱ་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:169
msgid "Related image width."
msgstr "འབྲེལ་བ་ཅན་གྱི་ གཟུགས་བརྙན་གྱི་ རྒྱ་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:170
msgid "Related Sound File"
msgstr "འབྲེལ་བ་ཡོད་མི་སྒྲ་སྐད་ཡིག་སྣོད།"

#: plugins/exiv2/exiv2-plugin.cc:171
msgid "Resolution Unit"
msgstr "ཧུམ་ཆ་ཕྲན།"

#: plugins/exiv2/exiv2-plugin.cc:171
msgid ""
"The unit for measuring <Exif.XResolution> and <Exif.YResolution>. The same "
"unit is used for both <Exif.XResolution> and <Exif.YResolution>. If the "
"image resolution is unknown, 2 (inches) is designated."
msgstr ""
"ཆ་ཕྲན་འདི་གི་དོན་ལུ་ <Exif.XResolution> དང་ "
"<Exif.YResolution>འཇལ་ནི་དོན་ལུ་ཨིན། ཆ་ཕྲན་ཅོག་འཐདཔ་འདི་ <Exif.XResolution> "
"དང་ <Exif.YResolution>གཉིས་ཆ་རང་ལུ་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན། "
"གཟུགས་བརྙན་ཧུམ་ཆ་འདི་མ་ཤེས་པ་ཅིན་ (ཨིན་ཅེས་ཚུ་)༢ བཀོད་སྒྲིག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:172
msgid "Rows per Strip"
msgstr "བཤུབ་རེའི་གྱལ་ཚུ།"

#: plugins/exiv2/exiv2-plugin.cc:172
msgid ""
"The number of rows per strip. This is the number of rows in the image of one"
" strip when an image is divided into strips. With JPEG compressed data this "
"designation is not needed and is omitted."
msgstr ""
"བཤུབ་རེ་གྱལ་ཚུ་གི་ཨང་འདི། "
"གཟུགས་བརྙན་ཅིག་བཤུབ་ཚུའི་ནང་བགོ་ཡོད་པའི་སྐབས་བཤུབ་གཅིག་གི་གཟུགས་བརྙན་འདི་ནང་གྱལ་ཚུ་གི་ཨང་འདི་ཨིན།"
" "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་ཡོད་མི་གནས་སྡུད་དང་གཅིག་ཁར་གོ་གནས་འདི་མ་དགོཔ་ལས་སྐྱུར་བཞག་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:173
msgid "Samples per Pixel"
msgstr "པིག་སེལ་རེའི་དཔེ་ཚད་ཚུ།"

#: plugins/exiv2/exiv2-plugin.cc:173
msgid ""
"The number of components per pixel. Since this standard applies to RGB and "
"YCbCr images, the value set for this tag is 3. In JPEG compressed data a "
"JPEG marker is used instead of this tag."
msgstr ""
"པིག་སེལ་རེ་རེ་ཆ་ཤས་ཚུ་གི་ཨང་འདི། "
"ཨར་ཇི་བི་དང་ཝའི་སི་བི་སི་ཨར་གཟུགས་བརྙན་ཚུ་ལུ་ཚད་ལྡན་འདི་འཇུག་སྤྱོད་འབདཝ་ལས་ཚུར་་"
" ངོ་རྟགས་འདི་གི་དོནལུ་གཞི་སྒྲིག་འབད་མི་གནས་གོང་འདི་ ༣ ཨིན། "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་གནས་སྡུད་ནང་ངོ་རྟགས་འདི་གི་ཚབ་མ་ཇེ་པི་ཨི་ཇི་རྟགས་བཀོད་པ་ཅིག་ལག་ལེན་འཐབ་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:174
msgid "Saturation"
msgstr "མཐའ་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:175
msgid "Scene Capture Type"
msgstr "འཆར་སྣང་འཛིན་བཟུང་དབྱེ་བ།"

#: plugins/exiv2/exiv2-plugin.cc:176
msgid "Scene Type"
msgstr "འཆར་སྣང་དབྱེ་བ།"

#: plugins/exiv2/exiv2-plugin.cc:177
msgid "Sensing Method"
msgstr "ཚོར་འཕྲུལ་ཐབས་ལམ།"

#: plugins/exiv2/exiv2-plugin.cc:178
msgid "Sharpness"
msgstr "རྣོ་ཅན་གྱི་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:98
msgid "Shutter Speed"
msgstr "འགེབས་བྱེད་མགྱོགས་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:98
msgid ""
"Shutter speed. The unit is the APEX (Additive System of Photographic "
"Exposure) setting."
msgstr ""
"འགེབས་བྱེད་མགྱོགས་ཚད། "
"ཆ་ཕྲན་འདི་ཨེ་པི་ཨི་ཨེགསི་(ཕོ་ཊོ་ག་ར་ཕིཀ་མདངས་ཕོག་གི་བསྡོམས་བཏུབ་རིམ་ལུགས)སྒྲིག་སྟངས་འདི་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:80 plugins/exiv2/exiv2-plugin.cc:179
msgid "Software"
msgstr "མཉེན་ཆས།"

#: plugins/exiv2/exiv2-plugin.cc:179
msgid ""
"This tag records the name and version of the software or firmware of the "
"camera or image input device used to generate the image. When the field is "
"left blank, it is treated as unknown."
msgstr ""
"ངོ་རྟགས་འདི་གིས་གཟུགས་བརྙན་འདི་བཟོ་བཏོན་འབད་ནི་ལུ་ལག་ལེན་འཐབ་ཡོད་མི་པར་ཆས་ཡང་གཟུགས་བརྙན་ཨིན་པུཊི་ཐབས་འཕྲུལ་གྱི་མཉེན་ཆས་ཡང་ན་ཚོང་ལས་ཁང་གི་ཅ་ཆས་ཀྱི་མིང་དང་ཐོན་རིམ་འདི་སྒྲ་བཟུངམ་ཨིན།"
" ས་སྒོ་འདི་སྟོངམ་སྦེ་བཞགཔ་ད་འདི་མ་ཤེསཔ་སྦེ་བརྩི་འཇོག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:180
msgid "Spatial Frequency Response"
msgstr "སྟོང་ཆའི་འབྱུང་ཐེངས་ལན།"

#: plugins/exiv2/exiv2-plugin.cc:180
msgid ""
"This tag records the camera or input device spatial frequency table and SFR "
"values in the direction of image width, image height, and diagonal "
"direction, as specified in ISO 12233."
msgstr ""
"ངོ་རྟགས་འདི་གིས་པར་ཆས་དང་ཨིན་པུཊི་ཐབས་འཕྲུལ་འབྱུང་ཐེངས་ཐིག་ཁྲམ་་དང་ "
"ཨའི་ཨེསི་ཨོ་ ༡༢༢༣༣ "
"ནང་གསལ་བཀོད་འབད་ཡོད་མི་བཟུམ་གཟུགས་བརྙན་རྒྱ་ཚད་ཀྱི་བཀོད་རྒྱ་ "
"གཟུགས་བརྙན་གྱི་མཐོ་ཚད་ "
"དང་གསེག་ཐིག་ཅན་བཀོད་རྒྱའི་ཕྱོགས་ནང་ཨེསི་ཨེཕ་ཨར་གནས་གོང་ཚུ་སྒྲ་བཟུངམ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:181
msgid "Spectral Sensitivity"
msgstr "སྟོང་ཆའི་ཉེན་ཁ་ཅན།"

#: plugins/exiv2/exiv2-plugin.cc:182
msgid "Strip Byte Count"
msgstr "བཤུབ་བཱའིཊི་གྱངས་རྐྱབས།"

#: plugins/exiv2/exiv2-plugin.cc:182
msgid ""
"The total number of bytes in each strip. With JPEG compressed data this "
"designation is not needed and is omitted."
msgstr ""
"བཤུབ་རེ་རེ་ནང་བཱའིཊིསི་གི་ཨང་ཕསྡོམས་འདི། "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་ཡོད་མི་གནས་སྡུད་དང་གཅིག་ཁར་གོ་གནས་འདི་མི་དགོཔ་ལས་སྐྱུར་བཞག་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:183
msgid "Strip Offsets"
msgstr "བཤུབ་པར་ལེན་ཚུ།"

#: plugins/exiv2/exiv2-plugin.cc:183
msgid ""
"For each strip, the byte offset of that strip. It is recommended that this "
"be selected so the number of strip bytes does not exceed 64 Kbytes. With "
"JPEG compressed data this designation is not needed and is omitted."
msgstr ""
"བཤུབ་དེ་གི་བཱའིཊི་པར་ལེན་འདི་བཤུབ་རེ་རེ་དོན་ལུ། "
"བཱའིཊིསི་བཤུབ་གིས་ཀེ་བཱའིཊིསི་ ༦༤ "
"ལྷག་ནི་མེད་མི་ཨང་་སེལ་འཐུ་འབད་ཡོདཔ་སྦེ་འོས་སྦྱོར་འབད་ཡོདཔ་ཨིན། "
"ཇེ་པི་ཨི་ཇི་ཨེབ་བཙུགས་གནས་སྡུད་དང་གཅིག་ཁར་གོ་གནས་འདི་མི་དགོཔ་ལས་སྐྱུར་བཞག་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:184
msgid "Sub IFD Offsets"
msgstr "ཨའི་ཨེཕ་ཌི་པར་ལེན་ཡན་ལག་ཚུ།"

#: plugins/exiv2/exiv2-plugin.cc:184
msgid "Defined by Adobe Corporation to enable TIFF Trees within a TIFF file."
msgstr ""
"ཊི་ཨའི་ཨེཕ་ཨེཕ་ཡིག་སྣོད་ནང་འཁོད་རྩ་བའི་ཊི་ཨའི་ཨེཕ་ཨེཕ་ལྕོགས་ཅན་ལུ་ཨེ་ཌོ་བི་ལས་ཁང་གིས་ངེས་འཛིན་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:185
msgid "Subject Area"
msgstr "དོན་ཚན་མངའ་ཁོངས།"

#: plugins/exiv2/exiv2-plugin.cc:186
msgid "Subject Distance"
msgstr "དོན་ཚན་གྱང་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:186
msgid "The distance to the subject, given in meters."
msgstr "མི་ཊར་ཚུ་ནང་བྱིན་ཡོད་མི་དོན་ཚན་འདི་ལུ་གྱང་ཚད་འདི།"

#: plugins/exiv2/exiv2-plugin.cc:187
msgid "Subject Distance Range"
msgstr "དོན་ཚན་གྱང་ཚད་ཁྱབ་ཚད།"

#: plugins/exiv2/exiv2-plugin.cc:188
msgid "Subject Location"
msgstr "དོན་ཚན་གནས་ཁོངས།"

#: plugins/exiv2/exiv2-plugin.cc:189
msgid "Subsec Time"
msgstr "དབྱེ་ཚན་ཡན་ལག་དུས་ཚོད།"

#: plugins/exiv2/exiv2-plugin.cc:190
msgid "Subsec Time Digitized"
msgstr "དབྱེ་ཚན་ཡན་ལག་དུས་ཚོད་ཨང་ཡིག་བཟོ་ཡོད་མི།"

#: plugins/exiv2/exiv2-plugin.cc:191
msgid "Subsec Time Original"
msgstr "དབྱེ་ཚན་ཡན་ལག་དུས་ཚོད་ངོ་མ།"

#: plugins/exiv2/exiv2-plugin.cc:192
msgid "TIFF/EP Standard ID"
msgstr "ཊི་ཨའི་ཨེཕ་ཨེཕ/ཨི་པི་ཨའི་ཌི་ཚད་ལྡན།"

#: plugins/exiv2/exiv2-plugin.cc:192
msgid "TIFF/EP Standard ID."
msgstr "ཊི་ཨའི་ཨེཕ་ཨེཕ/ཨི་པི་ ཚད་ལྡན་ ཨའི་ཌི།"

#: plugins/exiv2/exiv2-plugin.cc:193
msgid "Transfer Function"
msgstr "ལས་འགན་གནས་སོར་གཏང་།"

#: plugins/exiv2/exiv2-plugin.cc:193
msgid ""
"A transfer function for the image, described in tabular style. Normally this"
" tag is not necessary, since color space is specified in <Exif.ColorSpace> "
"tag."
msgstr ""
"རེའུ་མིག་ཅན་བཟོ་རྣམ་ནང་འགྲེལ་བཤད་འབད་ཡོད་མི་གཟུགས་བརྙན་འདི་གི་གནས་སོར་ལས་འགན་ཅིག"
" སྤྱིར་བཏང་གི་ངོ་རྟགས་འདི་ཉེར་མཁོ་མེདཔ་ལས་ཚུར་ ངོ་རྟགས་ནང་ <Exif.ColorSpace>"
" ཚོས་གཞི་བར་སྟོང་གསལ་བཀོད་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:194
msgid "Transfer Range"
msgstr "ཁྱབ་ཚད་གནས་སོར་གཏང་།"

#: plugins/exiv2/exiv2-plugin.cc:194
msgid "Transfer range."
msgstr "ཁྱབ་ཚད་ གནས་སོར་གཏང་།"

#: plugins/exiv2/exiv2-plugin.cc:109
msgid "User Comment"
msgstr "ལག་ལེན་པའི་བསམ་བཀོད།"

#: plugins/exiv2/exiv2-plugin.cc:82 plugins/exiv2/exiv2-plugin.cc:99
msgid "White Balance"
msgstr "དཀརཔོ་ཚད་སྙོམས།"

#: plugins/exiv2/exiv2-plugin.cc:99
msgid "The white balance mode set when the image was shot."
msgstr ""
"གཟུགས་བརྙན་འདི་བཏབ་ཡོད་པའི་སྐབས་ཚད་སྙོམས་ཐབས་ལམ་དཀརཔོ་འདི་གཞི་སྒྲིག་འབད།"

#: plugins/exiv2/exiv2-plugin.cc:195
msgid "White Point"
msgstr "དཀརཔོ་རྩེ།"

#: plugins/exiv2/exiv2-plugin.cc:195
msgid ""
"The chromaticity of the white point of the image. Normally this tag is not "
"necessary, since color space is specified in <Exif.ColorSpace> tag."
msgstr ""
"གཟུགས་བརྙན་འདི་གི་དཀརཔོ་ཚད་འདི་གི་ཀོརོམ་ཊིསི་ཊི་འདི། "
"སྤྱིར་བཏང་གི་ངོ་རྟགས་འདི་ཉེར་མཁོ་མེདཔ་ལས་ཚུར་ ངོ་རྟགས་ནང་ <Exif.ColorSpace> "
"ཚོས་གཞི་བར་སྟོང་འདི་གསལ་བཀོད་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:196
msgid "XML Packet"
msgstr "ཨེགསི་ཨེམ་ཨེལ་འཕྲིན་ཚན།"

#: plugins/exiv2/exiv2-plugin.cc:196
msgid "XMP metadata."
msgstr "ཨེགསི་ཨེམ་པི་མི་ཊ་གནས་སྡུད།"

#: plugins/exiv2/exiv2-plugin.cc:102
msgid "x Resolution"
msgstr "ཨེགསི་ཧུམ་ཆ།"

#: plugins/exiv2/exiv2-plugin.cc:102
msgid ""
"The number of pixels per <Exif.ResolutionUnit> in the <Exif.ImageWidth> "
"direction. When the image resolution is unknown, 72 [dpi] is designated."
msgstr ""
"བཀོད་རྒྱ་འདི་ནང་ <Exif.ResolutionUnit> པིག་སེལ་རེ་གི་ <Exif.ImageWidth> "
"ཨང་འདི། གཟུགས་བརྙན་ཧུམ་ཆ་འདི་མ་ཤེསཔ་ཨིན་པ་ཅིན་  [dpi] ༧༢་ "
"འདི་བཀོད་སྒྲིག་འབད་ཡོདཔ་ཨིན།"

#: plugins/exiv2/exiv2-plugin.cc:197
msgid "YCbCr Coefficients"
msgstr "ཝའི་སི་བི་སི་ཨར་གྲངས་རྟགས་ཚུ།"

#: plugins/exiv2/exiv2-plugin.cc:198
msgid "YCbCr Positioning"
msgstr "ཝའི་སི་བི་སི་ཨར་གནས་ས་བཀོད་ནི།"

#: plugins/exiv2/exiv2-plugin.cc:198
msgid ""
"The position of chrominance components in relation to the luminance "
"component. This field is designated only for JPEG compressed data or "
"uncompressed YCbCr data. The TIFF default is 1 (centered); but when Y:Cb:Cr "
"= 4:2:2 it is recommended that 2 (co-sited) be used to record data, in order"
" to improve the image quality when viewed on TV systems. When this field "
"does not exist, the reader shall assume the TIFF default. In the case of "
"Y:Cb:Cr = 4:2:0, the TIFF default (centered) is recommended. If the reader "
"does not have the capability of supporting both kinds of "
"<Exif.YCbCrPositioning>, it shall follow the TIFF default regardless of the "
"value in this field. It is preferable that readers be able to support both "
"centered and co-sited positioning."
msgstr ""
