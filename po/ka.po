msgstr "მიბმული ხმოვანი ფაილი"

#: plugins/image-metadata.py:154
msgid ""
"This tag is used to record the name of an audio file related to the image data."
msgstr ""

#: plugins/image-metadata.py:157
msgid "Focal Plane X Resolution"
msgstr "ფოკალური სიბრტყის X გაფართოება"

#: plugins/image-metadata.py:157
msgid ""
"Number of pixels per FocalPlaneResolutionUnit (37392) in ImageWidth direction for "
"main image."
msgstr ""

#: plugins/image-metadata.py:158
msgid "Focal Plane Y Resolution"
msgstr "ფოკალური სიბრტყის Y გაფართოება"

#: plugins/image-metadata.py:158
msgid ""
"Number of pixels per FocalPlaneResolutionUnit (37392) in ImageLength direction for "
"main image."
msgstr ""

#: plugins/image-metadata.py:159
msgid "Focal Plane Resolution Unit"
msgstr ""

#: plugins/image-metadata.py:159
msgid ""
"Unit of measurement for FocalPlaneXResolution(37390) and "
"FocalPlaneYResolution(37391)."
msgstr ""

#: plugins/image-metadata.py:160
msgid "Subject Location"
msgstr "სუბიექტის მდებარეობა"

#: plugins/image-metadata.py:160
msgid "Indicates the location and area of the main subject in the overall scene."
msgstr ""

#: plugins/image-metadata.py:162
msgid "Sensing Method"
msgstr "გრძნობის მეთოდი"

#: plugins/image-metadata.py:162
msgid "Type of image sensor."
msgstr "გამოსახულების სენსორის ტიპი."

#: plugins/image-metadata.py:163
msgid "File Source"
msgstr "ფაილის წყაროები"

#: plugins/image-metadata.py:163
msgid ""
"Indicates the image source. If a DSC recorded the image, this tag value of this "
"tag always be set to 3, indicating that the image was recorded on a DSC."
msgstr ""

#: plugins/image-metadata.py:164
msgid "Scene Type"
msgstr "სცენის ტიპი"

#: plugins/image-metadata.py:164
msgid ""
"Indicates the type of scene. If a DSC recorded the image, this tag value must "
"always be set to 1, indicating that the image was directly photographed."
msgstr ""

#: plugins/image-metadata.py:165
msgid "Custom Rendered"
msgstr "ხელით დარენდერებული"

#: plugins/image-metadata.py:165
msgid ""
"This tag indicates the use of special processing on image data, such as rendering "
"geared to output."
msgstr ""

#: plugins/image-metadata.py:166
msgid "Exposure Mode"
msgstr "ექსპოზიციის რეჟიმი"

#: plugins/image-metadata.py:166
msgid ""
"This tag indicates the exposure mode set when the image was shot. In auto-"
"bracketing mode, the camera shoots a series of frames of the same scene at "
"different exposure settings."
msgstr ""

#: plugins/image-metadata.py:167
msgid "White Balance"
msgstr "თეთრის ბალანსი"

#: plugins/image-metadata.py:167
msgid "This tag indicates the white balance mode set when the image was shot."
msgstr ""

#: plugins/image-metadata.py:168
msgid "Digital Zoom Ratio"
msgstr "ციფრული გადიდების კოეფიციენტი"

#: plugins/image-metadata.py:168
msgid ""
"This tag indicates the digital zoom ratio when the image was shot. If the "
"numerator of the recorded value is 0, this indicates that digital zoom was not "
"used."
msgstr ""

#: plugins/image-metadata.py:169
msgid "Focal Length In 35mm Film"
msgstr "ფოკალური სიგრძე 35 მმ ლენტა"

#: plugins/image-metadata.py:169
msgid ""
"This tag indicates the equivalent focal length assuming a 35mm film camera, in mm. "
"A value of 0 means the focal length is unknown."
msgstr ""

#: plugins/image-metadata.py:170
msgid "Scene Capture Type"
msgstr "სცენის ჩაწერის ტიპი"

#: plugins/image-metadata.py:170
msgid "This tag indicates the type of scene that was shot."
msgstr ""

#: plugins/image-metadata.py:171
msgid "Gain Control"
msgstr "გაძლიერების კონტროლი"

#: plugins/image-metadata.py:171
msgid "This tag indicates the degree of overall image gain adjustment."
msgstr ""

#: plugins/image-metadata.py:172
msgid "Contrast"
msgstr "კონტრასტი"

#: plugins/image-metadata.py:172
msgid ""
"This tag indicates the direction of contrast processing applied by the camera when "
"the image was shot."
msgstr ""

#: plugins/image-metadata.py:173
msgid "Saturation"
msgstr "გაჯერებულობა"

#: plugins/image-metadata.py:173
msgid ""
"This tag indicates the direction of saturation processing applied by the camera "
"when the image was shot."
msgstr ""

#: plugins/image-metadata.py:174
msgid "Sharpness"
msgstr "სიმკვეთრე"

#: plugins/image-metadata.py:174
msgid ""
"This tag indicates the direction of sharpness processing applied by the camera "
"when the image was shot."
msgstr ""

#: plugins/image-metadata.py:175
msgid "Device Setting Description"
msgstr "მოწყობილობის პარამეტრების აღწერა"

#: plugins/image-metadata.py:175
msgid ""
"This tag indicates information on the picture-taking conditions of a particular "
"camera model."
msgstr ""

#: plugins/image-metadata.py:176
msgid "Subject Distance Range"
msgstr "სუბიექტის დაშორების დიაპაზონი"

#: plugins/image-metadata.py:176
msgid "This tag indicates the distance to the subject."
msgstr ""

#: plugins/image-metadata.py:177
msgid "Image Unique ID"
msgstr "გამოსახულების უნიკალური ID"

#: plugins/image-metadata.py:177
msgid "This tag indicates an identifier assigned uniquely to each image."
msgstr ""

#: plugins/image-metadata.py:178
msgid "Camera Owner Name"
msgstr "კამერის მფლობელის სახელი"

#: plugins/image-metadata.py:178
msgid ""
"This tag records the owner of a camera used in photography as an ASCII string."
msgstr ""

#: plugins/image-metadata.py:179
msgid "Body Serial Number"
msgstr "აპარატის სერიული ნომერი"

#: plugins/image-metadata.py:179
msgid ""
"This tag records the serial number of the body of the camera that was used in "
"photography as an ASCII string."
msgstr ""

#: plugins/image-metadata.py:180
msgid "Lens Specification"
msgstr "ლინზის სპეციფიკაცია"

#: plugins/image-metadata.py:180
msgid ""
"This tag notes minimum focal length, maximum focal length, minimum F number in the "
"minimum focal length, and minimum F number in the maximum focal length, which are "
"specification information for the lens that was used in photography. When the "
"minimum F number is unknown, the notation is 0/0"
msgstr ""

#: plugins/image-metadata.py:181
msgid "Lens Make"
msgstr "ლინზის მწარმოებელი"

#: plugins/image-metadata.py:181
msgid "This tag records the lens manufactor as an ASCII string."
msgstr ""

#: plugins/image-metadata.py:182
msgid "Lens Model"
msgstr "ლინზის მოდელი"

#: plugins/image-metadata.py:182
msgid "This tag records the lens's model name and model number as an ASCII string."
msgstr ""

#: plugins/image-metadata.py:183
msgid "Lens Serial Number"
msgstr "ლინზის სერიული ნომერი"

#: plugins/image-metadata.py:183
msgid ""
"This tag records the serial number of the interchangeable lens that was used in "
"photography as an ASCII string."
msgstr ""

#: plugins/image-metadata.py:184
msgid "Gamma"
msgstr "გამა"

#: plugins/image-metadata.py:184
msgid "Indicates the value of coefficient gamma."
msgstr ""

#: plugins/image-metadata.py:185
msgid "Black Level"
msgstr "შავის დონე"

#: plugins/image-metadata.py:185
msgid ""
"Specifies the zero light (a.k.a. thermal black or black current) encoding level, "
"as a repeating pattern. The origin of this pattern is the top-left corner of the "
"ActiveArea rectangle. The values are stored in row-column-sample scan order."
msgstr ""

#: plugins/image-metadata.py:189
msgid "Interoperability Index"
msgstr "თავსებადობის ინდექსი"

#: plugins/image-metadata.py:189
msgid "Indicates the identification of the Interoperability rule."
msgstr ""

#: plugins/image-metadata.py:190
msgid "Interoperability Version"
msgstr "თავსებადობის ვერსია"

#: plugins/image-metadata.py:190
msgid "Interoperability version"
msgstr "თავსებადობის ვერსია"

#: plugins/image-metadata.py:191
msgid "Related Image File Format"
msgstr ""

#: plugins/image-metadata.py:191
msgid "File format of image file"
msgstr "გამოსახულების ფაილის ფორმატი"

#: plugins/image-metadata.py:192
msgid "Related Image Width"
msgstr ""

#: plugins/image-metadata.py:192
msgid "Image width"
msgstr "გამოსახულების სიგანე"

#: plugins/image-metadata.py:193
msgid "Related Image Length"
msgstr ""

#: plugins/image-metadata.py:193
msgid "Image height"
msgstr "გამოსახულების სიმაღლე"

#: plugins/image-metadata.py:194
msgid "GPS Version ID"
msgstr "GPS ვერსიის ID"

#: plugins/image-metadata.py:194
msgid "Indicates the version of <GPSInfoIFD>. The version is given as 2.0.0.0."
msgstr ""

#: plugins/image-metadata.py:195
msgid "GPS Latitude Reference"
msgstr "GPS განედის მიმართვა"

#: plugins/image-metadata.py:195
msgid ""
"Indicates whether the latitude is north or south latitude. The ASCII value 'N' "
"indicates north latitude, and 'S' is south latitude."
msgstr ""

#: plugins/image-metadata.py:196
msgid "GPS Latitude"
msgstr "GPS გრძედი"

#: plugins/image-metadata.py:196
msgid ""
"Indicates the latitude. The latitude is expressed as three RATIONAL values giving "
"the degrees, minutes, and seconds, respectively. When degrees, minutes and seconds "
"are expressed, the format is dd/1,mm/1,ss/1. When degrees and minutes are used "
"and, for example, fractions of minutes are given up to two decimal places, the "
"format is dd/1,mmmm/100,0/1."
msgstr ""

#: plugins/image-metadata.py:197
msgid "GPS Longitude Reference"
msgstr "GPS გრძედის მიმართვა"

#: plugins/image-metadata.py:197
msgid ""
"Indicates whether the longitude is east or west longitude. ASCII 'E' indicates "
"east longitude, and 'W' is west longitude."
msgstr ""

#: plugins/image-metadata.py:198
msgid "GPS Longitude"
msgstr "GPS გრძედი"

#: plugins/image-metadata.py:198
msgid ""
"Indicates the longitude. The longitude is expressed as three RATIONAL values "
"giving the degrees, minutes, and seconds, respectively. When degrees, minutes and "
"seconds are expressed, the format is ddd/1,mm/1,ss/1. When degrees and minutes are "
"used and, for example, fractions of minutes are given up to two decimal places, "
"the format is ddd/1,mmmm/100,0/1."
msgstr ""

#: plugins/image-metadata.py:199
msgid "GPS Altitude"
msgstr "GPS სიმაღლე"

#: plugins/image-metadata.py:199
msgid ""
"Indicates the altitude based on the reference in GPSAltitudeRef. Altitude is "
"expressed as one RATIONAL value. The reference unit is meters."
msgstr ""

#: plugins/image-metadata.py:200
msgid "GPS Time Stamp"
msgstr "GPS-ის დროის შტამპი"

#: plugins/image-metadata.py:200
msgid ""
"Indicates the time as UTC (Coordinated Universal Time). <TimeStamp> is expressed "
"as three RATIONAL values giving the hour, minute, and second (atomic clock)."
msgstr ""

#: plugins/image-metadata.py:201
msgid "GPS Satellites"
msgstr "GPS თანამგზავრები"

#: plugins/image-metadata.py:201
msgid ""
"Indicates the GPS satellites used for measurements. This tag can be used to "
"describe the number of satellites, their ID number, angle of elevation, azimuth, "
"SNR and other information in ASCII notation."
msgstr ""

#: plugins/image-metadata.py:202
msgid "GPS Status"
msgstr "GPS-ის სტატუსი"

#: plugins/image-metadata.py:202
msgid ""
"Indicates the status of the GPS receiver when the image is recorded. \"A\" means "
"measurement is in progress, and \"V\" means the measurement is Interoperability."
msgstr ""

#: plugins/image-metadata.py:203
msgid "GPS Measure Mode"
msgstr "GPS გაზომვის რეჟიმი"

#: plugins/image-metadata.py:203
msgid ""
"Indicates the GPS measurement mode. \"2\" means two-dimensional measurement and "
"\"3\" means three-dimensional measurement is in progress."
msgstr ""

#: plugins/image-metadata.py:204
msgid "GPS Data Degree of Precision"
msgstr ""

#: plugins/image-metadata.py:204
msgid ""
"Indicates the GPS DOP (data degree of precision). An HDOP value is written during "
"two-dimensional measurement, and PDOP during three-dimensional measurement."
msgstr ""

#: plugins/image-metadata.py:205
msgid "GPS Speed Reference"
msgstr "GPS სიჩქარის მიმართვა"

#: plugins/image-metadata.py:205
msgid ""
"Indicates the unit used to express the GPS receiver speed of movement. \"K\" \"M\" "
"and \"N\" represents kilometers per hour, miles per hour, and knots."
msgstr ""

#: plugins/image-metadata.py:206
msgid "GPS Speed"
msgstr "GPS სიჩქარე"

#: plugins/image-metadata.py:206
msgid "Indicates the speed of GPS receiver movement."
msgstr ""

#: plugins/image-metadata.py:207
msgid "GPS Track Ref"
msgstr ""

#: plugins/image-metadata.py:207
msgid ""
"Indicates the reference for giving the direction of GPS receiver movement. \"T\" "
"denotes true direction and \"M\" is magnetic direction."
msgstr ""

#: plugins/image-metadata.py:208
msgid "GPS Track"
msgstr ""

#: plugins/image-metadata.py:208
msgid ""
"Indicates the direction of GPS receiver movement. The range of values is from 0.00 "
"to 359.99."
msgstr ""

#: plugins/image-metadata.py:209
msgid "GPS Image Direction Reference"
msgstr "GPS გამოსახულების მიმართულების მითითება"

#: plugins/image-metadata.py:209
msgid ""
"Indicates the reference for giving the direction of the image when it is captured. "
"\"T\" denotes true direction and \"M\" is magnetic direction."
msgstr ""

#: plugins/image-metadata.py:210
msgid "GPS Image Direction"
msgstr "GPS გამოსახულების მიმართულება"

#: plugins/image-metadata.py:210
msgid ""
"Indicates the direction of the image when it was captured. The range of values is "
"from 0.00 to 359.99."
msgstr ""

#: plugins/image-metadata.py:211
msgid "GPS Map Datum"
msgstr ""

#: plugins/image-metadata.py:211
msgid ""
"Indicates the geodetic survey data used by the GPS receiver. If the survey data is "
"restricted to Japan, the value of this tag is \"TOKYO\" or \"WGS-84\"."
msgstr ""

#: plugins/image-metadata.py:212
msgid "GPS Destination Latitude Reference"
msgstr "GPS დანიშნულების განედის მიმართვა"

#: plugins/image-metadata.py:212
msgid ""
"Indicates whether the latitude of the destination point is north or south "
"latitude. The ASCII value \"N\" indicates north latitude, and \"S\" is south "
"latitude."
msgstr ""

#: plugins/image-metadata.py:213
msgid "GPS Destination Latitude"
msgstr "GPS დანიშნულების გრძედი"

#: plugins/image-metadata.py:213
msgid ""
"Indicates the latitude of the destination point. The latitude is expressed as "
"three RATIONAL values giving the degrees, minutes, and seconds, respectively. If "
"latitude is expressed as degrees, minutes and seconds, a typical format would be "
"dd/1,mm/1,ss/1. When degrees and minutes are used and, for example, fractions of "
"minutes are given up to two decimal places, the format would be dd/1,mmmm/100,0/1."
msgstr ""

#: plugins/image-metadata.py:214
msgid "GPS Destination Longitude Reference"
msgstr "GPS დანიშნულების გრძედის მიმართვა"

#: plugins/image-metadata.py:214
msgid ""
"Indicates whether the longitude of the destination point is east or west "
"longitude. ASCII \"E\" indicates east longitude, and \"W\" is west longitude."
msgstr ""

#: plugins/image-metadata.py:215
msgid "GPS Destination Longitude"
msgstr "GPS დანიშნულების განედი"

#: plugins/image-metadata.py:215
msgid ""
"Indicates the longitude of the destination point. The longitude is expressed as "
"three RATIONAL values giving the degrees, minutes, and seconds, respectively. If "
"longitude is expressed as degrees, minutes and seconds, a typical format would be "
"ddd/1,mm/1,ss/1. When degrees and minutes are used and, for example, fractions of "
"minutes are given up to two decimal places, the format would be ddd/1,mmmm/100,0/1."
msgstr ""

#: plugins/image-metadata.py:216
msgid "GPS Destination Bearing Reference"
msgstr ""

#: plugins/image-metadata.py:216
msgid ""
"Indicates the reference used for giving the bearing to the destination point. "
"\"T\" denotes true direction and \"M\" is magnetic direction."
msgstr ""

#: plugins/image-metadata.py:217
msgid "GPS Destination Bearing"
msgstr "GPS დანიშნულების ტარება"

#: plugins/image-metadata.py:217
msgid ""
"Indicates the bearing to the destination point. The range of values is from 0.00 "
"to 359.99."
msgstr ""

#: plugins/image-metadata.py:218
msgid "GPS Destination Distance Reference"
msgstr ""

#: plugins/image-metadata.py:218
msgid ""
"Indicates the unit used to express the distance to the destination point. \"K\", "
"\"M\" and \"N\" represent kilometers, miles and nautical miles."
msgstr ""

#: plugins/image-metadata.py:219
msgid "GPS Destination Distance"
msgstr "GPS დანიშნულების მანძილი"

#: plugins/image-metadata.py:219
msgid "Indicates the distance to the destination point."
msgstr ""

#: plugins/image-metadata.py:220
msgid "GPS Processing Method"
msgstr "GPS დამუშავების მეთოდი"

#: plugins/image-metadata.py:220
msgid ""
"A character string recording the name of the method used for location finding."
msgstr ""

#: plugins/image-metadata.py:221
msgid "GPS Area Information"
msgstr ""

#: plugins/image-metadata.py:221
msgid "A character string recording the name of the GPS area."
msgstr ""

#: plugins/image-metadata.py:222
msgid "GPS Date Stamp"
msgstr "GPS-ის თარიღის შტამპი"

#: plugins/image-metadata.py:222
msgid ""
"A character string recording date and time information relative to UTC "
"(Coordinated Universal Time). The format is \"YYYY:MM:DD.\"."
msgstr ""

#: plugins/image-metadata.py:223
msgid "GPS Differential"
msgstr ""

#: plugins/image-metadata.py:223
msgid "Indicates whether differential correction is applied to the GPS receiver."
msgstr ""

#: plugins/image-metadata.py:233
msgid "A plugin for extracting metadata from images files."
msgstr ""

#: plugins/image-metadata.py:235
msgid ""
"Python3 package exifread has to be installed on your system for this plugin to "
"work."
msgstr ""

#: plugins/image-metadata.py:250
msgid ""
"Required exifread module not found. Please install exifread for Python3 on your "
