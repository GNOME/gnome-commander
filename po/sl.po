#: data/org.gnome.gnome-commander.desktop.in:2 data/org.gnome.gnome-commander.metainfo.xml.in:16
#: src/main_win.rs:270
msgid "Gnome Commander"
msgstr "Gnome Commander"

#: data/org.gnome.gnome-commander.desktop.in:3
msgid "A file manager using dual-panel layout"
msgstr "Upravitelj datotek z dvostrano postavitvijo podoken"

#. TRANSLATORS: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gnome-commander.desktop.in:5
msgid "file;manager;folder;explore;disk;filesystem;"
msgstr "datoteka;upravljalnik;mapa;raziskovanje;disk;sistem;fajli;iskanje;preimenovanje;commander;komander;"

#: data/org.gnome.gnome-commander.gschema.xml:48
msgid "List of advanced rename tool profiles"
msgstr "Seznam profilov orodja za napredno preimenovanje"

#: data/org.gnome.gnome-commander.gschema.xml:49
msgid ""
"The entries in this array represent the profiles in the advanced rename tool with specific settings for "
"each profile."
msgstr "Vnosi matrike predstavljajo profile orodja za napredno preimenovanje."

#: data/org.gnome.gnome-commander.gschema.xml:55
msgid "Advanced rename tool window width"
msgstr "Širina okna orodja za napredno preimenovanje"

#: data/org.gnome.gnome-commander.gschema.xml:56
msgid "This option defines the width of the advanced rename tool window."
msgstr "Možnost določa širino okna orodja za napredno preimenovanje."

#: data/org.gnome.gnome-commander.gschema.xml:62
msgid "Advanced rename tool window height"
msgstr "Višina okna orodja za napredno preimenovanje"

#: data/org.gnome.gnome-commander.gschema.xml:63
msgid "This option defines the height of the advanced rename tool window."
msgstr "Možnost določa višino okna orodja za napredno preimenovanje."

#: data/org.gnome.gnome-commander.gschema.xml:69
msgid "Advanced rename tool template history"
msgstr "Zgodovina predlog orodja za napredno preimenovanje"

#: data/org.gnome.gnome-commander.gschema.xml:70
msgid "This string array represents the history of templates in the advanced rename tool."
msgstr "Nastavitev predstavlja zgodovino uporabljenih predlog v orodju za napredno preimenovanje."

#: data/org.gnome.gnome-commander.gschema.xml:76
msgid "History of visited directories"
msgstr "Zgodovina obiskanih map"

#: data/org.gnome.gnome-commander.gschema.xml:77
msgid "This string array represents the history of visited directories."
msgstr "Nastavitev predstavlja zgodovino doslej obiskanih map."

#: data/org.gnome.gnome-commander.gschema.xml:83
msgid "Filesize display mode"
msgstr "Način prikaza velikosti datoteke"

#: data/org.gnome.gnome-commander.gschema.xml:84
msgid "Defines how the filesize will be displayed in the associated panel column."
msgstr "Določa, kako naj bo izpisana velikost datoteke v ustreznem stolpcu pulta."

#: data/org.gnome.gnome-commander.gschema.xml:90 src/dialogs/options/format_tab.rs:86
msgid "Permission display mode"
msgstr "Način prikazovanja dovoljenj"

#: data/org.gnome.gnome-commander.gschema.xml:91
msgid "Defines how the file permission will be displayed in the associated panel column."
msgstr "Določa, kako naj bodo prikazane oznake dovoljenj datoteke v ustreznem stolpcu pulta."

#: data/org.gnome.gnome-commander.gschema.xml:97
msgid "Graphical layout mode"
msgstr "Grafični način razporeditve"

#: data/org.gnome.gnome-commander.gschema.xml:98
msgid "Defines the icon style of files and folders in the file panels."
msgstr "Določa slog ikon datotek in map v podoknih datotek."

#. Translators: Feel free to replace the default date format to a common value
#. used in your country. See https://docs.gtk.org/glib/method.DateTime.format.html for details.
#. Attention: Do not change the single quotes which sourround the string.
#. If nothing is set, the application uses the hard-coded value '%c', which is
#. "the preferred date and time representation for the current locale".
#: data/org.gnome.gnome-commander.gschema.xml:108
msgid "'%F %R'"
msgstr "'%e.%m.%y %R'"

#: data/org.gnome.gnome-commander.gschema.xml:109 src/dialogs/options/format_tab.rs:94
msgid "Date format"
msgstr "Zapis datuma"

#: data/org.gnome.gnome-commander.gschema.xml:110
msgid "Format of the date in the file panel."
msgstr "Zapis datuma/časa v oknu podoknu datotek."

#: data/org.gnome.gnome-commander.gschema.xml:116
msgid "List font"
msgstr "Pisava seznama"

#: data/org.gnome.gnome-commander.gschema.xml:117
msgid "The font in the file panels."
msgstr "Pisava v podoknih datotek."

#: data/org.gnome.gnome-commander.gschema.xml:121
msgid "Extension display mode"
msgstr "Način prikazovanja pripone"

#: data/org.gnome.gnome-commander.gschema.xml:122
msgid "Defines where the file name extension is displayed."
msgstr "Določa, kje naj bo prikazana pripona datoteke."

#: data/org.gnome.gnome-commander.gschema.xml:128
msgid "Left mouse button mode"
msgstr "Način levega gumba miške"

#: data/org.gnome.gnome-commander.gschema.xml:129
msgid "Number of left mouse button clicks for opening a file or folder."
msgstr "Določa število klikov levega gumba miške za odpiranje datoteke ali mape."

#: data/org.gnome.gnome-commander.gschema.xml:135
msgid "Left mouse button unselects"
msgstr "Preklop izbora z levim gumbom miške"

#: data/org.gnome.gnome-commander.gschema.xml:136
msgid "Defines if a click on an unselected item unselects already selected items."
msgstr "Določa, ali klik na predmet odstrani izbor že izbranega predmeta."

#: data/org.gnome.gnome-commander.gschema.xml:142
msgid "Right mouse button mode"
msgstr "Način desnega gumba miške"

#: data/org.gnome.gnome-commander.gschema.xml:143
msgid "Defines what happens when the right mouse button is clicked on an item."
msgstr "Določa, kaj se zgodi, ko se na predmetu izvede klik z desnim gumbom miške."

#: data/org.gnome.gnome-commander.gschema.xml:149
msgid "Use trash"
msgstr "Uporabi smeti"

#: data/org.gnome.gnome-commander.gschema.xml:150
msgid "Defines if items should be moved to trash by default instead of really deleting them."
msgstr "Določa, ali naj bodo predmeti privzeto premaknjeni v smeti oziroma naj bodo zares izbrisani."

#: data/org.gnome.gnome-commander.gschema.xml:156
msgid "Icon size"
msgstr "Velikost ikone"

#: data/org.gnome.gnome-commander.gschema.xml:157
msgid "Size of icons in the file panel."
msgstr "Velikost ikon v podoknu datotek."

#: data/org.gnome.gnome-commander.gschema.xml:161
msgid "Icon scale quality"
msgstr "Kakovost prilagoditve velikosti ikone"

#: data/org.gnome.gnome-commander.gschema.xml:162
msgid "Describes the different interpolation modes that can be used with the scaling functions."
msgstr "Določa različni način interpolacije, ki jo je mogoče uporabiti pri prilagajanju velikosti."

#: data/org.gnome.gnome-commander.gschema.xml:166
msgid "MIME icon directory"
msgstr "Mapa ikon MIME"

#: data/org.gnome.gnome-commander.gschema.xml:167
msgid "Directory in which MIME icons are located."
msgstr "Mapa, v kateri so shranjene ikone MIME."

#: data/org.gnome.gnome-commander.gschema.xml:171
msgid "Command line history"
msgstr "Zgodovina ukazne vrstice"

#: data/org.gnome.gnome-commander.gschema.xml:172
msgid "This string array represents the history of commands executed in the command line."
msgstr "Nastavitev predstavlja zgodovino ukazov, ki jih je uporabnik izvršil v ukazni vrstici."

#: data/org.gnome.gnome-commander.gschema.xml:179
msgid "Command line history length"
msgstr "Dolžina zgodovine ukazne vrstice"

#: data/org.gnome.gnome-commander.gschema.xml:183
msgid "Split between panels and command line"
msgstr "Razdeli med plošče in ukazno vrstico"

#: data/org.gnome.gnome-commander.gschema.xml:184
msgid ""
"Determines the height of file panels in pixels. Remaining vertical space is allocated for the command "
"line."
msgstr ""
"Določa višino datotečnih plošč v slikovnih točkah. Preostali navpični prostor je namenjen ukazni vrstici."

#: data/org.gnome.gnome-commander.gschema.xml:190
msgid "Automatically hide command line output"
msgstr "Samodejno skrij izhod ukazne vrstice"

#: data/org.gnome.gnome-commander.gschema.xml:191
msgid "If enabled, command line output is hidden automatically when the command line is inactive."
msgstr "Če je omogočeno, je izhod ukazne vrstice samodejno skrit, ko je ukazna vrstica nedejavna."

#: data/org.gnome.gnome-commander.gschema.xml:197
msgid "Horizontal orientation"
msgstr "Vodoravna postavitev"

#: data/org.gnome.gnome-commander.gschema.xml:198
msgid "Defines if the orientation of the file panels should be horizontal or not."
msgstr "Določa, ali je usmerjenost podoken datotek vodoravna ali navpična."

#: data/org.gnome.gnome-commander.gschema.xml:205
msgid "GUI update rate"
msgstr "Hitrost posodabljanja grafičnega vmesnika"

#: data/org.gnome.gnome-commander.gschema.xml:206
msgid "Update rate of the graphical user interface in 1/1000ths of a second."
msgstr "Posodobite hitrost posodabljanja grafičnega vmesnika v tisočinkah sekunde."

#: data/org.gnome.gnome-commander.gschema.xml:210
msgid "Show device buttons"
msgstr "Pokaži gumbe naprav"

#: data/org.gnome.gnome-commander.gschema.xml:211
msgid "Defines if device buttons are shown."
msgstr "Nastavitev določa, ali so gumbi naprave prikazane v vmesniku."

#: data/org.gnome.gnome-commander.gschema.xml:215
msgid "Show device list"
msgstr "Pokaži seznam naprav"

#: data/org.gnome.gnome-commander.gschema.xml:216
msgid "Defines if the list of devices is shown."
msgstr "Nastavitev določa, ali je prikazan seznam razpoložljivih naprav."

#: data/org.gnome.gnome-commander.gschema.xml:220
msgid "Show command line"
msgstr "Pokaži ukazno vrstico"

#: data/org.gnome.gnome-commander.gschema.xml:221
msgid "Defines if command line is shown."
msgstr "Nastavitev določa, ali je prikazana ukazna vrstica."

#: data/org.gnome.gnome-commander.gschema.xml:225
msgid "Show toolbar"
msgstr "Pokaži orodno vrstico"

#: data/org.gnome.gnome-commander.gschema.xml:226
msgid "Defines if the toolbar is shown."
msgstr "Nastavitev določa, ali je prikazana orodna vrstica."

#: data/org.gnome.gnome-commander.gschema.xml:230
msgid "Show buttonbar"
msgstr "Pokaži funkcijske tipke"

#: data/org.gnome.gnome-commander.gschema.xml:231
msgid "Defines if the buttonbar is shown."
msgstr "Nastavitev določa, ali naj bodo prikazane funkcijske tipke."

#: data/org.gnome.gnome-commander.gschema.xml:235
msgid "Symlink string"
msgstr "Simbolna povezava"

#: data/org.gnome.gnome-commander.gschema.xml:236
msgid ""
"This string defines the default name of a newly created symlink. Leave the string empty to use the "
"default value which is hard coded into the program code. A “%s” will be expanded to the item name for "
"which a link should be created."
msgstr ""
"Niz določa privzeto ime novo ustvarjene simbolne povezave. Prazno polje določa uporabo privzete "
"vrednosti, vpisane v kodi programa. Vrednost »%s« se razširi na ime predmeta, za katerega je treba "
"ustvariti povezavo."

#: data/org.gnome.gnome-commander.gschema.xml:244
msgid "Main window width"
msgstr "Širina glavnega okna"

#: data/org.gnome.gnome-commander.gschema.xml:245
msgid "This option defines the width of the main window."
msgstr "Možnost določa širino glavnega okna."

#: data/org.gnome.gnome-commander.gschema.xml:251
msgid "List of bookmarks"
msgstr "Seznam zaznamkov"

#: data/org.gnome.gnome-commander.gschema.xml:252
msgid "Each entry in this list represents a bookmark."
msgstr "Vsak vnos seznama predstavlja zaznamek."

#: data/org.gnome.gnome-commander.gschema.xml:258
msgid "Bookmarks window width"
msgstr "Širina okna zaznamkov"

#: data/org.gnome.gnome-commander.gschema.xml:259
msgid "This option defines the width of the bookmarks window."
msgstr "Možnost določa višino okna zaznamkov."

#: data/org.gnome.gnome-commander.gschema.xml:265
msgid "Bookmarks window height"
msgstr "Višina okna zaznamkov"

#: data/org.gnome.gnome-commander.gschema.xml:266
msgid "This option defines the height of the bookmarks window."
msgstr "Možnost določa višino okna zaznamkov."

#: data/org.gnome.gnome-commander.gschema.xml:272
msgid "List of connections"
msgstr "Seznam povezav"

#: data/org.gnome.gnome-commander.gschema.xml:273
msgid "Each entry in this list represents a connection."
msgstr "Vsak vnos seznama predstavlja povezavo."

#: data/org.gnome.gnome-commander.gschema.xml:279
msgid "Main window height"
msgstr "Višina glavnega okna"

#: data/org.gnome.gnome-commander.gschema.xml:280
msgid "This option defines the height of the main window."
msgstr "Možnost določa višino glavnega okna."

#: data/org.gnome.gnome-commander.gschema.xml:286
msgid "Options dialog width"
msgstr "Širina okna možnosti"

#: data/org.gnome.gnome-commander.gschema.xml:287
msgid "This setting defines the width of the options dialog window."
msgstr "Nastavitev določa širino okna možnosti."

#: data/org.gnome.gnome-commander.gschema.xml:293
msgid "Options dialog height"
msgstr "Višina okna možnosti"

#: data/org.gnome.gnome-commander.gschema.xml:294
msgid "This setting defines the height of the options dialog window."
msgstr "Nastavitev določa višino okna možnosti."

#: data/org.gnome.gnome-commander.gschema.xml:300
msgid "Width of icon column"
msgstr "Širina stolpca ikone"

#: data/org.gnome.gnome-commander.gschema.xml:301 data/org.gnome.gnome-commander.gschema.xml:308
#: data/org.gnome.gnome-commander.gschema.xml:315 data/org.gnome.gnome-commander.gschema.xml:322
#: data/org.gnome.gnome-commander.gschema.xml:329 data/org.gnome.gnome-commander.gschema.xml:336
#: data/org.gnome.gnome-commander.gschema.xml:343 data/org.gnome.gnome-commander.gschema.xml:350
#: data/org.gnome.gnome-commander.gschema.xml:357 data/org.gnome.gnome-commander.gschema.xml:364
#: data/org.gnome.gnome-commander.gschema.xml:505 data/org.gnome.gnome-commander.gschema.xml:576
msgid "This setting is only present for backwards compatibility and will be removed in future."
msgstr ""
"Ta nastavitev je prisotna le zaradi združljivosti s starejšimi različicami in bo v prihodnosti "
"odstranjena."

#: data/org.gnome.gnome-commander.gschema.xml:307
msgid "Width of name column"
msgstr "Širina stolpca imena datoteke"

#: data/org.gnome.gnome-commander.gschema.xml:314
msgid "Width of extension column"
msgstr "Širina stolpca pripone imena datoteke"

#: data/org.gnome.gnome-commander.gschema.xml:321
msgid "Width of directory column"
msgstr "Širina stolpca mape"

#: data/org.gnome.gnome-commander.gschema.xml:328
msgid "Width of size column"
msgstr "Širina stolpca velikosti"

#: data/org.gnome.gnome-commander.gschema.xml:335
msgid "Width of date column"
msgstr "Širina stolpca datuma"

#: data/org.gnome.gnome-commander.gschema.xml:342
msgid "Width of permissions column"
msgstr "Širina stolpca dovoljenj"

#: data/org.gnome.gnome-commander.gschema.xml:349
msgid "Width of owner column"
msgstr "Širina stolpca lastništva"

#: data/org.gnome.gnome-commander.gschema.xml:356
msgid "Width of group column"
msgstr "Širina stolpca skupine"

#: data/org.gnome.gnome-commander.gschema.xml:363
msgid "Legacy list of keybindings"
msgstr "Zastareli seznam tipkovnih bližnjic"

#: data/org.gnome.gnome-commander.gschema.xml:370
msgid "List of keybindings"
msgstr "Seznam tipkovnih bližnjic"

#: data/org.gnome.gnome-commander.gschema.xml:371
msgid "Each entry in this list represents a keybinding."
msgstr "Vsak vnos seznama določa tipkovno bližnjico."

#: data/org.gnome.gnome-commander.gschema.xml:378
msgid "Main window state"
msgstr "Stanje glavnega okna"

#: data/org.gnome.gnome-commander.gschema.xml:379
msgid ""
"The number represents the main window state, e.g. “maximized”, “fullscreen”, etc. and is calculated "
"internally."
msgstr ""
"Številka predstavlja stanje glavnega okna, npr. »razpeto«, »celozaslonsko« ... in se izračuna interno."

#: data/org.gnome.gnome-commander.gschema.xml:385
msgid "Middle mouse button mode"
msgstr "Način srednjega gumba miške"

#: data/org.gnome.gnome-commander.gschema.xml:386
msgid "Defines what happens when the middle mouse button is clicked."
msgstr "Določa, kaj se zgodi ob kliku srednjega gumba miške."

#: data/org.gnome.gnome-commander.gschema.xml:392
msgid "Save directories on exit"
msgstr "Shrani izbor map ob končanju"

#: data/org.gnome.gnome-commander.gschema.xml:393
msgid "Defines if the current directories are opened again when Gnome Commander is restarted."
msgstr "Določa, ali naj se trenutne mape znova odprejo, ko se program Gnome Commander ponovno zažene."

#: data/org.gnome.gnome-commander.gschema.xml:399
msgid "Save tabs on exit"
msgstr "Shrani zavihke ob končanju"

#: data/org.gnome.gnome-commander.gschema.xml:400
msgid "Defines if the current open tabs are opened again when Gnome Commander is restarted."
msgstr ""
"Določa, ali naj se trenutno odprti zavihki odprejo znova, ko se ponovno zažene program Gnome Commander."

#: data/org.gnome.gnome-commander.gschema.xml:406
msgid "Save directory history on exit"
msgstr "Shrani zgodovino map ob končanju"

#: data/org.gnome.gnome-commander.gschema.xml:407
msgid "Defines if the history of visited directories is saved on exit."
msgstr "Določa, ali naj se zgodovina obiskanih map shranjeni ob končanju."

#: data/org.gnome.gnome-commander.gschema.xml:413
msgid "Save commandline history on exit"
msgstr "Shrani zgodovino ukazne vrstice ob končanju"

#: data/org.gnome.gnome-commander.gschema.xml:414
msgid "Defines if the history of commands in the commandline is saved on exit."
msgstr "Določa, ali naj se zgodovina obiskanih map shranjeni ob končanju."

#: data/org.gnome.gnome-commander.gschema.xml:420
msgid "Save search history on exit"
msgstr "Shrani zgodovino iskanja ob izhodu"

#: data/org.gnome.gnome-commander.gschema.xml:421
msgid "Defines if the history of search patterns is saved on exit."
msgstr "Določa, ali se zgodovina vzorcev iskanja shrani ob izhodu."

#: data/org.gnome.gnome-commander.gschema.xml:427
msgid "Always show tab bar"
msgstr "Vedno pokaži vrstico z zavihki"

#: data/org.gnome.gnome-commander.gschema.xml:428
msgid "Defines if the tab bar is always shown."
msgstr "Določa, ali je vrstica z zavihki vedno vidna."

#: data/org.gnome.gnome-commander.gschema.xml:434 src/dialogs/options/tabs_tab.rs:62
msgid "Tab lock indicator"
msgstr "Določilnik zaklepa zavihka"

#: data/org.gnome.gnome-commander.gschema.xml:435
msgid "Defines the style of the tab lock indicator."
msgstr "Določa slog kazalnika zaklepa zavihka."

#: data/org.gnome.gnome-commander.gschema.xml:441
msgid "Case sensitive sorting"
msgstr "Razvrščaj, upoštevajoč velikost črk"

#: data/org.gnome.gnome-commander.gschema.xml:442
msgid "This option defines if sorting should be case sensitive."
msgstr "Možnost določa, ali naj se pri razvrščanju upošteva tudi velikost črk."

#: data/org.gnome.gnome-commander.gschema.xml:448
msgid "Select directories when all is marked"
msgstr "Izberi mape, ko so izbrani vsi predmeti"

#: data/org.gnome.gnome-commander.gschema.xml:449
msgid "This option defines if directories will be marked when all items in a file panel should be marked."
msgstr ""
"Možnost določa, ali bodo označene tudi vse mape, če uporabnik označi vse predmete v podoknu datotek."

#: data/org.gnome.gnome-commander.gschema.xml:455
msgid "Allow multiple instances"
msgstr "Omogoči odpiranje več primerkov programa"

#: data/org.gnome.gnome-commander.gschema.xml:456
msgid "This option defines if multiple instances are allowed."
msgstr "Možnost določa, ali je dovoljen zagon več kot enega primerka programa."

#: data/org.gnome.gnome-commander.gschema.xml:462
msgid "Only device icons"
msgstr "Le ikone naprave"

#: data/org.gnome.gnome-commander.gschema.xml:463
msgid "This option defines if only device icons should be shown instead of icons and text label."
msgstr "Možnost določa, ali naj bodo namesto ikone in imena prikazane le ikone naprave."

#: data/org.gnome.gnome-commander.gschema.xml:469
msgid "Show the samba workgroups icon"
msgstr "Pokaži ikono omrežja samba"

#: data/org.gnome.gnome-commander.gschema.xml:470
msgid "This option defines if the Samba workgroups icon should be shown in the devices list."
msgstr "Možnost določa, ali naj bo na seznamu naprav prikazana tudi ikona delovnih skupin Samba."

#: data/org.gnome.gnome-commander.gschema.xml:476
msgid "Main menu visibility"
msgstr "Vidnost glavnega menija"

#: data/org.gnome.gnome-commander.gschema.xml:477
msgid "This option defines if the main menu is visible or not."
msgstr "Možnost določa, ali je glavni meni programa prikazan ali ne."

#: data/org.gnome.gnome-commander.gschema.xml:483
msgid "Quick search shortcut"
msgstr "Tipkovna bližnjica za hitro iskanje"

#: data/org.gnome.gnome-commander.gschema.xml:484
msgid "This option defines the shortcut for quick search."
msgstr "Možnost določa tipkovno bližnjico za hitro iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:490
msgid "Default Quick Search mode"
msgstr "Privzeti način hitrega iskanja"

#: data/org.gnome.gnome-commander.gschema.xml:491
msgid "This option defines which mode Quick Search opens with."
msgstr "Ta možnost določa, v katerem načinu se odpre hitro iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:497
msgid "Case sensitive Quick Search"
msgstr "Hitro iskanje z upoštevanjem velikosti črk"

#: data/org.gnome.gnome-commander.gschema.xml:498
msgid "This option is used to remember the state of the \"Case Sensitive\" toggle in Quick Search."
msgstr ""
"Ta možnost se uporablja za shranjevanje nastavitve stikala »Razlikuj med velikimi in malimi črkami« v "
"hitrem iskanju."

#: data/org.gnome.gnome-commander.gschema.xml:504
msgid "Legacy list of file tabs"
msgstr "Stari seznam zavihkov datotek"

#: data/org.gnome.gnome-commander.gschema.xml:511
msgid "List of file tabs"
msgstr "Seznam zavihkov"

#: data/org.gnome.gnome-commander.gschema.xml:512
msgid "The entries in this list are used for restoring the tabs and their history from the last session."
msgstr "Vpisi tega seznama so namenjeni obnovitvi zavihkov in njihove zgodovine iz zadnje seje."

#: data/org.gnome.gnome-commander.gschema.xml:519
msgid "List of devices - deprecated"
msgstr "Seznam naprav - opuščeno"

#: data/org.gnome.gnome-commander.gschema.xml:520 data/org.gnome.gnome-commander.gschema.xml:527
msgid "The entries in this list represent the devices configured by the user."
msgstr "Vnosi na seznamu pomenijo naprave, ki jih je nastavil uporabnik."

#: data/org.gnome.gnome-commander.gschema.xml:526
msgid "List of devices"
msgstr "Seznam naprav"

#: data/org.gnome.gnome-commander.gschema.xml:533
msgid "List of favorite apps"
msgstr "Seznam programov"

#: data/org.gnome.gnome-commander.gschema.xml:534
msgid "The entries in this list represent the favorite apps configured by the user."
msgstr "Vnosi na seznamu pomenijo priljubljene programe, ki jih je nastavil uporabnik."

#: data/org.gnome.gnome-commander.gschema.xml:540
msgid "Search window width"
msgstr "Širina iskalnega okna"

#: data/org.gnome.gnome-commander.gschema.xml:541
msgid "This option defines the width of the search window."
msgstr "Ta možnost določa širino okna za iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:547
msgid "Search window height"
msgstr "Višina iskalnega okna"

#: data/org.gnome.gnome-commander.gschema.xml:548
msgid "This option defines the height of the search window."
msgstr "Ta možnost določa višino okna za iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:554
msgid "Search window is transient"
msgstr "Iskalno okno je prehodno"

#: data/org.gnome.gnome-commander.gschema.xml:555
msgid ""
"Defines if the search window is transient or if it can be minimized and moved behind the main window."
msgstr "Določa, ali je iskalno okno prehodno ali ga je mogoče minimizirati in premakniti za glavnim oknom."

#: data/org.gnome.gnome-commander.gschema.xml:561
msgid "Search text history"
msgstr "Zgodovina iskanega besedila"

#: data/org.gnome.gnome-commander.gschema.xml:562
msgid "This string array represents the history of text searches in the search tool."
msgstr "To polje nizov predstavlja zgodovino iskanja po besedilu v orodju za iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:568
msgid "Search pattern history"
msgstr "Zgodovina iskalnih nizov"

#: data/org.gnome.gnome-commander.gschema.xml:569
msgid "This string array represents the history of regular expression searches in the search tool."
msgstr "Niz predstavlja zgodovino iskanj z logičnimi izrazov v orodju za iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:575
msgid "Legacy search tool profiles"
msgstr "Profili opuščenega orodja za iskanje"

#: data/org.gnome.gnome-commander.gschema.xml:582
msgid "List of search tool profiles"
msgstr "Seznam profilov iskanja"

#: data/org.gnome.gnome-commander.gschema.xml:583
msgid ""
"The entries in this array represent the profiles in the search tool with specific settings for each "
"profile."
msgstr "Vnosi matrike predstavljajo profile v iskalnem orodju z določenimi nastavitvami za vsak profil."

#: data/org.gnome.gnome-commander.gschema.xml:591
msgid "Quick connect URI"
msgstr "Določilo URI za hitro povezavo"

#: data/org.gnome.gnome-commander.gschema.xml:592
msgid "Unified resource identifier for quick connections."
msgstr "Določilo URI za vzpostavljanje hitre povezave."

#: data/org.gnome.gnome-commander.gschema.xml:603
msgid "Password for anonymous FTP connections"
msgstr "Geslo za brezimno povezavo FTP"

#: data/org.gnome.gnome-commander.gschema.xml:604
msgid "This string defines the password for anonymous FTP connections."
msgstr "Niz predstavlja geslo za anonimno povezavo na strežnik FTP."

#: data/org.gnome.gnome-commander.gschema.xml:612
msgid "Confirm delete"
msgstr "Zahtevaj potrditev pred brisanjem"

#: data/org.gnome.gnome-commander.gschema.xml:613
msgid "Defines if deletion of an item should be confirmed."
msgstr "Možnost določa, ali naj se brisanje predmetov uporabniško potrjuje."

#: data/org.gnome.gnome-commander.gschema.xml:619
msgid "Delete default"
msgstr "Privzeto izbriši"

#: data/org.gnome.gnome-commander.gschema.xml:620
msgid "This setting defines the default active option in the delete confirmation dialog."
msgstr "Nastavitev določa privzeto izbiro dejanja v pogovornem oknu brisanja."

#: data/org.gnome.gnome-commander.gschema.xml:626
msgid "Confirm copy overwrite"
msgstr "Zahtevaj potrditev prepisa vsebine med kopiranjem"

#: data/org.gnome.gnome-commander.gschema.xml:627
msgid "This option defines the default behavior when items will be overwritten by a copy command."
msgstr "Možnost določa privzeto dejanje, ko naj bi bili predmeti prepisani z ukazom kopiranja."

#: data/org.gnome.gnome-commander.gschema.xml:633
msgid "Confirm move overwrite"
msgstr "Zahtevaj potrditev premikanja s prepisom"

#: data/org.gnome.gnome-commander.gschema.xml:634
msgid "This option defines the default behavior when items will be overwritten by a move command."
msgstr "Možnost določa privzeto dejanje prepisovanja predmetov pri izvajanju premikanja."

#: data/org.gnome.gnome-commander.gschema.xml:640
msgid "Confirm mouse drag and drop"
msgstr "Zahtevaj potrditev dejanja povleci in spusti"

#: data/org.gnome.gnome-commander.gschema.xml:641
msgid "This option defines the behavior of mouse drag and drop operations."
msgstr "Možnost določa obnašanje miške pri uporabi opravil povleci in spusti."

#: data/org.gnome.gnome-commander.gschema.xml:649
msgid "Hide unknown filetypes"
msgstr "Skrij neznane vrste datotek"

#: data/org.gnome.gnome-commander.gschema.xml:650
msgid "Hide files which type does not match to one of the other types."
msgstr "Skrij datoteke, ki niso skladne z nobeno izmed določenih vrst."

#: data/org.gnome.gnome-commander.gschema.xml:654
msgid "Hide regular files"
msgstr "Skrij običajne datoteke"

#: data/org.gnome.gnome-commander.gschema.xml:658
msgid "Hide directories"
msgstr "Skrij mape"

#: data/org.gnome.gnome-commander.gschema.xml:662
msgid "Hide symbolic links"
msgstr "Skrij simbolne povezave"

#: data/org.gnome.gnome-commander.gschema.xml:666
msgid "Hide special files, such as a socket, fifo, block devices, or character devices."
msgstr "Skrij posebne datoteke, kot so vtiči, bločne naprave, znakovne naprave, datoteke fifo ..."

#: data/org.gnome.gnome-commander.gschema.xml:670
msgid "Hide files and folders starting with a dot"
msgstr "Skrij datoteke in mape, ki se začnejo s piko"

#: data/org.gnome.gnome-commander.gschema.xml:674
msgid "Hide backup files"
msgstr "Skrij datoteke varnostnih kopij"

#: data/org.gnome.gnome-commander.gschema.xml:675
msgid "Hide all files with a suffix defined as the backup pattern."
msgstr "Skrij datoteke s pripono, opredeljeno kot vzorec za varnostne kopije."

#: data/org.gnome.gnome-commander.gschema.xml:679
msgid "Backup file pattern"
msgstr "Vzorec datotek varnostnih kopij"

#: data/org.gnome.gnome-commander.gschema.xml:680
msgid ""
"The given string defines suffixes (separated by semicolon) for files which should be filtered out if "
"backup files should be hidden."
msgstr ""
"Podan niz določa pripone (ločene s podpičjem) datotek, ki so skrite, če je določena možnost skrivanja "
"datotek varnostnih kopij."

#: data/org.gnome.gnome-commander.gschema.xml:689
msgid "Do not download files"
msgstr "Ne prejemaj datotek"

#: data/org.gnome.gnome-commander.gschema.xml:690
msgid "This option defines if remote files should be downloaded before opened by external programs."
msgstr "Možnost določa, ali naj bodo oddaljene datoteke pred odpiranjem najprej prejete krajevno."

#: data/org.gnome.gnome-commander.gschema.xml:696
msgid "Use internal viewer"
msgstr "Uporabi notranji pregledovalnik"

#: data/org.gnome.gnome-commander.gschema.xml:697
msgid "This option defines if the internal viewer should be used by default."
msgstr "Možnost določa, ali naj bo privzeto uporabljen notranji pregledovalnik."

#: data/org.gnome.gnome-commander.gschema.xml:703
msgid "Viewer command"
msgstr "Ukaz za zagon pregledovalnika"

#: data/org.gnome.gnome-commander.gschema.xml:704
msgid "This string defines the command for starting the (external) viewer."
msgstr "Niz določa ukaz za zagon (zunanjega) pregledovalnika."

#: data/org.gnome.gnome-commander.gschema.xml:710
msgid "Editor command"
msgstr "Ukaz za zagon urejevalnika"

#: data/org.gnome.gnome-commander.gschema.xml:711
msgid "This string defines the command for starting the editor."
msgstr "Niz določa ukaz, ki izvede zagon urejevalnika."

#: data/org.gnome.gnome-commander.gschema.xml:717
msgid "Differ command"
msgstr "Ukaz za primerjavo datotek"

#: data/org.gnome.gnome-commander.gschema.xml:718
msgid "This string defines the command for starting the diff tool."
msgstr "Niz določa ukaz za zagon orodja za primerjavo."

#: data/org.gnome.gnome-commander.gschema.xml:724
msgid "Use internal search"
msgstr "Uporabi notranje iskanje"

#: data/org.gnome.gnome-commander.gschema.xml:725
msgid "This option defines if the internal search should be used by default."
msgstr "Možnost določa, ali naj se privzeto uporablja notranje iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:731
msgid "Search command"
msgstr "Iskalni ukaz"

#: data/org.gnome.gnome-commander.gschema.xml:732
msgid "This string defines the command for starting an external file search tool."
msgstr "Niz določa ukaz za zagon zunanjega orodja za iskanje."

#: data/org.gnome.gnome-commander.gschema.xml:738
msgid "Command for opening a terminal"
msgstr "Ukaz za odpiranje terminala"

#: data/org.gnome.gnome-commander.gschema.xml:739
msgid "This string defines the command for opening a terminal."
msgstr "Možnost določa ukaz za zagon terminala."

#: data/org.gnome.gnome-commander.gschema.xml:745
msgid "Command for execution in terminal"
msgstr "Ukaz za izvedbo v terminalu"

#: data/org.gnome.gnome-commander.gschema.xml:746
msgid "This string defines the command for executing another command in a terminal."
msgstr "Niz določa ukaz, ki izvede drug ukaz v oknu terminala."

#: data/org.gnome.gnome-commander.gschema.xml:752
msgid "Send to command"
msgstr "Ukaz za pošiljanje"

#: data/org.gnome.gnome-commander.gschema.xml:753
msgid "This string defines the command for sending files to a receiver."
msgstr "Niz določa ukaz za pošiljanje datotek na prejemnik."

#: data/org.gnome.gnome-commander.gschema.xml:761
msgid "Color theme"
msgstr "Barvna tema"

#: data/org.gnome.gnome-commander.gschema.xml:762
msgid "This option defines the current color theme."
msgstr "Možnost določa trenutno barvno temo."

#: data/org.gnome.gnome-commander.gschema.xml:768
msgid "Normal foreground color"
msgstr "Običajna barva pisave"

#: data/org.gnome.gnome-commander.gschema.xml:769
msgid "Normal foreground color in custom mode."
msgstr "Običajna barva pisave pri uporabi sheme po meri."

#: data/org.gnome.gnome-commander.gschema.xml:775
msgid "Normal background color"
msgstr "Običajna barva ozadja"

#: data/org.gnome.gnome-commander.gschema.xml:776
msgid "Normal background color in custom mode."
msgstr "Običajna barva ozadja pri uporabi sheme po meri."

#: data/org.gnome.gnome-commander.gschema.xml:782
msgid "Alternate foreground color"
msgstr "Druga barva pisave"

#: data/org.gnome.gnome-commander.gschema.xml:783
msgid "Alternate foreground color in custom mode."
msgstr "Druga barva pisave pri uporabi sheme po meri."

#: data/org.gnome.gnome-commander.gschema.xml:789
msgid "Alternate background color"
msgstr "Druga barva ozadja"

#: data/org.gnome.gnome-commander.gschema.xml:790
msgid "Alternate background color in custom mode."
msgstr "Druga barva ozadja pri uporabi sheme po meri."

#: data/org.gnome.gnome-commander.gschema.xml:796
msgid "Selection foreground color"
msgstr "Barva ospredja izbora"

#: data/org.gnome.gnome-commander.gschema.xml:797
msgid "Foreground color for selections in custom mode."
msgstr "Barva pisave izbora v seznamu pri uporabi sheme po meri."

#: data/org.gnome.gnome-commander.gschema.xml:803
msgid "Selection background color"
msgstr "Barva ozadja izbora"

#: data/org.gnome.gnome-commander.gschema.xml:804
msgid "Background color for selections in custom mode."
msgstr "Barva ozadja izbora v seznamu pri uporabi sheme po meri."

#: data/org.gnome.gnome-commander.gschema.xml:810
msgid "Cursor foreground color"
msgstr "Barva ospredja kazalke"

#: data/org.gnome.gnome-commander.gschema.xml:811
msgid "Cursor foreground color in custom mode."
msgstr "Barva ospredja kazalke v shemi po meri."

#: data/org.gnome.gnome-commander.gschema.xml:817
msgid "Cursor background color"
msgstr "Barva ozadja kazalke"

#: data/org.gnome.gnome-commander.gschema.xml:818
msgid "Cursor background color in custom mode."
msgstr "Barva ozadja kazalke v shemi po meri."

#: data/org.gnome.gnome-commander.gschema.xml:824
msgid "Use LS colors"
msgstr "Uporabi barvno paleto LS"

#: data/org.gnome.gnome-commander.gschema.xml:825
msgid ""
"This option triggers if the value of the environment variable LS_COLORS should be used to dye files and "
"folders."
msgstr ""
"Možnost sproži izbor vrednosti okoljske spremenljivke LS_COLORS, ki je nato uporabljena za barvo datotek "
"in map."

#: data/org.gnome.gnome-commander.gschema.xml:832
msgid "LS_COLORS black foreground mapping"
msgstr "Preslikava črnega ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:833
msgid "This option adjusts the foreground color mapping for LS_COLORS black value."
msgstr "Možnost prilagodi preslikavo vrednosti črne barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:839
msgid "LS_COLORS black background mapping"
msgstr "Preslikava črnega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:840
msgid "This option adjusts the background color mapping for LS_COLORS black value."
msgstr "Možnost prilagodi preslikavo vrednosti črne barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:846
msgid "LS_COLORS red foreground mapping"
msgstr "Preslikava rdečega ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:847
msgid "This option adjusts the foreground color mapping for LS_COLORS red value."
msgstr "Možnost prilagodi preslikavo vrednosti rdeče barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:853
msgid "LS_COLORS red background mapping"
msgstr "Preslikava rdečega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:854
msgid "This option adjusts the background color mapping for LS_COLORS red value."
msgstr "Možnost prilagodi preslikavo vrednosti rdeče barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:860
msgid "LS_COLORS green foreground mapping"
msgstr "Preslikava zelenega ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:861
msgid "This option adjusts the foreground color mapping for LS_COLORS green value."
msgstr "Možnost prilagodi preslikavo vrednosti zelene barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:867
msgid "LS_COLORS green background mapping"
msgstr "Preslikava zelenega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:868
msgid "This option adjusts the background color mapping for LS_COLORS green value."
msgstr "Možnost prilagodi preslikavo vrednosti zelene barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:874
msgid "LS_COLORS yellow foreground mapping"
msgstr "Preslikava rumenega ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:875
msgid "This option adjusts the foreground color mapping for LS_COLORS yellow value."
msgstr "Možnost prilagodi preslikavo vrednosti rumene barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:881
msgid "LS_COLORS yellow background mapping"
msgstr "Preslikava rumenega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:882
msgid "This option adjusts the background color mapping for LS_COLORS yellow value."
msgstr "Možnost prilagodi preslikavo vrednosti rumene barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:888
msgid "LS_COLORS blue foreground mapping"
msgstr "Preslikava modrega ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:889
msgid "This option adjusts the foreground color mapping for LS_COLORS blue value."
msgstr "Možnost prilagodi preslikavo vrednosti modre barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:895
msgid "LS_COLORS blue background mapping"
msgstr "Preslikava modrega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:896
msgid "This option adjusts the background color mapping for LS_COLORS blue value."
msgstr "Možnost prilagodi preslikavo vrednosti modre barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:902
msgid "LS_COLORS magenta foreground mapping"
msgstr "Preslikava škrlatnega ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:903
msgid "This option adjusts the foreground color mapping for LS_COLORS magenta value."
msgstr "Možnost prilagodi preslikavo vrednosti škrlatne barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:909
msgid "LS_COLORS magenta background mapping"
msgstr "Preslikava škrlatnega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:910
msgid "This option adjusts the background color mapping for LS_COLORS magenta value."
msgstr "Možnost prilagodi preslikavo vrednosti škrlatne barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:916
msgid "LS_COLORS cyan foreground mapping"
msgstr "Preslikava sinjeg ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:917
msgid "This option adjusts the foreground color mapping for LS_COLORS cyan value."
msgstr "Možnost prilagodi preslikavo vrednosti sinje barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:923
msgid "LS_COLORS cyan background mapping"
msgstr "Preslikava sinjega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:924
msgid "This option adjusts the background color mapping for LS_COLORS cyan value."
msgstr "Možnost prilagodi preslikavo vrednosti sinje barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:930
msgid "LS_COLORS white foreground mapping"
msgstr "Preslikava belega ospredja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:931
msgid "This option adjusts the foreground color mapping for LS_COLORS white value."
msgstr "Možnost prilagodi preslikavo vrednosti bele barve v shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:937
msgid "LS_COLORS white background mapping"
msgstr "Preslikava belega ozadja sheme LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:938
msgid "This option adjusts the background color mapping for LS_COLORS white value."
msgstr "Možnost prilagodi preslikavo vrednosti bele barve ozadja shemi LS_COLOR."

#: data/org.gnome.gnome-commander.gschema.xml:946
msgid "Case sensitive search"
msgstr "Išči z upoštevanjem velikosti črk"

#: data/org.gnome.gnome-commander.gschema.xml:947
msgid "This option defines if searching within the internal viewer is case sensitive."
msgstr "Možnost določa, ali naj iskanje v notranjem pregledovalniku upošteva velikost črk."

#: data/org.gnome.gnome-commander.gschema.xml:953
msgid "Search mode"
msgstr "Iskalni način"

#: data/org.gnome.gnome-commander.gschema.xml:954
msgid "This option defines the search mode of the internal viewer."
msgstr "Možnost določa iskalni način notranjega pregledovalnika."

#: data/org.gnome.gnome-commander.gschema.xml:960
msgid "Character set"
msgstr "Znakovni nabor"

#: data/org.gnome.gnome-commander.gschema.xml:961
msgid "This option defines the default character encoding."
msgstr "Možnost določa privzet kodni nabor znakov."

#: data/org.gnome.gnome-commander.gschema.xml:967
msgid "Monospaced font"
msgstr "Pisava enakomerne širine"

#: data/org.gnome.gnome-commander.gschema.xml:968
msgid ""
"Description of the monospaced font used to display text. It should include at least font name and size "
"but can also contain additional options like Italic Light."
msgstr ""
"Opis pisave z enakomernim razmikom, ki se uporablja za prikaz besedila. Vsebovati mora vsaj ime pisave in "
"velikost, lahko pa vključuje tudi dodatne možnosti, kot je npr. »Italic Light« oz. »ležeča, tanka«."

#: data/org.gnome.gnome-commander.gschema.xml:975
msgid "Display hex offset"
msgstr "Pokaži šestnajstiški zamik"

#: data/org.gnome.gnome-commander.gschema.xml:976
msgid "This option defines if the hexadecimal offset should be displayed in hex mode."
msgstr "Možnost določa šestnajstiški odmik notranjega pregledovalnika v šestnajstiškem načinu pogleda."

#: data/org.gnome.gnome-commander.gschema.xml:982
msgid "Wrap mode"
msgstr "Način preloma"

#: data/org.gnome.gnome-commander.gschema.xml:983
msgid "This option defines if too long text lines should be wrapped."
msgstr "Možnost določa, ali naj se predolge besedilne vrstice prelomijo po določenem številu znakov."

#: data/org.gnome.gnome-commander.gschema.xml:989
msgid "Tab size"
msgstr "Velikost zamika tabulatorja"

#: data/org.gnome.gnome-commander.gschema.xml:990
msgid "This option defines the indentation width in terms of characters for a tabulator character."
msgstr "Možnost določa širino zamika kot število znakov za znake tabulatorja."

#: data/org.gnome.gnome-commander.gschema.xml:996
msgid "Bytes per line in binary mode"
msgstr "Število bajtov v vrstici v dvojiškem načinu"

#: data/org.gnome.gnome-commander.gschema.xml:997
msgid "This option defines how many bytes should be displayed in one line in binary mode."
msgstr "Možnost določa velikost prikazane vrstice dvojiškega izpisa v bajtih."

#: data/org.gnome.gnome-commander.gschema.xml:1003
msgid "Metadata view"
msgstr "Metapodatkovni pogled"

#: data/org.gnome.gnome-commander.gschema.xml:1004
msgid "This option defines if metadata should be visible."
msgstr "Možnost določa, ali naj bodo metapodatki prikazani."

#: data/org.gnome.gnome-commander.gschema.xml:1010
msgid "Window width"
msgstr "Širina okna"

#: data/org.gnome.gnome-commander.gschema.xml:1011
msgid "The width of the internal file viewer window."
msgstr "Določa širino okna notranjega pregledovalnika."

#: data/org.gnome.gnome-commander.gschema.xml:1017
msgid "Window height"
msgstr "Višina okna"

#: data/org.gnome.gnome-commander.gschema.xml:1018
msgid "The height of the internal file viewer window."
msgstr "Določa višino okna notranjega pregledovalnika."

#: data/org.gnome.gnome-commander.gschema.xml:1024
msgid "Window state"
msgstr "Stanje okna"

