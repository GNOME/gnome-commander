#~ "morja določi vrednost 1, dejanska vrednost pa se zabeleži kot absolutna vrednost v oznaki "
#~ "<Exif.GPS.Altitude>. Vrednost je v metrih."

#~ msgid "GPS Info IFDPointer"
#~ msgstr "GPS Info IFDPointer"

#~ msgid ""
