#: data/org.gnome.gnome-commander.desktop.in:2
#: data/org.gnome.gnome-commander.metainfo.xml.in:16 src/main_win.rs:271
msgid "Gnome Commander"
msgstr "Gnome Commander"

#: data/org.gnome.gnome-commander.desktop.in:3
msgid "A file manager using dual-panel layout"
msgstr "Програма для керування файлами з двопанельним компонуванням вікна"

#. TRANSLATORS: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gnome-commander.desktop.in:5
msgid "file;manager;folder;explore;disk;filesystem;"
msgstr ""
"file;manager;folder;explore;disk;filesystem;файл;керування;менеджер;тека;наві"
"гація;диск;файлова "
"система;"

#: data/org.gnome.gnome-commander.gschema.xml:52
msgid "List of advanced rename tool profiles"
msgstr "Список профілів засобу перейменування із додатковими можливостями"

#: data/org.gnome.gnome-commander.gschema.xml:53
msgid ""
"The entries in this array represent the profiles in the advanced rename tool "
"with specific settings for each profile."
msgstr ""
"Записи у цьому масиві визначають профілі у засобі перейменування із "
"додатковими можливостями. Кожен запис зберігає специфічні параметри "
"відповідного профілю."

#: data/org.gnome.gnome-commander.gschema.xml:59
msgid "Advanced rename tool window width"
msgstr "Ширина вікна засобу перейменування із додатковими можливостями"

#: data/org.gnome.gnome-commander.gschema.xml:60
msgid "This option defines the width of the advanced rename tool window."
msgstr ""
"Цей параметр визначає ширину вікна засобу перейменування із додатковими "
"можливостями."

#: data/org.gnome.gnome-commander.gschema.xml:66
msgid "Advanced rename tool window height"
msgstr "Висота вікна засобу перейменування із додатковими можливостями"

#: data/org.gnome.gnome-commander.gschema.xml:67
msgid "This option defines the height of the advanced rename tool window."
msgstr ""
"Цей параметр визначає висоту вікна засобу перейменування із додатковими "
"можливостями."

#: data/org.gnome.gnome-commander.gschema.xml:73
msgid "Advanced rename tool template history"
msgstr "Журнал шаблонів засобу перейменування із додатковими можливостями"

#: data/org.gnome.gnome-commander.gschema.xml:74
msgid ""
"This string array represents the history of templates in the advanced rename "
"tool."
msgstr ""
"Цей масив рядків зберігає журнал шаблонів засобу перейменовування із "
"додатковими можливостями."

#: data/org.gnome.gnome-commander.gschema.xml:80
msgid "History of visited directories"
msgstr "Журнал відвіданих каталогів"

#: data/org.gnome.gnome-commander.gschema.xml:81
msgid "This string array represents the history of visited directories."
msgstr "Цей масив рядків відповідає журналу відвіданих каталогів."

#: data/org.gnome.gnome-commander.gschema.xml:87
msgid "Filesize display mode"
msgstr "Режим показу розміру файлів"

#: data/org.gnome.gnome-commander.gschema.xml:88
msgid ""
"Defines how the filesize will be displayed in the associated panel column."
msgstr ""
"Визначає, як буде показано розмір файла у пов'язаному із ним стовпчику "
"панелі."

#: data/org.gnome.gnome-commander.gschema.xml:94
#: src/dialogs/options/format_tab.rs:86
msgid "Permission display mode"
msgstr "Режим відображення прав доступу"

#: data/org.gnome.gnome-commander.gschema.xml:95
msgid ""
"Defines how the file permission will be displayed in the associated panel "
"column."
msgstr ""
"Визначає, як буде показано права доступу у пов'язаному із ними стовпчику "
"панелі."

#: data/org.gnome.gnome-commander.gschema.xml:101
msgid "Graphical layout mode"
msgstr "Режим компонування графіки"

#: data/org.gnome.gnome-commander.gschema.xml:102
msgid "Defines the icon style of files and folders in the file panels."
msgstr "Визначає стиль піктограм файлів і тек на панелях файлів."

#. Translators: Feel free to replace the default date format to a common value
#. used in your country. See https://docs.gtk.org/glib/method.DateTime.format.html for details.
#. Attention: Do not change the single quotes which sourround the string.
#. If nothing is set, the application uses the hard-coded value '%c', which is
#. "the preferred date and time representation for the current locale".
#: data/org.gnome.gnome-commander.gschema.xml:112
msgid "'%F %R'"
msgstr "'%d.%m.%y %R'"

#: data/org.gnome.gnome-commander.gschema.xml:113
#: src/dialogs/options/format_tab.rs:94
msgid "Date format"
msgstr "Формат дати"

#: data/org.gnome.gnome-commander.gschema.xml:114
msgid "Format of the date in the file panel."
msgstr "Формат дат на панелі файлів."

#: data/org.gnome.gnome-commander.gschema.xml:120
msgid "List font"
msgstr "Шрифт списку"

#: data/org.gnome.gnome-commander.gschema.xml:121
msgid "The font in the file panels."
msgstr "Шрифт на панелях файлів."

#: data/org.gnome.gnome-commander.gschema.xml:125
msgid "Extension display mode"
msgstr "Режим показу суфіксів назв"

#: data/org.gnome.gnome-commander.gschema.xml:126
msgid "Defines where the file name extension is displayed."
msgstr "Визначає місце показу суфікса назви файла."

#: data/org.gnome.gnome-commander.gschema.xml:132
msgid "Left mouse button mode"
msgstr "Режим лівої кнопки миші"

#: data/org.gnome.gnome-commander.gschema.xml:133
msgid "Number of left mouse button clicks for opening a file or folder."
msgstr ""
"Кількість клацань лівою кнопкою миші, яка потрібна для відкриття файла або "
"теки."

#: data/org.gnome.gnome-commander.gschema.xml:139
msgid "Left mouse button unselects"
msgstr "Ліва кнопка миші знімає позначення"

#: data/org.gnome.gnome-commander.gschema.xml:140
msgid ""
"Defines if a click on an unselected item unselects already selected items."
msgstr ""
"Визначає, чи буде клацання на непозначеному записі призводити до зняття "
"позначення з позначених записів."

#: data/org.gnome.gnome-commander.gschema.xml:146
msgid "Right mouse button mode"
msgstr "Режим правої кнопки миші"

#: data/org.gnome.gnome-commander.gschema.xml:147
msgid ""
"Defines what happens when the right mouse button is clicked on an item."
msgstr "Визначає дію у відповідь на клацання правою кнопкою миші на пункті."

#: data/org.gnome.gnome-commander.gschema.xml:153
msgid "Use trash"
msgstr "Скористатися смітником"

#: data/org.gnome.gnome-commander.gschema.xml:154
msgid ""
"Defines if items should be moved to trash by default instead of really "
"deleting them."
msgstr ""
"Визначає, чи має бути типово пересунуто записи до смітника замість "
"справжнього вилучення."

#: data/org.gnome.gnome-commander.gschema.xml:160
msgid "Icon size"
msgstr "Розмір піктограм"

#: data/org.gnome.gnome-commander.gschema.xml:161
msgid "Size of icons in the file panel."
msgstr "Розмір піктограм на панелі файлів."

#: data/org.gnome.gnome-commander.gschema.xml:165
msgid "Icon scale quality"
msgstr "Якість масштабування піктограм"

#: data/org.gnome.gnome-commander.gschema.xml:166
msgid ""
"Describes the different interpolation modes that can be used with the "
"scaling functions."
msgstr ""
"Описує різні режими інтерполяції, якими можна скористатися у функціях "
"масштабування."

#: data/org.gnome.gnome-commander.gschema.xml:170
msgid "Command line history"
msgstr "Журнал командного рядка"

#: data/org.gnome.gnome-commander.gschema.xml:171
msgid ""
"This string array represents the history of commands executed in the command "
"line."
msgstr ""
"Цей масив рядків є представленням журналу команд, які було віддано у "
"командному рядку."

#: data/org.gnome.gnome-commander.gschema.xml:178
msgid "Command line history length"
msgstr "Довжина журналу командного рядка"

#: data/org.gnome.gnome-commander.gschema.xml:182
msgid "Split between panels and command line"
msgstr "Поділ між панелями і командним рядком"

#: data/org.gnome.gnome-commander.gschema.xml:183
msgid ""
"Determines the height of file panels in pixels. Remaining vertical space is "
"allocated for the command line."
msgstr ""
"Визначає висоту файлових панелей у пікселях. Решту вертикального простору "
"буде використано для командного рядка."

#: data/org.gnome.gnome-commander.gschema.xml:189
msgid "Automatically hide command line output"
msgstr "Автоматично ховати виведення до командного рядка"

#: data/org.gnome.gnome-commander.gschema.xml:190
msgid ""
"If enabled, command line output is hidden automatically when the command "
"line is inactive."
msgstr ""
"Якщо увімкнено, виведені до командного рядка дані буде автоматично "
"приховано, коли командний рядок є неактивним."

#: data/org.gnome.gnome-commander.gschema.xml:196
msgid "Horizontal orientation"
msgstr "Горизонтальна орієнтація"

#: data/org.gnome.gnome-commander.gschema.xml:197
msgid ""
"Defines if the orientation of the file panels should be horizontal or not."
msgstr "Визначає, чи буде орієнтація панелей файлів горизонтальною."

#: data/org.gnome.gnome-commander.gschema.xml:204
msgid "GUI update rate"
msgstr "Інтервал оновлення інтерфейсу"

#: data/org.gnome.gnome-commander.gschema.xml:205
msgid "Update rate of the graphical user interface in 1/1000ths of a second."
msgstr ""
"Інтервал оновлення графічного зображення для користувача у тисячних секунди."

#: data/org.gnome.gnome-commander.gschema.xml:209
msgid "Show device buttons"
msgstr "Показати кнопки пристроїв"

#: data/org.gnome.gnome-commander.gschema.xml:210
msgid "Defines if device buttons are shown."
msgstr "Визначає, чи буде показано кнопки пристроїв."

#: data/org.gnome.gnome-commander.gschema.xml:214
msgid "Show device list"
msgstr "Показати список пристроїв"

#: data/org.gnome.gnome-commander.gschema.xml:215
msgid "Defines if the list of devices is shown."
msgstr "Визначає, чи має бути показано список пристроїв."

#: data/org.gnome.gnome-commander.gschema.xml:219
msgid "Show command line"
msgstr "Показати командний рядок"

#: data/org.gnome.gnome-commander.gschema.xml:220
msgid "Defines if command line is shown."
msgstr "Визначає, чи має бути показано командний рядок."

#: data/org.gnome.gnome-commander.gschema.xml:224
msgid "Show toolbar"
msgstr "Показати панель інструментів"

#: data/org.gnome.gnome-commander.gschema.xml:225
msgid "Defines if the toolbar is shown."
msgstr "Визначає, чи буде показано панель інструментів."

#: data/org.gnome.gnome-commander.gschema.xml:229
msgid "Show buttonbar"
msgstr "Показати панель кнопок"

#: data/org.gnome.gnome-commander.gschema.xml:230
msgid "Defines if the buttonbar is shown."
msgstr "Визначає, чи має бути показано панель кнопок."

#: data/org.gnome.gnome-commander.gschema.xml:234
msgid "Symlink string"
msgstr "Рядок символьного посилання"

#: data/org.gnome.gnome-commander.gschema.xml:235
msgid ""
"This string defines the default name of a newly created symlink. Leave the "
"string empty to use the default value which is hard coded into the program "
"code. A “%s” will be expanded to the item name for which a link should be "
"created."
msgstr ""
"Цей рядок визначає типову назву для новостворених символічних посилань. Не "
"заповнюйте, якщо слід використати типове значення, яке жорстко закодовано до "
"коду програми. Замінник «%s» буде розгорнуто до назви запису, для якого має "
"бути створено посилання."

#: data/org.gnome.gnome-commander.gschema.xml:243
msgid "Main window width"
msgstr "Ширина головного вікна"

#: data/org.gnome.gnome-commander.gschema.xml:244
msgid "This option defines the width of the main window."
msgstr "Цей параметр визначає ширину головного вікна програми."

#: data/org.gnome.gnome-commander.gschema.xml:250
msgid "List of bookmarks"
msgstr "Список закладок"

#: data/org.gnome.gnome-commander.gschema.xml:251
msgid "Each entry in this list represents a bookmark."
msgstr "Кожен запис у цьому списку є закладкою."

#: data/org.gnome.gnome-commander.gschema.xml:257
msgid "Bookmarks window width"
msgstr "Ширина вікна закладок"

#: data/org.gnome.gnome-commander.gschema.xml:258
msgid "This option defines the width of the bookmarks window."
msgstr "Цей параметр визначає ширину вікна закладок програми."

#: data/org.gnome.gnome-commander.gschema.xml:264
msgid "Bookmarks window height"
msgstr "Висота вікна закладок"

#: data/org.gnome.gnome-commander.gschema.xml:265
msgid "This option defines the height of the bookmarks window."
msgstr "Цей параметр визначає висоту вікна закладок програми."

#: data/org.gnome.gnome-commander.gschema.xml:271
msgid "List of connections"
msgstr "Список з'єднань"

#: data/org.gnome.gnome-commander.gschema.xml:272
msgid "Each entry in this list represents a connection."
msgstr "Кожен із записів у цьому списку є записом з'єднання."

#: data/org.gnome.gnome-commander.gschema.xml:278
msgid "Main window height"
msgstr "Висота головного вікна"

#: data/org.gnome.gnome-commander.gschema.xml:279
msgid "This option defines the height of the main window."
msgstr "Цей параметр визначає висоту головного вікна програми."

#: data/org.gnome.gnome-commander.gschema.xml:285
msgid "Options dialog width"
msgstr "Ширина вікна параметрів"

#: data/org.gnome.gnome-commander.gschema.xml:286
msgid "This setting defines the width of the options dialog window."
msgstr "Цей параметр визначає ширину діалогового вікна параметрів."

#: data/org.gnome.gnome-commander.gschema.xml:292
msgid "Options dialog height"
msgstr "Висота вікна параметрів"

#: data/org.gnome.gnome-commander.gschema.xml:293
msgid "This setting defines the height of the options dialog window."
msgstr "Цей параметр визначає висоту діалогового вікна параметрів."

#: data/org.gnome.gnome-commander.gschema.xml:299
msgid "Width of icon column"
msgstr "Ширина стовпчика піктограм"

#: data/org.gnome.gnome-commander.gschema.xml:300
#: data/org.gnome.gnome-commander.gschema.xml:307
#: data/org.gnome.gnome-commander.gschema.xml:314
#: data/org.gnome.gnome-commander.gschema.xml:321
#: data/org.gnome.gnome-commander.gschema.xml:328
#: data/org.gnome.gnome-commander.gschema.xml:335
#: data/org.gnome.gnome-commander.gschema.xml:342
#: data/org.gnome.gnome-commander.gschema.xml:349
#: data/org.gnome.gnome-commander.gschema.xml:356
#: data/org.gnome.gnome-commander.gschema.xml:363
#: data/org.gnome.gnome-commander.gschema.xml:504
#: data/org.gnome.gnome-commander.gschema.xml:575
msgid ""
"This setting is only present for backwards compatibility and will be removed "
"in future."
msgstr ""
"Цей параметр є у програмі лише для зворотної сумісності — його буде вилучено "
"у майбутніх версіях."

#: data/org.gnome.gnome-commander.gschema.xml:306
msgid "Width of name column"
msgstr "Ширина стовпчика назв"

#: data/org.gnome.gnome-commander.gschema.xml:313
msgid "Width of extension column"
msgstr "Ширина стовпчика суфіксів назв"

#: data/org.gnome.gnome-commander.gschema.xml:320
msgid "Width of directory column"
msgstr "Ширина стовпчика каталогу"

#: data/org.gnome.gnome-commander.gschema.xml:327
msgid "Width of size column"
msgstr "Ширина стовпчика розмірів"

#: data/org.gnome.gnome-commander.gschema.xml:334
msgid "Width of date column"
msgstr "Ширина стовпчика даних"

#: data/org.gnome.gnome-commander.gschema.xml:341
msgid "Width of permissions column"
msgstr "Ширина стовпчика прав доступу"

#: data/org.gnome.gnome-commander.gschema.xml:348
msgid "Width of owner column"
msgstr "Ширина стовпчика власників"

#: data/org.gnome.gnome-commander.gschema.xml:355
msgid "Width of group column"
msgstr "Ширина стовпчика груп"

#: data/org.gnome.gnome-commander.gschema.xml:362
msgid "Legacy list of keybindings"
msgstr "Застарілий список клавіатурних скорочень"

#: data/org.gnome.gnome-commander.gschema.xml:369
msgid "List of keybindings"
msgstr "Список клавіатурних скорочень"

#: data/org.gnome.gnome-commander.gschema.xml:370
msgid "Each entry in this list represents a keybinding."
msgstr "Кожен запис у цьому списку відповідає клавіатурному скороченню."

#: data/org.gnome.gnome-commander.gschema.xml:377
msgid "Main window state"
msgstr "Стан головного вікна"

#: data/org.gnome.gnome-commander.gschema.xml:378
msgid ""
"The number represents the main window state, e.g. “maximized”, “fullscreen”, "
"etc. and is calculated internally."
msgstr ""
"Число, яке відповідає стану головного вікна, наприклад «максимізовано», «на "
"увесь екран» тощо. Обчислюється на внутрішньому рівні програми."

#: data/org.gnome.gnome-commander.gschema.xml:384
msgid "Middle mouse button mode"
msgstr "Режим середньої кнопки миші"

#: data/org.gnome.gnome-commander.gschema.xml:385
msgid "Defines what happens when the middle mouse button is clicked."
msgstr ""
"Визначає дію, яку буде виконано у відповідь на клацання середньою кнопкою "
"миші."

#: data/org.gnome.gnome-commander.gschema.xml:391
msgid "Save directories on exit"
msgstr "Зберігати каталоги при виході"

#: data/org.gnome.gnome-commander.gschema.xml:392
msgid ""
"Defines if the current directories are opened again when Gnome Commander is "
"restarted."
msgstr ""
"Визначає, чи має програма відкривати поточні каталоги, коли Gnome Commander "
"буде перезапущено."

#: data/org.gnome.gnome-commander.gschema.xml:398
msgid "Save tabs on exit"
msgstr "Зберігати вкладки при виході"

#: data/org.gnome.gnome-commander.gschema.xml:399
msgid ""
"Defines if the current open tabs are opened again when Gnome Commander is "
"restarted."
msgstr ""
"Визначає, чи має програма відкривати поточні відкриті вкладки, коли Gnome "
"Commander буде перезапущено."

#: data/org.gnome.gnome-commander.gschema.xml:405
msgid "Save directory history on exit"
msgstr "Зберігати журнал каталогів під час виходу"

#: data/org.gnome.gnome-commander.gschema.xml:406
msgid "Defines if the history of visited directories is saved on exit."
msgstr ""
"Визначає, чи буде програма зберігати журнал відвіданих каталогів при виході."

#: data/org.gnome.gnome-commander.gschema.xml:412
msgid "Save commandline history on exit"
msgstr "Зберігати журнал командного рядка при виході"

#: data/org.gnome.gnome-commander.gschema.xml:413
msgid ""
"Defines if the history of commands in the commandline is saved on exit."
msgstr ""
"Визначає, чи буде програма зберігати журнал команд, відданих у командному "
"рядку, при виході."

#: data/org.gnome.gnome-commander.gschema.xml:419
msgid "Save search history on exit"
msgstr "Зберігати журнал пошуку при виході"

#: data/org.gnome.gnome-commander.gschema.xml:420
msgid "Defines if the history of search patterns is saved on exit."
msgstr ""
"Визначає, чи буде програма зберігати журнал взірців пошуку при виході."

#: data/org.gnome.gnome-commander.gschema.xml:426
msgid "Always show tab bar"
msgstr "Завжди показувати панель вкладок"

#: data/org.gnome.gnome-commander.gschema.xml:427
msgid "Defines if the tab bar is always shown."
msgstr "Визначає, чи буде безумовного показано панель вкладок."

#: data/org.gnome.gnome-commander.gschema.xml:433
#: src/dialogs/options/tabs_tab.rs:62
msgid "Tab lock indicator"
msgstr "Індикатор блокування вкладки"

#: data/org.gnome.gnome-commander.gschema.xml:434
msgid "Defines the style of the tab lock indicator."
msgstr "Визначає стиль індикатора блокування вкладки."

#: data/org.gnome.gnome-commander.gschema.xml:440
msgid "Case sensitive sorting"
msgstr "Впорядкування з урахуванням регістру"

#: data/org.gnome.gnome-commander.gschema.xml:441
msgid "This option defines if sorting should be case sensitive."
msgstr ""
"Цей параметр визначає, чи має бути враховано регістр символів під час "
"упорядковування."

#: data/org.gnome.gnome-commander.gschema.xml:447
msgid "Select directories when all is marked"
msgstr "Позначати каталоги, якщо позначають все"

#: data/org.gnome.gnome-commander.gschema.xml:448
msgid ""
"This option defines if directories will be marked when all items in a file "
"panel should be marked."
msgstr ""
"Цей параметр визначає, чи слід позначати каталоги, коли ви позначаєте усі "
"записи на файловій панелі."

#: data/org.gnome.gnome-commander.gschema.xml:454
msgid "Allow multiple instances"
msgstr "Дозволити декілька екземплярів"

#: data/org.gnome.gnome-commander.gschema.xml:455
msgid "This option defines if multiple instances are allowed."
msgstr ""
"Цей параметр визначає, чи можна запускати одночасно декілька екземплярів "
"програми."

#: data/org.gnome.gnome-commander.gschema.xml:461
msgid "Only device icons"
msgstr "Лише піктограми пристроїв"

#: data/org.gnome.gnome-commander.gschema.xml:462
msgid ""
"This option defines if only device icons should be shown instead of icons "
"and text label."
msgstr ""
"Цей параметр визначає, чи слід показувати лише піктограми пристроїв замість "
"піктограм із мітками."

#: data/org.gnome.gnome-commander.gschema.xml:468
msgid "Show the samba workgroups icon"
msgstr "Показ піктограми робочих груп Samba"

#: data/org.gnome.gnome-commander.gschema.xml:469
msgid ""
"This option defines if the Samba workgroups icon should be shown in the "
"devices list."
msgstr ""
"Цей параметр визначає, чи має бути показано піктограму робочих груп Samba у "
"списку пристроїв."

#: data/org.gnome.gnome-commander.gschema.xml:475
msgid "Main menu visibility"
msgstr "Видимість головного меню"

#: data/org.gnome.gnome-commander.gschema.xml:476
msgid "This option defines if the main menu is visible or not."
msgstr "Цей параметр визначає, чи буде видимим головне меню програми."

#: data/org.gnome.gnome-commander.gschema.xml:482
msgid "Quick search shortcut"
msgstr "Скорочення швидкого пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:483
msgid "This option defines the shortcut for quick search."
msgstr "Цей параметр визначає клавіатурне скорочення для швидкого пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:489
msgid "Default Quick Search mode"
msgstr "Типовий режим швидкого пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:490
msgid "This option defines which mode Quick Search opens with."
msgstr ""
"Цей параметр визначає режим, у якому відкриватиметься панель швидкого пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:496
msgid "Case sensitive Quick Search"
msgstr "Швидкий пошук із врахуванням регістру символів"

#: data/org.gnome.gnome-commander.gschema.xml:497
msgid ""
"This option is used to remember the state of the \"Case Sensitive\" toggle "
"in Quick Search."
msgstr ""
"Цей параметр використовують для зберігання стану перемикача «З врахуванням "
"регістру» у полі швидкого пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:503
msgid "Legacy list of file tabs"
msgstr "Застарілий список файлових вкладок"

#: data/org.gnome.gnome-commander.gschema.xml:510
msgid "List of file tabs"
msgstr "Список файлових вкладок"

#: data/org.gnome.gnome-commander.gschema.xml:511
msgid ""
"The entries in this list are used for restoring the tabs and their history "
"from the last session."
msgstr ""
"Записи у цьому списку використовуються для відновлення вкладок і журналу "
"роботи з ними із попереднього сеансу роботи програми."

#: data/org.gnome.gnome-commander.gschema.xml:518
msgid "List of devices - deprecated"
msgstr "Список пристроїв — застарілий"

#: data/org.gnome.gnome-commander.gschema.xml:519
#: data/org.gnome.gnome-commander.gschema.xml:526
msgid "The entries in this list represent the devices configured by the user."
msgstr ""
"Записи у цьому списку визначають пристрої, які налаштовано користувачем."

#: data/org.gnome.gnome-commander.gschema.xml:525
msgid "List of devices"
msgstr "Список пристроїв"

#: data/org.gnome.gnome-commander.gschema.xml:532
msgid "List of favorite apps"
msgstr "Список улюблених програм"

#: data/org.gnome.gnome-commander.gschema.xml:533
msgid ""
"The entries in this list represent the favorite apps configured by the user."
msgstr ""
"Записи у цьому списку визначають улюблені програми, які налаштовано "
"користувачем."

#: data/org.gnome.gnome-commander.gschema.xml:539
msgid "Search window width"
msgstr "Ширина вікна пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:540
msgid "This option defines the width of the search window."
msgstr "Цей параметр визначає ширину вікна пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:546
msgid "Search window height"
msgstr "Висота вікна пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:547
msgid "This option defines the height of the search window."
msgstr "Цей параметр визначає висоту вікна пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:553
msgid "Search window is transient"
msgstr "Вікно пошуку є перехідним"

#: data/org.gnome.gnome-commander.gschema.xml:554
msgid ""
"Defines if the search window is transient or if it can be minimized and "
"moved behind the main window."
msgstr ""
"Визначає, є вікно пошуку перехідним чи може бути мінімізоване і пересунуте "
"за головне вікно програми."

#: data/org.gnome.gnome-commander.gschema.xml:560
msgid "Search text history"
msgstr "Журнал текстового пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:561
msgid ""
"This string array represents the history of text searches in the search tool."
msgstr ""
"Масив рядків, який відповідає журналу текстового пошуку у засобі пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:567
msgid "Search pattern history"
msgstr "Журнал взірців пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:568
msgid ""
"This string array represents the history of regular expression searches in "
"the search tool."
msgstr ""
"Масив рядків, який відповідає журналу пошуку за формальними виразами у "
"засобі пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:574
msgid "Legacy search tool profiles"
msgstr "Застарілі профілі засобу пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:581
msgid "List of search tool profiles"
msgstr "Список профілів засобу пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:582
msgid ""
"The entries in this array represent the profiles in the search tool with "
"specific settings for each profile."
msgstr ""
"Записи у цьому масиві визначають профілі у засобі пошуку. Кожен запис "
"зберігає специфічні параметри відповідного профілю."

#: data/org.gnome.gnome-commander.gschema.xml:590
msgid "Quick connect URI"
msgstr "Адреса швидкого з'єднання"

#: data/org.gnome.gnome-commander.gschema.xml:591
msgid "Unified resource identifier for quick connections."
msgstr "Уніфікований ідентифікатор ресурсу для швидких з'єднань."

#: data/org.gnome.gnome-commander.gschema.xml:602
msgid "Password for anonymous FTP connections"
msgstr "Пароль для анонімних з'єднань FTP"

#: data/org.gnome.gnome-commander.gschema.xml:603
msgid "This string defines the password for anonymous FTP connections."
msgstr "Цей рядок визначає пароль для анонімних з'єднань FTP."

#: data/org.gnome.gnome-commander.gschema.xml:611
msgid "Confirm delete"
msgstr "Підтвердження вилучення"

#: data/org.gnome.gnome-commander.gschema.xml:612
msgid "Defines if deletion of an item should be confirmed."
msgstr "Визначає, чи слід підтверджувати вилучення об'єктів."

#: data/org.gnome.gnome-commander.gschema.xml:618
msgid "Delete default"
msgstr "Типовий варіант вилучення"

#: data/org.gnome.gnome-commander.gschema.xml:619
msgid ""
"This setting defines the default active option in the delete confirmation "
"dialog."
msgstr ""
"Цей параметр визначає типовий активний варіант у діалоговому вікні вилучення."

#: data/org.gnome.gnome-commander.gschema.xml:625
msgid "Confirm copy overwrite"
msgstr "Підтвердження перезапису при копіюванні"

#: data/org.gnome.gnome-commander.gschema.xml:626
msgid ""
"This option defines the default behavior when items will be overwritten by a "
"copy command."
msgstr ""
"Цей параметр визначає типову поведінку при перезаписів об'єктів командою "
"копіювання."

#: data/org.gnome.gnome-commander.gschema.xml:632
msgid "Confirm move overwrite"
msgstr "Підтвердження перезапису при пересуванні"

#: data/org.gnome.gnome-commander.gschema.xml:633
msgid ""
"This option defines the default behavior when items will be overwritten by a "
"move command."
msgstr ""
"Цей параметр визначає типову поведінку при перезаписів об'єктів командою "
"пересування."

#: data/org.gnome.gnome-commander.gschema.xml:639
msgid "Confirm mouse drag and drop"
msgstr "Підтвердження перетягування зі скиданням за допомогою миші"

#: data/org.gnome.gnome-commander.gschema.xml:640
msgid "This option defines the behavior of mouse drag and drop operations."
msgstr ""
"Цей параметр визначає поведінку програми у відповідь на дії із перетягування "
"зі скиданням за допомогою вказівника миші."

#: data/org.gnome.gnome-commander.gschema.xml:648
msgid "Hide unknown filetypes"
msgstr "Приховати файли невідомих типів"

#: data/org.gnome.gnome-commander.gschema.xml:649
msgid "Hide files which type does not match to one of the other types."
msgstr "Приховати файли, чий тип не відповідає одному із інших типів."

#: data/org.gnome.gnome-commander.gschema.xml:653
msgid "Hide regular files"
msgstr "Приховати звичайні файли"

#: data/org.gnome.gnome-commander.gschema.xml:657
msgid "Hide directories"
msgstr "Приховати каталоги"

#: data/org.gnome.gnome-commander.gschema.xml:661
msgid "Hide symbolic links"
msgstr "Приховати символічні посилання"

#: data/org.gnome.gnome-commander.gschema.xml:665
msgid ""
"Hide special files, such as a socket, fifo, block devices, or character "
"devices."
msgstr ""
"Приховати особливі файли, зокрема сокети, канали, блокові пристрої та "
"символьні пристрої."

#: data/org.gnome.gnome-commander.gschema.xml:669
msgid "Hide files and folders starting with a dot"
msgstr "Приховати усі пункти файлів і тек, назви яких починаються з крапки"

#: data/org.gnome.gnome-commander.gschema.xml:673
msgid "Hide backup files"
msgstr "Приховувати файли резервних копій"

#: data/org.gnome.gnome-commander.gschema.xml:674
msgid "Hide all files with a suffix defined as the backup pattern."
msgstr ""
"Приховати усі файли, назви яких мають суфікс, визначений взірцем назв файлів "
"резервних копій."

#: data/org.gnome.gnome-commander.gschema.xml:678
msgid "Backup file pattern"
msgstr "Взірець назв файлів резервних копій"

#: data/org.gnome.gnome-commander.gschema.xml:679
msgid ""
"The given string defines suffixes (separated by semicolon) for files which "
"should be filtered out if backup files should be hidden."
msgstr ""
"Заданий рядок визначає суфікси (відокремлені крапкою з комою) для файлів, "
"які має бути відфільтровано, якщо наказати приховувати файли резервних копій."

#: data/org.gnome.gnome-commander.gschema.xml:688
msgid "Do not download files"
msgstr "Не отримувати файли"

#: data/org.gnome.gnome-commander.gschema.xml:689
msgid ""
"This option defines if remote files should be downloaded before opened by "
"external programs."
msgstr ""
"Цей параметр визначає, чи слід отримувати віддалені файли, перш ніж "
"відкривати їх за допомогою зовнішніх програм."

#: data/org.gnome.gnome-commander.gschema.xml:695
msgid "Use internal viewer"
msgstr "Використати вбудований переглядач"

#: data/org.gnome.gnome-commander.gschema.xml:696
msgid "This option defines if the internal viewer should be used by default."
msgstr ""
"Цей параметр визначає, чи слід типово використовувати вбудований засіб "
"перегляду."

#: data/org.gnome.gnome-commander.gschema.xml:702
msgid "Viewer command"
msgstr "Команда засобу перегляду"

#: data/org.gnome.gnome-commander.gschema.xml:703
msgid "This string defines the command for starting the (external) viewer."
msgstr ""
"Цей рядок визначає команду для запуску (зовнішнього) засобу перегляду."

#: data/org.gnome.gnome-commander.gschema.xml:709
msgid "Editor command"
msgstr "Команда редактора"

#: data/org.gnome.gnome-commander.gschema.xml:710
msgid "This string defines the command for starting the editor."
msgstr "Цей рядок визначає команду для запуску редактора."

#: data/org.gnome.gnome-commander.gschema.xml:716
msgid "Differ command"
msgstr "Команда засобу побудови різниці"

#: data/org.gnome.gnome-commander.gschema.xml:717
msgid "This string defines the command for starting the diff tool."
msgstr ""
"Цей рядок визначає команду для запуску засобу порівняння файлів і каталогів."

#: data/org.gnome.gnome-commander.gschema.xml:723
msgid "Use internal search"
msgstr "Використати вбудований засіб пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:724
msgid "This option defines if the internal search should be used by default."
msgstr ""
"Цей параметр визначає, чи слід типово використовувати вбудований засіб "
"пошуку."

#: data/org.gnome.gnome-commander.gschema.xml:730
msgid "Search command"
msgstr "Команда пошуку"

#: data/org.gnome.gnome-commander.gschema.xml:731
msgid ""
"This string defines the command for starting an external file search tool."
msgstr ""
"Цей рядок визначає команду для запуску зовнішнього засобу пошуку файлів."

#: data/org.gnome.gnome-commander.gschema.xml:737
msgid "Command for opening a terminal"
msgstr "Команда для відкриття термінала"

#: data/org.gnome.gnome-commander.gschema.xml:738
msgid "This string defines the command for opening a terminal."
msgstr "Цей рядок визначає команду для відкриття термінала."

#: data/org.gnome.gnome-commander.gschema.xml:744
msgid "Command for execution in terminal"
msgstr "Команда для виконання у терміналі"

#: data/org.gnome.gnome-commander.gschema.xml:745
msgid ""
"This string defines the command for executing another command in a terminal."
msgstr "Цей рядок визначає команду для виконання іншої команди у терміналі."

#: data/org.gnome.gnome-commander.gschema.xml:751
msgid "Send to command"
msgstr "Команда надсилання"

#: data/org.gnome.gnome-commander.gschema.xml:752
msgid "This string defines the command for sending files to a receiver."
msgstr "Це рядок визначає команду для надсилання файлів отримувачу."

#: data/org.gnome.gnome-commander.gschema.xml:760
msgid "Color theme"
msgstr "Тема кольорів"

#: data/org.gnome.gnome-commander.gschema.xml:761
msgid "This option defines the current color theme."
msgstr "Цей параметр визначає поточну тему кольорів."

#: data/org.gnome.gnome-commander.gschema.xml:767
msgid "Normal foreground color"
msgstr "Звичайний колір переднього плану"

#: data/org.gnome.gnome-commander.gschema.xml:768
msgid "Normal foreground color in custom mode."
msgstr "Звичайний колір переднього плану у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:774
msgid "Normal background color"
msgstr "Звичайний колір тла"

#: data/org.gnome.gnome-commander.gschema.xml:775
msgid "Normal background color in custom mode."
msgstr "Звичайний колір тла у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:781
msgid "Alternate foreground color"
msgstr "Альтернативний колір переднього плану"

#: data/org.gnome.gnome-commander.gschema.xml:782
msgid "Alternate foreground color in custom mode."
msgstr "Альтернативний колір переднього плану у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:788
msgid "Alternate background color"
msgstr "Альтернативний колір тла"

#: data/org.gnome.gnome-commander.gschema.xml:789
msgid "Alternate background color in custom mode."
msgstr "Альтернативний колір тла у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:795
msgid "Selection foreground color"
msgstr "Колір переднього плану позначеного"

#: data/org.gnome.gnome-commander.gschema.xml:796
msgid "Foreground color for selections in custom mode."
msgstr "Колір переднього плану для позначених пунктів у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:802
msgid "Selection background color"
msgstr "Колір тла позначеного"

#: data/org.gnome.gnome-commander.gschema.xml:803
msgid "Background color for selections in custom mode."
msgstr "Колір тла для позначених пунктів у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:809
msgid "Cursor foreground color"
msgstr "Колір переднього плану курсора"

#: data/org.gnome.gnome-commander.gschema.xml:810
msgid "Cursor foreground color in custom mode."
msgstr "Колір переднього плану курсора у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:816
msgid "Cursor background color"
msgstr "Колір тла курсора"

#: data/org.gnome.gnome-commander.gschema.xml:817
msgid "Cursor background color in custom mode."
msgstr "Колір тла курсора у нетиповому режимі."

#: data/org.gnome.gnome-commander.gschema.xml:823
msgid "Use LS colors"
msgstr "Використовувати кольори LS"

#: data/org.gnome.gnome-commander.gschema.xml:824
msgid ""
"This option triggers if the value of the environment variable LS_COLORS "
"should be used to dye files and folders."
msgstr ""
"Цей параметр перемикає використання змінної середовища LS_COLORS для "
"розфарбовування файлів і тек."

#: data/org.gnome.gnome-commander.gschema.xml:831
msgid "LS_COLORS black foreground mapping"
msgstr "Прив'язка чорного переднього плану у LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:832
msgid ""
"This option adjusts the foreground color mapping for LS_COLORS black value."
msgstr ""
"Цей параметр коригує прив'язку кольору переднього плану для значення чорного "
"з LS_COLORS."

#: data/org.gnome.gnome-commander.gschema.xml:838
msgid "LS_COLORS black background mapping"
msgstr "Прив'язка чорного тла у LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:839
msgid ""
"This option adjusts the background color mapping for LS_COLORS black value."
msgstr ""
"Цей параметр коригує прив'язку кольору тла для значення чорного з LS_COLORS."

#: data/org.gnome.gnome-commander.gschema.xml:845
msgid "LS_COLORS red foreground mapping"
msgstr "Прив'язка червоного переднього плану у LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:846
msgid ""
"This option adjusts the foreground color mapping for LS_COLORS red value."
msgstr ""
"Цей параметр коригує прив'язку кольору переднього плану для значення "
"червоного з LS_COLORS."

#: data/org.gnome.gnome-commander.gschema.xml:852
msgid "LS_COLORS red background mapping"
msgstr "Прив'язка червоного тла у LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:853
msgid ""
"This option adjusts the background color mapping for LS_COLORS red value."
msgstr ""
"Цей параметр коригує прив'язку кольору тла для значення червоного з "
"LS_COLORS."

#: data/org.gnome.gnome-commander.gschema.xml:859
msgid "LS_COLORS green foreground mapping"
msgstr "Прив'язка зеленого переднього плану у LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:860
msgid ""
"This option adjusts the foreground color mapping for LS_COLORS green value."
msgstr ""
"Цей параметр коригує прив'язку кольору переднього плану для значення "
