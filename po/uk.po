msgstr ""
"Стан вмісту, приклади: «чернетка», «рецензовано» та «остаточний варіант»"

#: plugins/document-metadata.py:113 src/tags/basic.rs:74
msgid "Keywords"
msgstr "Ключові слова"

#: plugins/document-metadata.py:113
