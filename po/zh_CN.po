msgstr "无效的链接。"

#: plugins/gsf/gsf-plugin.cc:93
msgid "Locale System Default"
msgstr "区域系统默认"

#: plugins/gsf/gsf-plugin.cc:93
msgid "Identifier representing the default system locale."
msgstr "代表默认系统区域的标识。"

#: plugins/gsf/gsf-plugin.cc:95
msgid "Manager"
msgstr "管理器"

#: plugins/gsf/gsf-plugin.cc:95
