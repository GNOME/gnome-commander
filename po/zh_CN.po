msgstr "文档上次打印的时间。"

#: plugins/gsf/gsf-plugin.cc:92
msgid "Last Saved By"
msgstr "上次保存者"

#: plugins/gsf/gsf-plugin.cc:92
msgid ""
"The entity that made the last change to the document, typically a person, "
"organization, or service."
msgstr "文档的最后修改者，一般是一个人、组织或者服务。"

#: plugins/gsf/gsf-plugin.cc:74
msgid "Line Count"
msgstr "行数"

#: plugins/gsf/gsf-plugin.cc:74
msgid "Number of lines in the document."
msgstr "文档的行数。"

#: plugins/gsf/gsf-plugin.cc:108
msgid "Links Dirty"
msgstr "无效链接"

#: plugins/gsf/gsf-plugin.cc:108
