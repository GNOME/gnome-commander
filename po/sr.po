msgstr "Датум и време када су било који метаподаци за овај ресурс последњи пут промењени"

#: plugins/document-metadata.py:148
#| msgid "Initial Creator"
msgid "Initial Generator"
msgstr "Почетни творац"

#: plugins/document-metadata.py:148
#| msgid "The template file that is been used to generate this document."
msgid "Name of the first known tool used to create the document"
msgstr "Назив првог познатог алата који је искоришћен за стварање документа"

#: plugins/document-metadata.py:149
msgid "PDF/A Part"
msgstr "PDF/A део"

#: plugins/document-metadata.py:149
