#: data/org.gnome.gnome-commander.desktop.in:2
#: data/org.gnome.gnome-commander.metainfo.xml.in:16 src/main_win.rs:265
msgid "Gnome Commander"
msgstr "Gnome Commander"

#: data/org.gnome.gnome-commander.desktop.in:3
msgid "A file manager using dual-panel layout"
msgstr "İki bölmeli düzeni kullanan dosya yönetici"

#. TRANSLATORS: Search terms to find this application. Do NOT translate or localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gnome-commander.desktop.in:5
msgid "file;manager;folder;explore;disk;filesystem;"
msgstr ""
"dosya;yönetici;dizin;tarayıcı;disk;dosya "
"sistemi;klasör;keşfet;bul;yokla;incele;ara;"

#: data/org.gnome.gnome-commander.gschema.xml:48
msgid "List of advanced rename tool profiles"
msgstr "Gelişmiş yeniden adlandırma aracı profilleri"

#: data/org.gnome.gnome-commander.gschema.xml:49
msgid ""
"The entries in this array represent the profiles in the advanced rename tool "
"with specific settings for each profile."
msgstr ""
"Bu dizideki girişler, gelişmiş yeniden adlandırma aracındaki profilleri, her "
"profil için özel ayarlarla gösterir."

#: data/org.gnome.gnome-commander.gschema.xml:55
msgid "Advanced rename tool window width"
msgstr "Gelişmiş yeniden adlandırma aracı pencere genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:56
msgid "This option defines the width of the advanced rename tool window."
msgstr ""
"Bu seçenek, gelişmiş yeniden adlandırma penceresi genişliğini temsil eder."

#: data/org.gnome.gnome-commander.gschema.xml:62
msgid "Advanced rename tool window height"
msgstr "Gelişmiş yeniden adlandırma aracı pencere yüksekliği"

#: data/org.gnome.gnome-commander.gschema.xml:63
msgid "This option defines the height of the advanced rename tool window."
msgstr ""
"Bu seçenek, gelişmiş yeniden adlandırma aracı penceresinin yüksekliğini "
"tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:69
msgid "Advanced rename tool template history"
msgstr "Gelişmiş yeniden adlandırma şablon geçmişi"

#: data/org.gnome.gnome-commander.gschema.xml:70
msgid ""
"This string array represents the history of templates in the advanced rename "
"tool."
msgstr ""
"Bu dizge dizisi, gelişmiş yeniden adlandırma şablonların geçmişini belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:76
msgid "History of visited directories"
msgstr "Ziyaret edilmiş dizinler geçmişi"

#: data/org.gnome.gnome-commander.gschema.xml:77
msgid "This string array represents the history of visited directories."
msgstr "Bu dizge dizisi, ziyaret edilen dizinlerin geçmişini belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:83
msgid "Panel font"
msgstr "Panel yazı tipi"

#: data/org.gnome.gnome-commander.gschema.xml:84
msgid ""
"A custom font that will be used for the file panels if the “Use default "
"font” option is turned off."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:90
msgid "Filesize display mode"
msgstr "Dosya boyutu gösterim kipi"

#: data/org.gnome.gnome-commander.gschema.xml:91
msgid ""
"Defines how the filesize will be displayed in the associated panel column."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:97
#: src/dialogs/options/format_tab.rs:86
msgid "Permission display mode"
msgstr "İzin görünüm kipi"

#: data/org.gnome.gnome-commander.gschema.xml:98
msgid ""
"Defines how the file permission will be displayed in the associated panel "
"column."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:104
msgid "Graphical layout mode"
msgstr "Grafik yerleşim kipi"

#: data/org.gnome.gnome-commander.gschema.xml:105
msgid "Defines the icon style of files and folders in the file panels."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:111
msgid "List row height"
msgstr "Liste satır yüksekliği"

#: data/org.gnome.gnome-commander.gschema.xml:112
msgid "Defines the height of a row in the file panel."
msgstr "Dosya panelindeki satırın yüksekliğini tanımlar."

#. Translators: Feel free to replace the default date format to a common value
#. used in your country. See https://docs.gtk.org/glib/method.DateTime.format.html for details.
#. Attention: Do not change the single quotes which sourround the string.
#. If nothing is set, the application uses the hard-coded value '%c', which is
#. "the preferred date and time representation for the current locale".
#: data/org.gnome.gnome-commander.gschema.xml:122
msgid "'%F %R'"
msgstr "'%F %R'"

#: data/org.gnome.gnome-commander.gschema.xml:123
#: src/dialogs/options/format_tab.rs:94
msgid "Date format"
msgstr "Tarih biçimi"

#: data/org.gnome.gnome-commander.gschema.xml:124
msgid "Format of the date in the file panel."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:130
msgid "List font"
msgstr "Liste yazı tipi"

#: data/org.gnome.gnome-commander.gschema.xml:131
msgid "The font in the file panels."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:135
msgid "Extension display mode"
msgstr "Uzantı gösterim kipi"

#: data/org.gnome.gnome-commander.gschema.xml:136
msgid "Defines where the file name extension is displayed."
msgstr "Dosya adı uzantısının nerede görüntüleneceğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:142
msgid "Left mouse button mode"
msgstr "Sol fare düğmesi kipi"

#: data/org.gnome.gnome-commander.gschema.xml:143
msgid "Number of left mouse button clicks for opening a file or folder."
msgstr "Dosya veya dizinin açılması için gereken sol tıklama sayısı."

#: data/org.gnome.gnome-commander.gschema.xml:149
msgid "Left mouse button unselects"
msgstr "Sol fare düğmesi seçilmedi"

#: data/org.gnome.gnome-commander.gschema.xml:150
msgid ""
"Defines if a click on an unselected item unselects already selected items."
msgstr ""
"Bu değer, seçilmemiş bir nesneye yapılan tıklamanın önceden seçilmiş "
"nesnelerin seçimini kaldırma durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:156
msgid "Right mouse button mode"
msgstr "Sağ fare düğmesi kipi"

#: data/org.gnome.gnome-commander.gschema.xml:157
msgid "Defines what happens when the right mouse button is clicked on an item."
msgstr "Nesneye sağ fare tuşuyla tıklandığında ne olacağını tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:163
msgid "Use trash"
msgstr "Çöp kutusu kullan"

#: data/org.gnome.gnome-commander.gschema.xml:164
msgid ""
"Defines if items should be moved to trash by default instead of really "
"deleting them."
msgstr ""
"Ögelerin gerçekten silmek yerine öntanımlı olarak çöp kutusuna taşınması "
"durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:170
msgid "Icon size"
msgstr "Simge boyutu"

#: data/org.gnome.gnome-commander.gschema.xml:171
msgid "Size of icons in the file panel."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:175
msgid "Icon scale quality"
msgstr "Simge ölçekleme kalitesi"

#: data/org.gnome.gnome-commander.gschema.xml:176
msgid ""
"Describes the different interpolation modes that can be used with the "
"scaling functions."
msgstr ""
"Ölçeklendirme işlevleriyle kullanılabilecek farklı ara değerleme kiplerini "
"açıklar."

#: data/org.gnome.gnome-commander.gschema.xml:180
msgid "MIME icon directory"
msgstr "MIME simge dizini"

#: data/org.gnome.gnome-commander.gschema.xml:181
msgid "Directory in which MIME icons are located."
msgstr "MIME simgelerinin bulunduğu dizin."

#: data/org.gnome.gnome-commander.gschema.xml:185
msgid "Command line history"
msgstr "Komut satırı geçmişi"

#: data/org.gnome.gnome-commander.gschema.xml:186
msgid ""
"This string array represents the history of commands executed in the command "
"line."
msgstr ""
"Bu dizge dizisi, komut satırında çalıştırılmış komutların geçmişini belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:193
msgid "Command line history length"
msgstr "Komut satırı geçmişinin uzunluğu"

#: data/org.gnome.gnome-commander.gschema.xml:197
msgid "Split between panels and command line"
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:198
msgid ""
"Determines the height of file panels in pixels. Remaining vertical space is "
"allocated for the command line."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:204
msgid "Automatically hide command line output"
msgstr "Komut satırı çıktısını kendiliğinden gizle"

#: data/org.gnome.gnome-commander.gschema.xml:205
msgid ""
"If enabled, command line output is hidden automatically when the command "
"line is inactive."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:211
msgid "Horizontal orientation"
msgstr "Yatay yönelim"

#: data/org.gnome.gnome-commander.gschema.xml:212
msgid ""
"Defines if the orientation of the file panels should be horizontal or not."
msgstr ""
"Dosya panellerinin yöneliminin yatay olup olmaması gerektiğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:219
msgid "GUI update rate"
msgstr "Arayüz güncelleme hızı"

#: data/org.gnome.gnome-commander.gschema.xml:220
msgid "Update rate of the graphical user interface in 1/1000ths of a second."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:224
msgid "Show device buttons"
msgstr "Aygıt düğmelerini göster"

#: data/org.gnome.gnome-commander.gschema.xml:225
msgid "Defines if device buttons are shown."
msgstr "Aygıt düğmelerinin gösterim durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:229
msgid "Show device list"
msgstr "Aygıt listesini göster"

#: data/org.gnome.gnome-commander.gschema.xml:230
msgid "Defines if the list of devices is shown."
msgstr "Aygıt listesinin gösterim durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:234
msgid "Show command line"
msgstr "Komut satırını göster"

#: data/org.gnome.gnome-commander.gschema.xml:235
msgid "Defines if command line is shown."
msgstr "Komut satırının gösterim durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:239
msgid "Show toolbar"
msgstr "Araç çubuğunu göster"

#: data/org.gnome.gnome-commander.gschema.xml:240
msgid "Defines if the toolbar is shown."
msgstr "Araç çubuğunun gösterim durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:244
msgid "Show buttonbar"
msgstr "Düğme çubuğunu göster"

#: data/org.gnome.gnome-commander.gschema.xml:245
msgid "Defines if the buttonbar is shown."
msgstr "Düğme çubuğunun gösterim durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:249
msgid "Symlink string"
msgstr "Sembolik bağlantı dizgesi"

#: data/org.gnome.gnome-commander.gschema.xml:250
msgid ""
"This string defines the default name of a newly created symlink. Leave the "
"string empty to use the default value which is hard coded into the program "
"code. A “%s” will be expanded to the item name for which a link should be "
"created."
msgstr ""
"Bu dizge, yeni oluşturulan sembolik bağlantının öntanımlı adını tanımlar. "
"Yazılım koduna sabit kodlanmış öntanımlı değeri kullanmak için dizgeyi boş "
"bırakın. Bağlantı oluşturulması gereken nesne adına bir “%s” "
"genişletilecektir."

#: data/org.gnome.gnome-commander.gschema.xml:258
msgid "Main window width"
msgstr "Ana pencere genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:259
msgid "This option defines the width of the main window."
msgstr "Bu seçenek, ana pencere genişliğin tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:265
msgid "List of bookmarks"
msgstr "Yer imleri listesi"

#: data/org.gnome.gnome-commander.gschema.xml:266
msgid "Each entry in this list represents a bookmark."
msgstr "Bu listedeki her girdi bir yer imini belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:272
msgid "Bookmarks window width"
msgstr "Yer imleri pencere genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:273
msgid "This option defines the width of the bookmarks window."
msgstr "Bu seçenek, yer imi sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:279
msgid "Bookmarks window height"
msgstr "Yer imleri pencere yüksekliği"

#: data/org.gnome.gnome-commander.gschema.xml:280
msgid "This option defines the height of the bookmarks window."
msgstr "Bu seçenek, yerimleri penceresi yüksekliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:286
msgid "List of connections"
msgstr "Bağlantı listesi"

#: data/org.gnome.gnome-commander.gschema.xml:287
msgid "Each entry in this list represents a connection."
msgstr "Bu listedeki her girdi bir bağlantıyı belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:293
msgid "Main window height"
msgstr "Ana pencere yüksekliği"

#: data/org.gnome.gnome-commander.gschema.xml:294
msgid "This option defines the height of the main window."
msgstr "Bu seçenek, ana pencere yüksekliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:300
msgid "Options dialog width"
msgstr "Seçenekler iletişim kutusu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:301
msgid "This setting defines the width of the options dialog window."
msgstr "Bu ayar, seçenekler iletişim penceresi genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:307
msgid "Options dialog height"
msgstr "Seçenekler iletişim kutusu yüksekliği"

#: data/org.gnome.gnome-commander.gschema.xml:308
msgid "This setting defines the height of the options dialog window."
msgstr "Bu ayar, seçenekler iletişim penceresi yüksekliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:314
msgid "Width of icon column"
msgstr "Simge sütunu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:315
msgid "This option defines the width of the icon column."
msgstr "Bu seçenek, simge sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:321
msgid "Width of name column"
msgstr "Ad sütunu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:322
msgid "This option defines the width of the name column."
msgstr "Bu seçenek, ad sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:328
msgid "Width of extension column"
msgstr "Uzantı sütunu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:329
msgid "This option defines the width of the extension column."
msgstr "Bu seçenek, uzantı sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:335
msgid "Width of directory column"
msgstr "Dizin sutunu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:336
msgid "This option defines the width of the directory column."
msgstr "Bu seçenek, dizin sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:342
msgid "Width of size column"
msgstr "Boyut sütunu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:343
msgid "This option defines the width of the size column."
msgstr "Bu seçenek, boyut sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:349
msgid "Width of date column"
msgstr "Tarih sütunu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:350
msgid "This option defines the width of the date column."
msgstr "Bu seçenek, tarih sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:356
msgid "Width of permissions column"
msgstr "İzinler sütunu genişliğ"

#: data/org.gnome.gnome-commander.gschema.xml:357
msgid "This option defines the width of the permissions column."
msgstr "Bu seçenek, izinler sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:363
msgid "Width of owner column"
msgstr "Sahip sütunu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:364
msgid "This option defines the width of the owner column."
msgstr "Bu seçenek, sahip sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:370
msgid "Width of group column"
msgstr "Grup sutünu genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:371
msgid "This option defines the width of the group column."
msgstr "Bu seçenek, grup sütunu genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:377
msgid "Legacy list of keybindings"
msgstr "Eski anahtarbağlama listesi"

#: data/org.gnome.gnome-commander.gschema.xml:378
#: data/org.gnome.gnome-commander.gschema.xml:527
#: data/org.gnome.gnome-commander.gschema.xml:598
msgid ""
"This setting is only present for backwards compatibility and will be removed "
"in future."
msgstr ""
"Bu seçenek yalnızca geriye uyumluluk içindir ve gelecekte kaldırılacaktır."

#: data/org.gnome.gnome-commander.gschema.xml:384
msgid "List of keybindings"
msgstr "Anahtarbağlama listesi"

#: data/org.gnome.gnome-commander.gschema.xml:385
msgid "Each entry in this list represents a keybinding."
msgstr "Listedeki her giriş bir anahtarbağlamayı belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:392
msgid "Main window state"
msgstr "Ana pencere durumu"

#: data/org.gnome.gnome-commander.gschema.xml:393
msgid ""
"The number represents the main window state, e.g. “maximized”, “fullscreen”, "
"etc. and is calculated internally."
msgstr ""
"Bu sayı, ana pencere durumunu, örn. “maximized”, “fullscreen”, vb. belirtir "
"ve içsel olarak hesaplanır."

#: data/org.gnome.gnome-commander.gschema.xml:399
msgid "Middle mouse button mode"
msgstr "Orta fare düğmesi kipi"

#: data/org.gnome.gnome-commander.gschema.xml:400
msgid "Defines what happens when the middle mouse button is clicked."
msgstr "Orta fare tuşu tıklandığında ne olacağını tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:406
msgid "Save directories on exit"
msgstr "Çıkışta dizinleri kaydet"

#: data/org.gnome.gnome-commander.gschema.xml:407
msgid ""
"Defines if the current directories are opened again when Gnome Commander is "
"restarted."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:413
msgid "Save tabs on exit"
msgstr "Çıkışta sekmeleri kaydet"

#: data/org.gnome.gnome-commander.gschema.xml:414
msgid ""
"Defines if the current open tabs are opened again when Gnome Commander is "
"restarted."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:420
msgid "Save directory history on exit"
msgstr "Çıkışta dizin geçmişini kaydet"

#: data/org.gnome.gnome-commander.gschema.xml:421
msgid "Defines if the history of visited directories is saved on exit."
msgstr ""
"Bu değer, ziyaret edilen dizinler geçmişinin çıkışta kayıt durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:427
msgid "Save commandline history on exit"
msgstr "Çıkışta komut satırı geçmişini kaydet"

#: data/org.gnome.gnome-commander.gschema.xml:428
msgid "Defines if the history of commands in the commandline is saved on exit."
msgstr ""
"Bu değer, komut satırı komut geçmişinin çıkışta kayıt durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:434
msgid "Save search history on exit"
msgstr "Çıkışta arama geçmişini kaydet"

#: data/org.gnome.gnome-commander.gschema.xml:435
msgid "Defines if the history of search patterns is saved on exit."
msgstr "Bu değer, arama örüntüleri geçmişinin çıkışta kayıt durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:441
msgid "Always show tab bar"
msgstr "Sekme çubuğunu her zaman göster"

#: data/org.gnome.gnome-commander.gschema.xml:442
msgid "Defines if the tab bar is always shown."
msgstr "Bu değer, sekme çubuğunun her zaman gösterim durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:448
#: src/dialogs/options/tabs_tab.rs:62
msgid "Tab lock indicator"
msgstr "Sekme kilitleme göstegesi"

#: data/org.gnome.gnome-commander.gschema.xml:449
msgid "Defines the style of the tab lock indicator."
msgstr "Sekme kilit göstergesi biçimini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:455
msgid "Case sensitive sorting"
msgstr "Büyük/küçük harf duyarlı sıralama"

#: data/org.gnome.gnome-commander.gschema.xml:456
msgid "This option defines if sorting should be case sensitive."
msgstr ""
"Bu seçenek, sıralamanın büyük küçük harf duyarlılık davranışını tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:462
#: src/dialogs/options/general_tab.rs:154
msgid "Treat symbolic links as regular files"
msgstr "Sembolik bağlantılara normal dosyalar gibi davran"

#: data/org.gnome.gnome-commander.gschema.xml:463
msgid ""
"This option defines if symbolic links should be treated as regular files. In "
"the file panel they are listed between other files and not at the top if "
"their target is not existing."
msgstr ""

#: data/org.gnome.gnome-commander.gschema.xml:470
msgid "Select directories when all is marked"
msgstr "Tümü işaretlendiğinde dizinleri seç"

#: data/org.gnome.gnome-commander.gschema.xml:471
#, fuzzy
#| msgid "This option defines if too long text lines should be wrapped."
msgid ""
"This option defines if directories will be marked when all items in a file "
"panel should be marked."
msgstr ""
"Bu seçenek, çok uzun metin satırlarının sarmalanma davranışını tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:477
msgid "Allow multiple instances"
msgstr "Çoklu örneklere izin ver"

#: data/org.gnome.gnome-commander.gschema.xml:478
msgid "This option defines if multiple instances are allowed."
msgstr "Bu seçenek, çoklu örneklere izin verilme durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:484
msgid "Only device icons"
msgstr "Yalnızca aygıt simgeleri"

#: data/org.gnome.gnome-commander.gschema.xml:485
msgid ""
"This option defines if only device icons should be shown instead of icons "
"and text label."
msgstr ""
"Bu seçenek, simge ve metin etiketi yerine yalnızca aygıt simgesinin gösterim "
"durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:491
msgid "Show the samba workgroups icon"
msgstr "Samba çalışma kümeleri simgesini göster"

#: data/org.gnome.gnome-commander.gschema.xml:492
msgid ""
"This option defines if the Samba workgroups icon should be shown in the "
"devices list."
msgstr ""
"Bu seçenek, aygıtlar listesinde Samba çalışma kümeleri simgesinin gösterilme "
"durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:498
msgid "Main menu visibility"
msgstr "Ana menü görünürlüğü"

#: data/org.gnome.gnome-commander.gschema.xml:499
msgid "This option defines if the main menu is visible or not."
msgstr "Bu seçenek, ana menünün görünürlük davranışını tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:505
msgid "Quick search shortcut"
msgstr "Hızlı arama kısayolu"

#: data/org.gnome.gnome-commander.gschema.xml:506
msgid "This option defines the shortcut for quick search."
msgstr "Bu seçenek, hızlı arama için kısayol tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:512
msgid "Default Quick Search mode"
msgstr "Öntanımlı Hızlı Arama kipi"

#: data/org.gnome.gnome-commander.gschema.xml:513
msgid "This option defines which mode Quick Search opens with."
msgstr "Bu seçenek, Hızlı Arama’nın açılacağı kipi tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:519
msgid "Case sensitive Quick Search"
msgstr "Büyük/küçük harf duyarlı Hızlı Arama"

#: data/org.gnome.gnome-commander.gschema.xml:520
msgid ""
"This option is used to remember the state of the \"Case Sensitive\" toggle "
"in Quick Search."
msgstr ""
"Bu seçenek, Hızlı Arama’daki \"Büyük/Küçük Harf Duyarlı\" ayarının durumunu "
"anımsamada kullanılır."

#: data/org.gnome.gnome-commander.gschema.xml:526
msgid "Legacy list of file tabs"
msgstr "Dosya sekmeleri eski listesi"

#: data/org.gnome.gnome-commander.gschema.xml:533
msgid "List of file tabs"
msgstr "Dosya sekmeleri listesi"

#: data/org.gnome.gnome-commander.gschema.xml:534
#, fuzzy
#| msgid ""
#| "The entries in this list represent the favorite apps configured by the "
#| "user."
msgid ""
"The entries in this list are used for restoring the tabs and their history "
"from the last session."
msgstr ""
"Bu listedeki girdiler sekmeleri ve son oturumdaki geçmişlerini geri yüklemede "
"kullanılır."

#: data/org.gnome.gnome-commander.gschema.xml:541
msgid "List of devices - deprecated"
msgstr "Aygıt listesi - kullanımdan kaldırıldı"

#: data/org.gnome.gnome-commander.gschema.xml:542
#: data/org.gnome.gnome-commander.gschema.xml:549
msgid "The entries in this list represent the devices configured by the user."
msgstr "Bu listedeki girdiler kullanıcıca yapılandırılan aygıtları belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:548
msgid "List of devices"
msgstr "Aygıt listesi"

#: data/org.gnome.gnome-commander.gschema.xml:555
msgid "List of favorite apps"
msgstr "Gözde uygulamalar listesi"

#: data/org.gnome.gnome-commander.gschema.xml:556
msgid ""
"The entries in this list represent the favorite apps configured by the user."
msgstr ""
"Bu listedeki girdiler kullanıcıca yapılandırılan gözde uygulamaları belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:562
msgid "Search window width"
msgstr "Arama penceresi genişliği"

#: data/org.gnome.gnome-commander.gschema.xml:563
msgid "This option defines the width of the search window."
msgstr "Bu seçenek, arama penceresi genişliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:569
msgid "Search window height"
msgstr "Arama penceresi yüksekliği"

#: data/org.gnome.gnome-commander.gschema.xml:570
msgid "This option defines the height of the search window."
msgstr "Bu seçenek, arama penceresi yüksekliğini tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:576
msgid "Search window is transient"
msgstr "Arama penceresi geçici"

#: data/org.gnome.gnome-commander.gschema.xml:577
msgid ""
"Defines if the search window is transient or if it can be minimized and "
"moved behind the main window."
msgstr ""
"Bu değer, arama penceresinin geçici olma durumunu veya simge durumuna "
"küçültülme ve ana pencerenin arkasına taşınabilme durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:583
msgid "Search text history"
msgstr "Arama metni geçmişi"

#: data/org.gnome.gnome-commander.gschema.xml:584
msgid ""
"This string array represents the history of text searches in the search tool."
msgstr "Bu dizge dizisi, arama aracında aranmış metinlerin geçmişini belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:590
msgid "Search pattern history"
msgstr "Arama örüntüsü geçmişi"

#: data/org.gnome.gnome-commander.gschema.xml:591
msgid ""
"This string array represents the history of regular expression searches in "
"the search tool."
msgstr ""
"Bu dizge dizisi, arama aracında aranmış düzenli ifadelerin geçmişini "
"belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:597
msgid "Legacy search tool profiles"
msgstr "Eski arama aracı profilleri"

#: data/org.gnome.gnome-commander.gschema.xml:604
msgid "List of search tool profiles"
msgstr "Arama araç profillerinin listesi"

#: data/org.gnome.gnome-commander.gschema.xml:605
msgid ""
"The entries in this array represent the profiles in the search tool with "
"specific settings for each profile."
msgstr ""
"Bu dizideki girdiler, arama aracındaki profilleri, her profil için özel "
"ayarlarla belirtir."

#: data/org.gnome.gnome-commander.gschema.xml:613
msgid "Quick connect URI"
msgstr "Hızlı bağlan adresi"

#: data/org.gnome.gnome-commander.gschema.xml:614
msgid "Unified resource identifier for quick connections."
msgstr "Hızlı bağlantılar için birleşik kaynak tanımlayıcı."

#: data/org.gnome.gnome-commander.gschema.xml:625
msgid "Password for anonymous FTP connections"
msgstr "Anonim FTP bağlantıları için parola"

#: data/org.gnome.gnome-commander.gschema.xml:626
msgid "This string defines the password for anonymous FTP connections."
msgstr "Bu dizge, anonim FTP bağlantıları için parolaları tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:634
msgid "Confirm delete"
msgstr "Silmeden önce onayla"

#: data/org.gnome.gnome-commander.gschema.xml:635
msgid "Defines if deletion of an item should be confirmed."
msgstr "Bu değer, silme işlemi için onaylan durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:641
msgid "Delete default"
msgstr "Öntanımlı sil"

#: data/org.gnome.gnome-commander.gschema.xml:642
msgid ""
"This setting defines the default active option in the delete confirmation "
"dialog."
msgstr ""
"Bu ayar, silme doğrulama iletişim penceresinde öntanımlı etkin seçeneği "
"tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:648
msgid "Confirm copy overwrite"
msgstr "Kopyala üzerine yazmayı doğrula"

#: data/org.gnome.gnome-commander.gschema.xml:649
msgid ""
"This option defines the default behavior when items will be overwritten by a "
"copy command."
msgstr ""
"Bu seçenek, nesnelerin bir kopyalama komutunca üzerine yazılacağı öntanımlı "
"davranışı tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:655
msgid "Confirm move overwrite"
msgstr "Taşı üzerine yazmayı doğrula"

#: data/org.gnome.gnome-commander.gschema.xml:656
msgid ""
"This option defines the default behavior when items will be overwritten by a "
"move command."
msgstr ""
"Bu seçenek, nesnelerin bir taşıma komutunca üzerine yazılacağı öntanımlı "
"davranışı tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:662
msgid "Confirm mouse drag and drop"
msgstr "Fare sürükle bırak işlemlerini onayla"

#: data/org.gnome.gnome-commander.gschema.xml:663
msgid "This option defines the behavior of mouse drag and drop operations."
msgstr "Bu seçenek, fare sürükle bırak işlemlerinin davranışını tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:671
msgid "Hide unknown filetypes"
msgstr "Bilinmeyen dosya türlerini gizle"

#: data/org.gnome.gnome-commander.gschema.xml:672
msgid "Hide files which type does not match to one of the other types."
msgstr "Diğer türlerden biriyle uyuşmayan dosyaları gizle."

#: data/org.gnome.gnome-commander.gschema.xml:676
msgid "Hide regular files"
msgstr "Normal dosyaları gizle"

#: data/org.gnome.gnome-commander.gschema.xml:680
msgid "Hide directories"
msgstr "Dizinleri gizle"

#: data/org.gnome.gnome-commander.gschema.xml:684
msgid "Hide symbolic links"
msgstr "Sembolik bağlantıları gizle"

#: data/org.gnome.gnome-commander.gschema.xml:688
msgid ""
"Hide special files, such as a socket, fifo, block devices, or character "
"devices."
msgstr ""
"Yuva, fifo, blok aygıt veya karakter aygıtları gibi özel dosyaları gizle."

#: data/org.gnome.gnome-commander.gschema.xml:692
msgid "Hide shortcut files (Windows systems)"
msgstr "Kısayol dosyalarını gizle (Windows sistemleri)"

#: data/org.gnome.gnome-commander.gschema.xml:696
msgid "Hide mountable locations"
msgstr "Bağlanabilir konumları gizle"

#: data/org.gnome.gnome-commander.gschema.xml:700
msgid "Hide virtual files"
msgstr "Sanal dosyaları gizle"

#: data/org.gnome.gnome-commander.gschema.xml:704
msgid "Hide volatile files"
msgstr "Uçucu dosyaları gizle"

#: data/org.gnome.gnome-commander.gschema.xml:708
msgid "Hide files and folders starting with a dot"
msgstr "Gizli dosyaları gizle"

#: data/org.gnome.gnome-commander.gschema.xml:712
msgid "Hide backup files"
msgstr "Yedek dosyalarını gizle"

#: data/org.gnome.gnome-commander.gschema.xml:713
msgid "Hide all files with a suffix defined as the backup pattern."
msgstr "Yedek örüntüsüyle tanımlanmış uzantılara sahip tüm dosyaları gizle."

#: data/org.gnome.gnome-commander.gschema.xml:717
msgid "Backup file pattern"
msgstr "Yedek dosya örüntüsü"

#: data/org.gnome.gnome-commander.gschema.xml:718
msgid ""
"The given string defines suffixes (separated by semicolon) for files which "
"should be filtered out if backup files should be hidden."
msgstr ""
"Verilen dizge, yedekleme dosyalarının gizlenmesi durumunda filtrelenmesi "
"gereken dosyaların uzantılarını (noktalı virgülle ayrılmış olarak) tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:727
msgid "Do not download files"
msgstr "Dosyaları indirme"

#: data/org.gnome.gnome-commander.gschema.xml:728
msgid ""
"This option defines if remote files should be downloaded before opened by "
"external programs."
msgstr ""
"Bu seçenek, uzak dosyaların dış programlarca açılmadan önce indirilmesi "
"durumunu tanımlar."

#: data/org.gnome.gnome-commander.gschema.xml:734
msgid "Use internal viewer"
msgstr "İç görüntüleyiciyi kullan"

#: data/org.gnome.gnome-commander.gschema.xml:735
msgid "This option defines if the internal viewer should be used by default."
msgstr ""
"Bu seçenek, iç görüntüleyicinin öntanımlı kullanım davranışını tanımlar."

