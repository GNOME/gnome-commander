msgstr "Filformat for dataene, der beskrives af denne metadata."

#: plugins/exiv2/exiv2-plugin.cc:242
msgid "File Version"
msgstr "Filversion"

#: plugins/exiv2/exiv2-plugin.cc:242
msgid "Version of the file format."
msgstr "Version af filformatet."

# ???
#: plugins/exiv2/exiv2-plugin.cc:243
