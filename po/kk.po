#: data/org.gnome.gnome-commander.desktop.in:2
#: data/org.gnome.gnome-commander.metainfo.xml.in:7 src/main_win.rs:284
msgid "GNOME Commander"
msgstr "GNOME Commander"

#: data/org.gnome.gnome-commander.desktop.in:3
msgid "A file manager using dual-panel layout"
msgstr "Екі панельді жайманы қолданатын файл менеджері"

#. TRANSLATORS: Search terms to find this application. Do NOT translate or
#. localize the semicolons! The list MUST also end with a semicolon!
#: data/org.gnome.gnome-commander.desktop.in:5
msgid "file;manager;folder;explore;disk;filesystem;"
msgstr "файл;менеджер;бума;шолу;диск;файлдық жүйе;"

#: data/org.gnome.gnome-commander.gschema.xml:36
msgid "List of advanced rename tool profiles"
msgstr "Атын өзгертудің кеңейтілген сайман профильдерінің тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:37
msgid ""
"The entries in this array represent the profiles in the advanced rename "
"tool with specific settings for each profile."
msgstr ""
"Осы массивтегі жазбалар атын өзгертудің кеңейтілген сайманындағы әрбір "
"профиль үшін арнайы баптаулары бар профильдерді білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:43
msgid "Advanced rename tool window width"
msgstr "Атын өзгертудің кеңейтілген сайман терезесінің ені"

#: data/org.gnome.gnome-commander.gschema.xml:44
msgid "This option defines the width of the advanced rename tool window."
msgstr ""
"Бұл опция атын өзгертудің кеңейтілген сайман терезесінің енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:50
msgid "Advanced rename tool window height"
msgstr "Атын өзгертудің кеңейтілген сайман терезесінің биіктігі"

#: data/org.gnome.gnome-commander.gschema.xml:51
msgid "This option defines the height of the advanced rename tool window."
msgstr ""
"Бұл опция атын өзгертудің кеңейтілген сайман терезесінің биіктігін "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:57
msgid "Advanced rename tool template history"
msgstr "Атын өзгертудің кеңейтілген сайман шаблондарының тарихы"

#: data/org.gnome.gnome-commander.gschema.xml:58
msgid ""
"This string array represents the history of templates in the advanced "
"rename tool."
msgstr ""
"Бұл жолдық массив атын өзгертудің кеңейтілген сайманындағы шаблондар "
"тарихын білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:64
msgid "History of visited directories"
msgstr "Қаралған бумалар тарихы"

#: data/org.gnome.gnome-commander.gschema.xml:65
msgid "This string array represents the history of visited directories."
msgstr "Бұл жолдық массив қаралған бумалар тарихын білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:71
msgid "Panel font"
msgstr "Панель қаріпі"

#: data/org.gnome.gnome-commander.gschema.xml:72
msgid ""
"A custom font that will be used for the file panels if the “Use default "
"font” option is turned off."
msgstr ""
"Егер «Бастапқы қаріпті қолдану» опциясы сөндірілсе, файл панельдері үшін "
"қолданылатын таңдаулы қаріп."

#: data/org.gnome.gnome-commander.gschema.xml:78
msgid "Filesize display mode"
msgstr "Файл өлшемін көрсету режимі"

#: data/org.gnome.gnome-commander.gschema.xml:79
msgid ""
"Defines how the filesize will be displayed in the associated panel column."
msgstr ""
"Сәйкес панель бағанында файл өлшемінің қалай көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:85
#: src/dialogs/options/format_tab.rs:100
msgid "Permission display mode"
msgstr "Рұқсаттарды көрсету режимі"

#: data/org.gnome.gnome-commander.gschema.xml:86
msgid ""
"Defines how the file permission will be displayed in the associated panel "
"column."
msgstr ""
"Сәйкес панель бағанында файл рұқсаттарының қалай көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:92
msgid "Graphical layout mode"
msgstr "Графикалық жайма режимі"

#: data/org.gnome.gnome-commander.gschema.xml:93
msgid "Defines the icon style of files and folders in the file panels."
msgstr "Файл панельдеріндегі файлдар мен бумалардың таңбаша стилін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:99
msgid "List row height"
msgstr "Тізім жолының биіктігі"

#: data/org.gnome.gnome-commander.gschema.xml:100
msgid "Defines the height of a row in the file panel."
msgstr "Файл панеліндегі жолдың биіктігін анықтайды."

#. Translators: Feel free to replace the default date format to a common value
#. used in your country. See
#. https://docs.gtk.org/glib/method.DateTime.format.html for details.
#. Attention: Do not change the single quotes which sourround the string.
#. If nothing is set, the application uses the hard-coded value '%c', which is
#. "the preferred date and time representation for the current locale".
#: data/org.gnome.gnome-commander.gschema.xml:110
msgid "'%F %R'"
msgstr "'%F %R'"

#: data/org.gnome.gnome-commander.gschema.xml:111
#: src/dialogs/options/format_tab.rs:108
msgid "Date format"
msgstr "Күн пішімі"

#: data/org.gnome.gnome-commander.gschema.xml:112
msgid "Format of the date in the file panel."
msgstr "Файл панеліндегі күн пішімі."

#: data/org.gnome.gnome-commander.gschema.xml:118
msgid "List font"
msgstr "Тізім қаріпі"

#: data/org.gnome.gnome-commander.gschema.xml:119
msgid "The font in the file panels."
msgstr "Файл панельдеріндегі қаріп."

#: data/org.gnome.gnome-commander.gschema.xml:123
msgid "Extension display mode"
msgstr "Кеңейтуді көрсету режимі"

#: data/org.gnome.gnome-commander.gschema.xml:124
msgid "Defines where the file name extension is displayed."
msgstr "Файл атының кеңейтуі қай жерде көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:130
msgid "Left mouse button mode"
msgstr "Сол жақ тышқан батырмасының режимі"

#: data/org.gnome.gnome-commander.gschema.xml:131
msgid "Number of left mouse button clicks for opening a file or folder."
msgstr ""
"Файлды немесе буманы ашуға арналған сол жақ тышқан батырмасы шертулерінің "
"саны."

#: data/org.gnome.gnome-commander.gschema.xml:137
msgid "Left mouse button unselects"
msgstr "Сол жақ тышқан батырмасы таңдауды алып тастайды"

#: data/org.gnome.gnome-commander.gschema.xml:138
msgid ""
"Defines if a click on an unselected item unselects already selected items."
msgstr ""
"Таңдалмаған элементті шерту бұрын таңдалған элементтердің таңдауын алып "
"тастайтынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:144
msgid "Right mouse button mode"
msgstr "Оң жақ тышқан батырмасының режимі"

#: data/org.gnome.gnome-commander.gschema.xml:145
msgid ""
"Defines what happens when the right mouse button is clicked on an item."
msgstr "Элементте оң жақ тышқан батырмасы шертілгенде не болатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:151
msgid "Use trash"
msgstr "Қоқыс шелегін қолдану"

#: data/org.gnome.gnome-commander.gschema.xml:152
msgid ""
"Defines if items should be moved to trash by default instead of really "
"deleting them."
msgstr ""
"Элементтерді біржола өшірудің орнына, оларды үнсіз келісім бойынша қоқыс "
"шелегіне тастау керек пе екенін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:158
msgid "Icon size"
msgstr "Таңбашалар өлшемі"

#: data/org.gnome.gnome-commander.gschema.xml:159
msgid "Size of icons in the file panel."
msgstr "Файл панеліндегі таңбашалардың өлшемі."

#: data/org.gnome.gnome-commander.gschema.xml:163
msgid "Icon scale quality"
msgstr "Таңбаша масштабының сапасы"

#: data/org.gnome.gnome-commander.gschema.xml:164
msgid ""
"Describes the different interpolation modes that can be used with the "
"scaling functions."
msgstr ""
"Масштабтау функцияларымен қолдануға болатын әртүрлі интерполяция режимдерін "
"сипаттайды."

#: data/org.gnome.gnome-commander.gschema.xml:168
msgid "MIME icon directory"
msgstr "MIME таңбашалар бумасы"

#: data/org.gnome.gnome-commander.gschema.xml:169
msgid "Directory in which MIME icons are located."
msgstr "MIME таңбашалары орналасқан бума."

#: data/org.gnome.gnome-commander.gschema.xml:173
msgid "Command line history"
msgstr "Командалық жол тарихы"

#: data/org.gnome.gnome-commander.gschema.xml:174
msgid ""
"This string array represents the history of commands executed in the "
"command line."
msgstr ""
"Бұл жолдық массив командалық жолда орындалған командалар тарихын білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:181
msgid "Command line history length"
msgstr "Командалық жол тарихының ұзындығы"

#: data/org.gnome.gnome-commander.gschema.xml:185
msgid "Split between panels and command line"
msgstr "Панельдер мен командалық жол арасындағы бөлгіш"

#: data/org.gnome.gnome-commander.gschema.xml:186
msgid ""
"Determines the height of file panels in pixels. Remaining vertical space is "
"allocated for the command line."
msgstr ""
"Файл панельдерінің биіктігін пиксельмен анықтайды. Қалған вертикалды орын "
"командалық жолға бөлінеді."

#: data/org.gnome.gnome-commander.gschema.xml:192
msgid "Horizontal orientation"
msgstr "Горизонталды бағдарлау"

#: data/org.gnome.gnome-commander.gschema.xml:193
msgid ""
"Defines if the orientation of the file panels should be horizontal or not."
msgstr ""
"Файл панельдерінің бағдарлануы горизонталды болуы керек пе, жоқ па, соны "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:200
msgid "GUI update rate"
msgstr "GUI жаңарту жиілігі"

#: data/org.gnome.gnome-commander.gschema.xml:201
msgid "Update rate of the graphical user interface in 1/1000ths of a second."
msgstr ""
"Графикалық пайдаланушы интерфейсінің жаңарту жиілігі секундтың 1/1000 "
"бөлігінде."

#: data/org.gnome.gnome-commander.gschema.xml:205
msgid "Show device buttons"
msgstr "Құрылғы батырмаларын көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:206
msgid "Defines if device buttons are shown."
msgstr "Құрылғы батырмалары көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:210
msgid "Show device list"
msgstr "Құрылғылар тізімін көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:211
msgid "Defines if the list of devices is shown."
msgstr "Құрылғылар тізімі көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:215
msgid "Show command line"
msgstr "Командалық жолды көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:216
msgid "Defines if command line is shown."
msgstr "Командалық жол көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:220
msgid "Show toolbar"
msgstr "Саймандар панелін көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:221
msgid "Defines if the toolbar is shown."
msgstr "Сайман панелі көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:225
msgid "Show buttonbar"
msgstr "Батырмалар панелін көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:226
msgid "Defines if the buttonbar is shown."
msgstr "Батырмалар панелі көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:230
msgid "Symlink string"
msgstr "Символдық сілтеме жолы"

#: data/org.gnome.gnome-commander.gschema.xml:231
msgid ""
"This string defines the default name of a newly created symlink. Leave the "
"string empty to use the default value which is hard coded into the program "
"code. A “%s” will be expanded to the item name for which a link should be "
"created."
msgstr ""
"Бұл жол жаңадан жасалған символдық сілтеменің бастапқы атын анықтайды. "
"Бағдарлама кодында бекітілген бастапқы мәнді қолдану үшін жолды бос "
"қалдырыңыз. «%s» сілтеме жасалуы тиіс элемент атына дейін жайылады."

#: data/org.gnome.gnome-commander.gschema.xml:239
msgid "Main window width"
msgstr "Басты терезенің ені"

#: data/org.gnome.gnome-commander.gschema.xml:240
msgid "This option defines the width of the main window."
msgstr "Бұл опция негізгі терезенің енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:246
msgid "List of bookmarks"
msgstr "Бетбелгілер тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:247
msgid "Each entry in this list represents a bookmark."
msgstr "Осы тізімдегі әрбір жазба бетбелгіні білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:253
msgid "Bookmarks window width"
msgstr "Бетбелгілер терезесіның ені"

#: data/org.gnome.gnome-commander.gschema.xml:254
msgid "This option defines the width of the bookmarks window."
msgstr "Бұл опция бетбелгілер терезесінің енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:260
msgid "Bookmarks window height"
msgstr "Бетбелгілер терезесінің биіктігі"

#: data/org.gnome.gnome-commander.gschema.xml:261
msgid "This option defines the height of the bookmarks window."
msgstr "Бұл опция бетбелгілер терезесінің биіктігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:267
msgid "List of connections"
msgstr "Байланыстар тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:268
msgid "Each entry in this list represents a connection."
msgstr "Осы тізімдегі әрбір жазба байланысты білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:274
msgid "Main window height"
msgstr "Басты терезенің биіктігі"

#: data/org.gnome.gnome-commander.gschema.xml:275
msgid "This option defines the height of the main window."
msgstr "Бұл опция негізгі терезенің биіктігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:281
msgid "Options dialog width"
msgstr "Опциялар сұхбат терезесінің ені"

#: data/org.gnome.gnome-commander.gschema.xml:282
msgid "This setting defines the width of the options dialog window."
msgstr "Бұл баптау опциялар сұхбат терезесінің енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:288
msgid "Options dialog height"
msgstr "Опциялар сұхбат терезесінің биіктігі"

#: data/org.gnome.gnome-commander.gschema.xml:289
msgid "This setting defines the height of the options dialog window."
msgstr "Бұл баптау опциялар сұхбат терезесінің биіктігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:295
msgid "Width of icon column"
msgstr "Таңбаша бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:296
msgid "This option defines the width of the icon column."
msgstr "Бұл опция таңбаша бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:302
msgid "Width of name column"
msgstr "Атау бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:303
msgid "This option defines the width of the name column."
msgstr "Бұл опция атау бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:309
msgid "Width of extension column"
msgstr "Кеңейту бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:310
msgid "This option defines the width of the extension column."
msgstr "Бұл опция кеңейту бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:316
msgid "Width of directory column"
msgstr "Бума бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:317
msgid "This option defines the width of the directory column."
msgstr "Бұл опция бума бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:323
msgid "Width of size column"
msgstr "Өлшем бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:324
msgid "This option defines the width of the size column."
msgstr "Бұл опция өлшем бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:330
msgid "Width of date column"
msgstr "Күн бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:331
msgid "This option defines the width of the date column."
msgstr "Бұл опция күн бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:337
msgid "Width of permissions column"
msgstr "Рұқсаттар бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:338
msgid "This option defines the width of the permissions column."
msgstr "Бұл опция рұқсаттар бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:344
msgid "Width of owner column"
msgstr "Иесі бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:345
msgid "This option defines the width of the owner column."
msgstr "Бұл опция иесі бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:351
msgid "Width of group column"
msgstr "Топ бағанының ені"

#: data/org.gnome.gnome-commander.gschema.xml:352
msgid "This option defines the width of the group column."
msgstr "Бұл опция топ бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:358
msgid "List of keybindings"
msgstr "Пернелер тіркесімінің тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:359
msgid "Each entry in this list represents a keybinding."
msgstr "Осы тізімдегі әрбір жазба пернелер тіркесімін білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:366
msgid "Main window state"
msgstr "Негізгі терезе күйі"

#: data/org.gnome.gnome-commander.gschema.xml:367
msgid ""
"The number represents the main window state, e.g. “maximized”, "
"“fullscreen”, etc. and is calculated internally."
msgstr ""
"Сан негізгі терезенің күйін білдіреді (мысалы, «maximized», «fullscreen» "
"және т.б.) және іштей есептеледі."

#: data/org.gnome.gnome-commander.gschema.xml:373
msgid "Middle mouse button mode"
msgstr "Ортаңғы тышқан батырмасының режимі"

#: data/org.gnome.gnome-commander.gschema.xml:374
msgid "Defines what happens when the middle mouse button is clicked."
msgstr "Ортаңғы тышқан батырмасы шертілгенде не болатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:380
msgid "Save directories on exit"
msgstr "Шыққан кезде бумаларды сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:381
msgid ""
"Defines if the current directories are opened again when GNOME Commander is "
"restarted."
msgstr ""
"GNOME Commander қайта іске қосылғанда ағымдағы бумалар қайта ашылатынын "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:387
msgid "Save tabs on exit"
msgstr "Шыққан кезде беттерді сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:388
msgid ""
"Defines if the current open tabs are opened again when GNOME Commander is "
"restarted."
msgstr ""
"GNOME Commander қайта іске қосылғанда ағымдағы ашық беттер қайта ашылатынын "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:394
msgid "Save directory history on exit"
msgstr "Шыққан кезде бумалар тарихын сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:395
msgid "Defines if the history of visited directories is saved on exit."
msgstr "Шыққан кезде қаралған бумалар тарихы сақталатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:401
msgid "Save commandline history on exit"
msgstr "Шыққан кезде командалық жол тарихын сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:402
msgid ""
"Defines if the history of commands in the commandline is saved on exit."
msgstr ""
"Шыққан кезде командалық жолдағы командалар тарихы сақталатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:408
msgid "Save search history on exit"
msgstr "Шыққан кезде іздеу тарихын сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:409
msgid "Defines if the history of search patterns is saved on exit."
msgstr "Шыққан кезде іздеу шаблондарының тарихы сақталатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:415
msgid "Always show tab bar"
msgstr "Беттер панелін әрқашан көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:416
msgid "Defines if the tab bar is always shown."
msgstr "Беттер панелі әрқашан көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:422
#: src/dialogs/options/tabs_tab.rs:76
msgid "Tab lock indicator"
msgstr "Бетті құлыптау индикаторы"

#: data/org.gnome.gnome-commander.gschema.xml:423
msgid "Defines the style of the tab lock indicator."
msgstr "Бетті құлыптау индикаторының стилін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:429
msgid "Case sensitive sorting"
msgstr "Регистрді ескеретін сұрыптау"

#: data/org.gnome.gnome-commander.gschema.xml:430
msgid "This option defines if sorting should be case sensitive."
msgstr "Бұл опция сұрыптау кезінде регистрді ескеру керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:436
#: src/dialogs/options/general_tab.rs:145
msgid "Treat symbolic links as regular files"
msgstr "Символдық сілтемелерді кәдімгі файлдар ретінде қарастыру"

#: data/org.gnome.gnome-commander.gschema.xml:437
msgid ""
"This option defines if symbolic links should be treated as regular files. "
"In the file panel they are listed between other files and not at the top if "
"their target is not existing."
msgstr ""
"Бұл опция символдық сілтемелерді кәдімгі файлдар ретінде қарастыру "
"керектігін анықтайды. Файл панелінде олар басқа файлдардың арасында "
"көрсетіледі, егер олардың мақсаты жоқ болса, жоғарыда көрсетілмейді."

#: data/org.gnome.gnome-commander.gschema.xml:444
msgid "Select directories when all is marked"
msgstr "Барлығы белгіленгенде бумаларды таңдау"

#: data/org.gnome.gnome-commander.gschema.xml:445
msgid ""
"This option defines if directories will be marked when all items in a file "
"panel should be marked."
msgstr ""
"Бұл опция файл панеліндегі барлық элементтер белгіленген кезде бумалардың "
"да белгіленетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:451
msgid "Allow multiple instances"
msgstr "Бірнеше данаға рұқсат беру"

#: data/org.gnome.gnome-commander.gschema.xml:452
msgid "This option defines if multiple instances are allowed."
msgstr "Бұл опция бірнеше дананың болуына рұқсат етілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:458
msgid "Quick search exact match begin"
msgstr "Жылдам іздеудің басынан сәйкес келуі"

#: data/org.gnome.gnome-commander.gschema.xml:459
msgid ""
"This option defines if quick search should match explicitly at the "
"beginning of an item name."
msgstr ""
"Бұл опция жылдам іздеу элемент атының басында нақты сәйкес келуі керектігін "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:465
msgid "Quick search exact match end"
msgstr "Жылдам іздеудің соңынан сәйкес келуі"

#: data/org.gnome.gnome-commander.gschema.xml:466
msgid ""
"This option defines if quick search should match explicitly at the end of "
"an item name."
msgstr ""
"Бұл опция жылдам іздеу элемент атының соңында нақты сәйкес келуі керектігін "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:472
msgid "Only device icons"
msgstr "Тек құрылғы таңбашалары"

#: data/org.gnome.gnome-commander.gschema.xml:473
msgid ""
"This option defines if only device icons should be shown instead of icons "
"and text label."
msgstr ""
"Бұл опция таңбашалар мен мәтіндік белгілердің орнына тек құрылғы "
"таңбашаларын көрсету керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:479
msgid "Show the samba workgroups icon"
msgstr "Samba жұмыс топтарының таңбашасын көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:480
msgid ""
"This option defines if the Samba workgroups icon should be shown in the "
"devices list."
msgstr ""
"Бұл опция құрылғылар тізімінде Samba жұмыс топтарының таңбашасы көрсетілуі "
"керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:486
msgid "Main menu visibility"
msgstr "Негізгі мәзірдің көрінуі"

#: data/org.gnome.gnome-commander.gschema.xml:487
msgid "This option defines if the main menu is visible or not."
msgstr ""
"Бұл опция негізгі мәзірдің көрінетінін немесе көрінбейтінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:493
msgid "Quick search shortcut"
msgstr "Жылдам іздеу жарлығы"

#: data/org.gnome.gnome-commander.gschema.xml:494
msgid "This option defines the shortcut for quick search."
msgstr "Бұл опция жылдам іздеу жарлығын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:500
msgid "Legacy list of file tabs"
msgstr "Файл беттерінің ескі тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:501
#: data/org.gnome.gnome-commander.gschema.xml:572
msgid ""
"This setting is only present for backwards compatibility and will be "
"removed in future."
msgstr "Бұл баптау тек кері үйлесімділік үшін бар және болашақта жойылады."

#: data/org.gnome.gnome-commander.gschema.xml:507
msgid "List of file tabs"
msgstr "Файл беттерінің тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:508
msgid ""
"The entries in this list are used for restoring the tabs and their history "
"from the last session."
msgstr ""
"Осы тізімдегі жазбалар соңғы сессиядағы беттер мен олардың тарихын қалпына "
"келтіру үшін қолданылады."

#: data/org.gnome.gnome-commander.gschema.xml:515
msgid "List of devices - deprecated"
msgstr "Құрылғылар тізімі - ескірген"

#: data/org.gnome.gnome-commander.gschema.xml:516
#: data/org.gnome.gnome-commander.gschema.xml:523
msgid "The entries in this list represent the devices configured by the user."
msgstr "Осы тізімдегі жазбалар пайдаланушы баптаған құрылғыларды білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:522
msgid "List of devices"
msgstr "Құрылғылар тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:529
msgid "List of favorite apps"
msgstr "Таңдаулы қолданбалар тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:530
msgid ""
"The entries in this list represent the favorite apps configured by the user."
msgstr ""
"Осы тізімдегі жазбалар пайдаланушы баптаған таңдаулы қолданбаларды "
"білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:536
msgid "Search window width"
msgstr "Іздеу терезесінің ені"

#: data/org.gnome.gnome-commander.gschema.xml:537
msgid "This option defines the width of the search window."
msgstr "Бұл опция іздеу терезесінің енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:543
msgid "Search window height"
msgstr "Іздеу терезесінің биіктігі"

#: data/org.gnome.gnome-commander.gschema.xml:544
msgid "This option defines the height of the search window."
msgstr "Бұл опция іздеу терезесінің биіктігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:550
msgid "Search window is transient"
msgstr "Іздеу терезесі уақытша"

#: data/org.gnome.gnome-commander.gschema.xml:551
msgid ""
"Defines if the search window is transient or if it can be minimized and "
"moved behind the main window."
msgstr ""
"Іздеу терезесінің уақытша екенін немесе оны кішірейтіп, негізгі терезенің "
"артына жылжытуға болатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:557
msgid "Search text history"
msgstr "Іздеу мәтінінің тарихы"

#: data/org.gnome.gnome-commander.gschema.xml:558
msgid ""
"This string array represents the history of text searches in the search "
"tool."
msgstr ""
"Бұл жолдық массив іздеу сайманындағы мәтіндік іздеулердің тарихын білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:564
msgid "Search pattern history"
msgstr "Іздеу шаблондарының тарихы"

#: data/org.gnome.gnome-commander.gschema.xml:565
msgid ""
"This string array represents the history of regular expression searches in "
"the search tool."
msgstr ""
"Бұл жолдық массив іздеу сайманындағы тұрақты өрнектермен іздеу тарихын "
"білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:571
msgid "Legacy search tool profiles"
msgstr "Іздеу сайманының ескі профильдері"

#: data/org.gnome.gnome-commander.gschema.xml:578
msgid "List of search tool profiles"
msgstr "Іздеу сайманы профильдерінің тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:579
msgid ""
"The entries in this array represent the profiles in the search tool with "
"specific settings for each profile."
msgstr ""
"Осы массивтегі жазбалар іздеу сайманындағы әрбір профиль үшін арнайы "
"баптаулары бар профильдерді білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:587
msgid "Quick connect URI"
msgstr "Жылдам қосылу URI"

#: data/org.gnome.gnome-commander.gschema.xml:588
msgid "Unified resource identifier for quick connections."
msgstr "Жылдам қосылымдарға арналған ресурстардың бірыңғай идентификаторы."

#: data/org.gnome.gnome-commander.gschema.xml:599
msgid "Password for anonymous FTP connections"
msgstr "Анонимді FTP қосылымдарына арналған пароль"

#: data/org.gnome.gnome-commander.gschema.xml:600
msgid "This string defines the password for anonymous FTP connections."
msgstr "Бұл жол анонимді FTP қосылымдарына арналған парольді анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:608
msgid "Confirm delete"
msgstr "Өшіруді растау"

#: data/org.gnome.gnome-commander.gschema.xml:609
msgid "Defines if deletion of an item should be confirmed."
msgstr "Элементті өшіруді растау керек пе екенін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:615
msgid "Delete default"
msgstr "Өшірудің бастапқы мәні"

#: data/org.gnome.gnome-commander.gschema.xml:616
msgid ""
"This setting defines the default active option in the delete confirmation "
"dialog."
msgstr ""
"Бұл баптау өшіруді растау сұхбат терезесіндегі үнсіз келісім бойынша "
"белсенді опцияны анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:622
msgid "Confirm copy overwrite"
msgstr "Көшіру кезінде қайта жазуды растау"

#: data/org.gnome.gnome-commander.gschema.xml:623
msgid ""
"This option defines the default behavior when items will be overwritten by "
"a copy command."
msgstr ""
"Бұл опция элементтер көшіру командасымен қайта жазылатын кездегі үнсіз "
"келісім бойынша әрекетті анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:629
msgid "Confirm move overwrite"
msgstr "Жылжыту кезінде қайта жазуды растау"

#: data/org.gnome.gnome-commander.gschema.xml:630
msgid ""
"This option defines the default behavior when items will be overwritten by "
"a move command."
msgstr ""
"Бұл опция элементтер жылжыту командасымен қайта жазылатын кездегі үнсіз "
"келісім бойынша әрекетті анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:636
msgid "Confirm mouse drag and drop"
msgstr "Тышқанмен сүйреп апаруды растау"

#: data/org.gnome.gnome-commander.gschema.xml:637
msgid "This option defines the behavior of mouse drag and drop operations."
msgstr "Бұл опция тышқанмен сүйреп апару операцияларының әрекетін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:645
msgid "Hide unknown filetypes"
msgstr "Белгісіз файл түрлерін жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:646
msgid "Hide files which type does not match to one of the other types."
msgstr "Түрі басқа түрлердің ешқайсысына сәйкес келмейтін файлдарды жасыру."

#: data/org.gnome.gnome-commander.gschema.xml:650
msgid "Hide regular files"
msgstr "Кәдімгі файлдарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:654
msgid "Hide directories"
msgstr "Бумаларды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:658
msgid "Hide symbolic links"
msgstr "Символдық сілтемелерді жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:662
msgid ""
"Hide special files, such as a socket, fifo, block devices, or character "
"devices."
msgstr ""
"Сокет, fifo, блоктық құрылғылар немесе символдық құрылғылар сияқты арнайы "
"файлдарды жасыру."

#: data/org.gnome.gnome-commander.gschema.xml:666
msgid "Hide shortcut files (Windows systems)"
msgstr "Жарлық файлдарын жасыру (Windows жүйелері)"

#: data/org.gnome.gnome-commander.gschema.xml:670
msgid "Hide mountable locations"
msgstr "Тіркелетін орындарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:674
msgid "Hide virtual files"
msgstr "Виртуалды файлдарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:678
msgid "Hide volatile files"
msgstr "Тұрақсыз файлдарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:682
msgid "Hide files and folders starting with a dot"
msgstr "Нүктеден басталатын файлдар мен бумаларды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:686
msgid "Hide backup files"
msgstr "Сақтық көшірме файлдарын жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:687
msgid "Hide all files with a suffix defined as the backup pattern."
msgstr ""
"Сақтық көшірме шаблоны ретінде анықталған суффиксі бар барлық файлдарды "
"жасыру."

#: data/org.gnome.gnome-commander.gschema.xml:691
msgid "Backup file pattern"
msgstr "Сақтық көшірме файлының шаблоны"

#: data/org.gnome.gnome-commander.gschema.xml:692
msgid ""
"The given string defines suffixes (separated by semicolon) for files which "
"should be filtered out if backup files should be hidden."
msgstr ""
"Берілген жол сақтық көшірме файлдарын жасыру қажет болған жағдайда "
"сүзгіленуі тиіс файлдар үшін суффикстерді (нүктелі үтірмен бөлінген) "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:701
msgid "Do not download files"
msgstr "Файлдарды жүктеп алмау"

#: data/org.gnome.gnome-commander.gschema.xml:702
msgid ""
"This option defines if remote files should be downloaded before opened by "
"external programs."
msgstr ""
"Бұл опция қашықтағы файлдарды сыртқы бағдарламалармен ашпас бұрын жүктеп "
"алу керек пе екенін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:708
msgid "Use internal viewer"
msgstr "Ішкі қарап шығушыны қолдану"

#: data/org.gnome.gnome-commander.gschema.xml:709
msgid "This option defines if the internal viewer should be used by default."
msgstr ""
"Бұл опция үнсіз келісім бойынша ішкі қарап шығушыны қолдану керектігін "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:715
msgid "Viewer command"
msgstr "Қарап шығу командасы"

#: data/org.gnome.gnome-commander.gschema.xml:716
msgid "This string defines the command for starting the (external) viewer."
msgstr "Бұл жол (сыртқы) қарап шығушыны іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:722
msgid "Editor command"
msgstr "Түзеткіш командасы"

#: data/org.gnome.gnome-commander.gschema.xml:723
msgid "This string defines the command for starting the editor."
msgstr "Бұл жол түзеткішті іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:729
msgid "Differ command"
msgstr "Салыстыру командасы"

#: data/org.gnome.gnome-commander.gschema.xml:730
msgid "This string defines the command for starting the diff tool."
msgstr "Бұл жол салыстыру сайманын іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:736
msgid "Use internal search"
msgstr "Ішкі іздеуді қолдану"

#: data/org.gnome.gnome-commander.gschema.xml:737
msgid "This option defines if the internal search should be used by default."
msgstr ""
"Бұл опция үнсіз келісім бойынша ішкі іздеуді қолдану керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:743
msgid "Search command"
msgstr "Іздеу командасы"

#: data/org.gnome.gnome-commander.gschema.xml:744
msgid ""
"This string defines the command for starting an external file search tool."
msgstr ""
"Бұл жол файлдарды іздеудің сыртқы сайманын іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:750
msgid "Command for opening a terminal"
msgstr "Терминалды ашу командасы"

#: data/org.gnome.gnome-commander.gschema.xml:751
