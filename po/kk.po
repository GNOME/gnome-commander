#: data/org.gnome.gnome-commander.appdata.xml.in:7
#: data/org.gnome.gnome-commander.desktop.in:2 src/gnome-cmd-application.cc:82
#: src/gnome-cmd-main-win.cc:564
msgid "GNOME Commander"
msgstr "GNOME Commander"

#: data/org.gnome.gnome-commander.appdata.xml.in:8
msgid "Two-pane file manager"
msgstr "Екі панельді файл менеджері"

#: data/org.gnome.gnome-commander.appdata.xml.in:10
msgid ""
"GNOME Commander is a “two-pane” graphical file manager for the GNOME desktop "
"environment. It features separate tabs for each pane, setting up custom device "
"buttons, bookmark manager, fully integrated commandline, file quick search, an "
"internal image viewer, a powerful batch renaming tool, and FTP and Samba "
"access."
msgstr ""
"GNOME Commander — GNOME жұмыс үстелі ортасына арналған «екі панельді» "
"графикалық файл менеджері. Оның мүмкіндіктеріне әр панельге арналған бөлек "
"беттер, пайдаланушы құрылғы батырмаларын баптау, бетбелгілер менеджері, толық "
"біріктірілген командалық жол, файлдарды жылдам іздеу, ішкі сурет қарау құралы, "
"қуатты топтық атын өзгерту сайманы және FTP мен Samba арқылы қол жеткізу "
"кіреді."

#: data/org.gnome.gnome-commander.appdata.xml.in:17
msgid ""
"GNOME Commander aims to advanced users who like to focus on precise file "
"management, working in parallel through special applications, and running "
"smart commands."
msgstr ""
"GNOME Commander файлдарды дәл басқаруға, арнайы қолданбалар арқылы қатар жұмыс "
"істеуге және ақылды командаларды орындауға назар аударатын тәжірибелі "
"пайдаланушыларға арналған."

#. developer_name tag deprecated with Appstream 1.0
