#: data/org.gnome.gnome-commander.gschema.xml:340
msgid "This option defines the width of the group column."
msgstr "Бұл опция топ бағанының енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:346
msgid "List of keybindings"
msgstr "Пернелер тіркесімінің тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:347
msgid "Each entry in this list represents a keybinding."
msgstr "Осы тізімдегі әрбір жазба пернелер тіркесімін білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:354
msgid "Main window state"
msgstr "Негізгі терезе күйі"

#: data/org.gnome.gnome-commander.gschema.xml:355
msgid ""
"The number represents the main window state, e.g. “maximized”, “fullscreen”, "
"etc. and is calculated internally."
msgstr ""
"Сан негізгі терезенің күйін білдіреді (мысалы, «maximized», «fullscreen» және "
"т.б.) және іштей есептеледі."

#: data/org.gnome.gnome-commander.gschema.xml:361
msgid "Middle mouse button mode"
msgstr "Ортаңғы тышқан батырмасының режимі"

#: data/org.gnome.gnome-commander.gschema.xml:362
msgid "Defines what happens when the middle mouse button is clicked."
msgstr "Ортаңғы тышқан батырмасы шертілгенде не болатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:368
msgid "Save directories on exit"
msgstr "Шыққан кезде бумаларды сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:369
msgid ""
"Defines if the current directories are opened again when GNOME Commander is "
"restarted."
msgstr ""
"GNOME Commander қайта іске қосылғанда ағымдағы бумалар қайта ашылатынын "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:375
msgid "Save tabs on exit"
msgstr "Шыққан кезде беттерді сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:376
msgid ""
"Defines if the current open tabs are opened again when GNOME Commander is "
"restarted."
msgstr ""
"GNOME Commander қайта іске қосылғанда ағымдағы ашық беттер қайта ашылатынын "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:382
msgid "Save directory history on exit"
msgstr "Шыққан кезде бумалар тарихын сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:383
msgid "Defines if the history of visited directories is saved on exit."
msgstr "Шыққан кезде қаралған бумалар тарихы сақталатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:389
msgid "Save commandline history on exit"
msgstr "Шыққан кезде командалық жол тарихын сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:390
msgid "Defines if the history of commands in the commandline is saved on exit."
msgstr ""
"Шыққан кезде командалық жолдағы командалар тарихы сақталатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:396
msgid "Save search history on exit"
msgstr "Шыққан кезде іздеу тарихын сақтау"

#: data/org.gnome.gnome-commander.gschema.xml:397
msgid "Defines if the history of search patterns is saved on exit."
msgstr "Шыққан кезде іздеу шаблондарының тарихы сақталатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:403
msgid "Always show tab bar"
msgstr "Беттер панелін әрқашан көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:404
msgid "Defines if the tab bar is always shown."
msgstr "Беттер панелі әрқашан көрсетілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:410
#: src/dialogs/gnome-cmd-options-dialog.cc:999
msgid "Tab lock indicator"
msgstr "Бетті құлыптау индикаторы"

#: data/org.gnome.gnome-commander.gschema.xml:411
msgid "Defines the style of the tab lock indicator."
msgstr "Бетті құлыптау индикаторының стилін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:417
msgid "Case sensitive sorting"
msgstr "Регистрді ескеретін сұрыптау"

#: data/org.gnome.gnome-commander.gschema.xml:418
msgid "This option defines if sorting should be case sensitive."
msgstr "Бұл опция сұрыптау кезінде регистрді ескеру керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:424
msgid "Select directories when all is marked"
msgstr "Барлығы белгіленгенде бумаларды таңдау"

#: data/org.gnome.gnome-commander.gschema.xml:425
msgid ""
"This option defines if directories will be marked when all items in a file "
"pane should be marked."
msgstr ""
"Бұл опция файл панеліндегі барлық элементтер ерекшеленген кезде бумалардың "
"ерекшеленетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:431
msgid "Allow multiple instances"
msgstr "Бірнеше данаға рұқсат беру"

#: data/org.gnome.gnome-commander.gschema.xml:432
msgid "This option defines if multiple instances are allowed."
msgstr "Бұл опция бірнеше дананың болуына рұқсат етілетінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:438
msgid "Quick search exact match begin"
msgstr "Жылдам іздеудің басынан сәйкес келуі"

#: data/org.gnome.gnome-commander.gschema.xml:439
msgid ""
"This option defines if quick search should match explicitly at the beginning "
"of an item name."
msgstr ""
"Бұл опция жылдам іздеу элемент атының басында нақты сәйкес келуі керектігін "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:445
msgid "Quick search exact match end"
msgstr "Жылдам іздеудің соңынан сәйкес келуі"

#: data/org.gnome.gnome-commander.gschema.xml:446
msgid ""
"This option defines if quick search should match explicitly at the end of an "
"item name."
msgstr ""
"Бұл опция жылдам іздеу элемент атының соңында нақты сәйкес келуі керектігін "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:452
msgid "Only device icons"
msgstr "Тек құрылғы таңбашалары"

#: data/org.gnome.gnome-commander.gschema.xml:453
msgid ""
"This option defines if only device icons should be shown instead of icons and "
"text label."
msgstr ""
"Бұл опция таңбашалар мен мәтіндік белгілердің орнына тек құрылғы таңбашаларын "
"көрсету керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:459
msgid "Show the samba workgroups icon"
msgstr "Samba жұмыс топтарының таңбашасын көрсету"

#: data/org.gnome.gnome-commander.gschema.xml:460
msgid ""
"This option defines if the Samba workgroups icon should be shown in the "
"devices list."
msgstr ""
"Бұл опция құрылғылар тізімінде Samba жұмыс топтарының таңбашасы көрсетілуі "
"керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:466
msgid "Main menu visibility"
msgstr "Негізгі мәзірдің көрінуі"

#: data/org.gnome.gnome-commander.gschema.xml:467
msgid "This option defines if the main menu is visible or not."
msgstr "Бұл опция негізгі мәзірдің көрінетінін немесе көрінбейтінін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:473
msgid "Quick search shortcut"
msgstr "Жылдам іздеу жарлығы"

#: data/org.gnome.gnome-commander.gschema.xml:474
msgid "This option defines the shortcut for quick search."
msgstr "Бұл опция жылдам іздеу жарлығын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:480
msgid "List of file tabs"
msgstr "Файл беттерінің тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:481
msgid ""
"The entries in this list are used for restoring the tabs from the last session."
msgstr ""
"Бұл тізімдегі жазбалар соңғы сессиядағы беттерді қалпына келтіру үшін "
"пайдаланылады."

#: data/org.gnome.gnome-commander.gschema.xml:488
msgid "List of devices - deprecated"
msgstr "Құрылғылар тізімі - ескірген"

#: data/org.gnome.gnome-commander.gschema.xml:489
#: data/org.gnome.gnome-commander.gschema.xml:496
msgid "The entries in this list represent the devices configured by the user."
msgstr "Осы тізімдегі жазбалар пайдаланушы баптаған құрылғыларды білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:495
msgid "List of devices"
msgstr "Құрылғылар тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:502
msgid "List of favorite apps"
msgstr "Таңдаулы қолданбалар тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:503
msgid ""
"The entries in this list represent the favorite apps configured by the user."
msgstr ""
"Осы тізімдегі жазбалар пайдаланушы баптаған таңдаулы қолданбаларды білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:509
msgid "Search window width"
msgstr "Іздеу терезесінің ені"

#: data/org.gnome.gnome-commander.gschema.xml:510
msgid "This option defines the width of the search window."
msgstr "Бұл опция іздеу терезесінің енін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:516
msgid "Search window height"
msgstr "Іздеу терезесінің биіктігі"

#: data/org.gnome.gnome-commander.gschema.xml:517
msgid "This option defines the height of the search window."
msgstr "Бұл опция іздеу терезесінің биіктігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:523
msgid "Search window is transient"
msgstr "Іздеу терезесі уақытша"

#: data/org.gnome.gnome-commander.gschema.xml:524
msgid ""
"Defines if the search window is transient or if it can be minimized and moved "
"behind the main window."
msgstr ""
"Іздеу терезесінің уақытша екенін немесе оны кішірейтіп, негізгі терезенің "
"артына жылжытуға болатынын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:530
msgid "Search text history"
msgstr "Іздеу мәтінінің тарихы"

#: data/org.gnome.gnome-commander.gschema.xml:531
msgid ""
"This string array represents the history of text searches in the search tool."
msgstr ""
"Бұл жолдық массив іздеу сайманындағы мәтіндік іздеулердің тарихын білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:537
msgid "Search pattern history"
msgstr "Іздеу шаблондарының тарихы"

#: data/org.gnome.gnome-commander.gschema.xml:538
msgid ""
"This string array represents the history of regular expression searches in the "
"search tool."
msgstr ""
"Бұл жолдық массив іздеу сайманындағы тұрақты өрнектермен іздеу тарихын "
"білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:544
msgid "List of search tool profiles"
msgstr "Іздеу сайманы профильдерінің тізімі"

#: data/org.gnome.gnome-commander.gschema.xml:545
msgid ""
"The entries in this array represent the profiles in the search tool with "
"specific settings for each profile."
msgstr ""
"Осы массивтегі жазбалар іздеу сайманындағы әрбір профиль үшін арнайы "
"баптаулары бар профильдерді білдіреді."

#: data/org.gnome.gnome-commander.gschema.xml:553
msgid "Quick connect URI"
msgstr "Жылдам қосылу URI"

#: data/org.gnome.gnome-commander.gschema.xml:554
msgid "Unified resource identifier for quick connections."
msgstr "Жылдам қосылымдарға арналған ресурстардың бірыңғай идентификаторы."

#: data/org.gnome.gnome-commander.gschema.xml:565
msgid "Password for anonymous FTP connections"
msgstr "Анонимді FTP қосылымдарына арналған пароль"

#: data/org.gnome.gnome-commander.gschema.xml:566
msgid "This string defines the password for anonymous FTP connections."
msgstr "Бұл жол анонимді FTP қосылымдарына арналған парольді анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:574
msgid "Confirm delete"
msgstr "Өшіруді растау"

#: data/org.gnome.gnome-commander.gschema.xml:575
msgid "Defines if deletion of an item should be confirmed."
msgstr "Элементті өшіруді растау керек пе екенін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:581
msgid "Delete default"
msgstr "Өшірудің бастапқы мәні"

#: data/org.gnome.gnome-commander.gschema.xml:582
msgid ""
"This setting defines the default active option in the delete confirmation "
"dialog."
msgstr ""
"Бұл баптау өшіруді растау сұхбат терезесіндегі үнсіз келісім бойынша белсенді "
"опцияны анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:588
msgid "Confirm copy overwrite"
msgstr "Көшіру кезінде қайта жазуды растау"

#: data/org.gnome.gnome-commander.gschema.xml:589
msgid ""
"This option defines the default behavior when items will be overwritten by a "
"copy command."
msgstr ""
"Бұл опция элементтер көшіру командасымен қайта жазылатын кездегі үнсіз келісім "
"бойынша әрекетті анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:595
msgid "Confirm move overwrite"
msgstr "Жылжыту кезінде қайта жазуды растау"

#: data/org.gnome.gnome-commander.gschema.xml:596
msgid ""
"This option defines the default behavior when items will be overwritten by a "
"move command."
msgstr ""
"Бұл опция элементтер жылжыту командасымен қайта жазылатын кездегі үнсіз "
"келісім бойынша әрекетті анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:602
msgid "Confirm mouse drag and drop"
msgstr "Тышқанмен сүйреп апаруды растау"

#: data/org.gnome.gnome-commander.gschema.xml:603
msgid "This option defines the behavior of mouse drag and drop operations."
msgstr "Бұл опция тышқанмен сүйреп апару операцияларының әрекетін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:611
msgid "Hide unknown filetypes"
msgstr "Белгісіз файл түрлерін жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:612
msgid "Hide files which type does not match to one of the other types."
msgstr "Түрі басқа түрлердің ешқайсысына сәйкес келмейтін файлдарды жасыру."

#: data/org.gnome.gnome-commander.gschema.xml:616
msgid "Hide regular files"
msgstr "Кәдімгі файлдарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:620
msgid "Hide directories"
msgstr "Бумаларды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:624
msgid "Hide symbolic links"
msgstr "Символдық сілтемелерді жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:628
msgid ""
"Hide special files, such as a socket, fifo, block devices, or character "
"devices."
msgstr ""
"Сокет, fifo, блоктық құрылғылар немесе символдық құрылғылар сияқты арнайы "
"файлдарды жасыру."

#: data/org.gnome.gnome-commander.gschema.xml:632
msgid "Hide shortcut files (Windows systems)"
msgstr "Жарлық файлдарын жасыру (Windows жүйелері)"

#: data/org.gnome.gnome-commander.gschema.xml:636
msgid "Hide mountable locations"
msgstr "Тіркелетін орындарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:640
msgid "Hide virtual files"
msgstr "Виртуалды файлдарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:644
msgid "Hide volatile files"
msgstr "Тұрақсыз файлдарды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:648
msgid "Hide files and folders starting with a dot"
msgstr "Нүктеден басталатын файлдар мен бумаларды жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:652
msgid "Hide backup files"
msgstr "Сақтық көшірме файлдарын жасыру"

#: data/org.gnome.gnome-commander.gschema.xml:653
msgid "Hide all files with a suffix defined as the backup pattern."
msgstr ""
"Сақтық көшірме шаблоны ретінде анықталған суффиксі бар барлық файлдарды жасыру."

#: data/org.gnome.gnome-commander.gschema.xml:657
msgid "Backup file pattern"
msgstr "Сақтық көшірме файлының шаблоны"

#: data/org.gnome.gnome-commander.gschema.xml:658
msgid ""
"The given string defines suffixes (separated by semicolon) for files which "
"should be filtered out if backup files should be hidden."
msgstr ""
"Берілген жол сақтық көшірме файлдарын жасыру қажет болған жағдайда сүзгіленуі "
"тиіс файлдар үшін суффикстерді (нүктелі үтірмен бөлінген) анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:667
msgid "Do not download files"
msgstr "Файлдарды жүктеп алмау"

#: data/org.gnome.gnome-commander.gschema.xml:668
msgid ""
"This option defines if remote files should be downloaded before opened by "
"external programs."
msgstr ""
"Бұл опция қашықтағы файлдарды сыртқы бағдарламалармен ашпас бұрын жүктеп алу "
"керек пе екенін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:674
msgid "Use internal viewer"
msgstr "Ішкі қарап шығушыны қолдану"

#: data/org.gnome.gnome-commander.gschema.xml:675
msgid "This option defines if the internal viewer should be used by default."
msgstr ""
"Бұл опция үнсіз келісім бойынша ішкі қарап шығушыны қолдану керектігін "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:681
msgid "Viewer command"
msgstr "Қарап шығу командасы"

#: data/org.gnome.gnome-commander.gschema.xml:682
msgid "This string defines the command for starting the (external) viewer."
msgstr "Бұл жол (сыртқы) қарап шығушыны іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:688
msgid "Editor command"
msgstr "Түзеткіш командасы"

#: data/org.gnome.gnome-commander.gschema.xml:689
msgid "This string defines the command for starting the editor."
msgstr "Бұл жол түзеткішті іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:695
msgid "Differ command"
msgstr "Салыстыру командасы"

#: data/org.gnome.gnome-commander.gschema.xml:696
msgid "This string defines the command for starting the diff tool."
msgstr "Бұл жол салыстыру сайманын іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:702
msgid "Use internal search"
msgstr "Ішкі іздеуді қолдану"

#: data/org.gnome.gnome-commander.gschema.xml:703
msgid "This option defines if the internal search should be used by default."
msgstr ""
"Бұл опция үнсіз келісім бойынша ішкі іздеуді қолдану керектігін анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:709
msgid "Search command"
msgstr "Іздеу командасы"

#: data/org.gnome.gnome-commander.gschema.xml:710
msgid ""
"This string defines the command for starting an external file search tool."
msgstr ""
"Бұл жол файлдарды іздеудің сыртқы сайманын іске қосу командасын анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:716
msgid "Leave terminal open"
msgstr "Терминалды ашық қалдыру"

#: data/org.gnome.gnome-commander.gschema.xml:717
msgid ""
"This option defines if a terminal window should stay open after a command "
"finishes inside of it."
msgstr ""
"Бұл опция команда аяқталғаннан кейін терминал терезесінің ашық қалу-қалмауын "
"анықтайды."

#: data/org.gnome.gnome-commander.gschema.xml:723
msgid "Command for opening a terminal"
msgstr "Терминалды ашу командасы"

