#: data/org.gnome.gnome-commander.gschema.xml:884
msgid "LS_COLORS red foreground mapping"
msgstr "Mapeamento de primeiro plano de vermelho de LS_COLORS"

#: data/org.gnome.gnome-commander.gschema.xml:885
msgid ""
